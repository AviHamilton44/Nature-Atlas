<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Darukaa.Earth — Nature Indicator Atlas</title>
<link rel="icon" type="image/png" href="Favicon.png">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://unpkg.com/lucide@latest"></script>
<style>
:root {
  --ink: #0e1a0f;
  --paper: #f7f5f0;
  --paper2: #ebe6da;
  --moss: #2d6a3f;
  --moss-light: #4a9e63;
  --moss-pale: #eaf5ec;
  --earth: #8b5e3c;
  --earth-pale: #f6efe6;
  --water: #1a4f7a;
  --water-pale: #e6f2fa;
  --fire: #b94a2c;
  --fire-pale: #fdf0ec;
  --sky: #4a2878;
  --sky-pale: #f5edf9;
  --gold: #d4a373;
  --gold-pale: #fefae0;
  --carbon: #1a6b5a;
  --carbon-pale: #eaf6f4;
  --shield: #2e4057;
  --shield-pale: #eef2f7;
  --composite: #6b2d82;
  --composite-pale: #f5edf9;
  --nbs: #27ae60;
  --nbs-pale: #eafaf1;
  --radius: 14px;
  --transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  --shadow-sm: 0 2px 12px rgba(14,26,15,0.04);
  --shadow: 0 8px 30px rgba(14,26,15,0.06);
  --shadow-lg: 0 16px 48px rgba(14,26,15,0.12);
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--paper);
  color: var(--ink);
  min-height: 100vh;
  font-size: 15px;
  line-height: 1.6;
  overflow-x: hidden;
  scroll-behavior: smooth;
}

/* ─── HEADER ─── */
.site-header {
  background: rgba(14, 26, 15, 0.9);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  color: var(--paper);
  padding: 0;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1.5px solid rgba(74, 158, 99, 0.2);
}
.header-inner {
  max-width: 1600px;
  margin: 0 auto;
  padding: 14px 32px;
  display: flex;
  align-items: center;
  gap: 24px;
  flex-wrap: wrap;
}
.logo {
  font-family: 'DM Serif Display', serif;
  font-size: 1.45rem;
  letter-spacing: -0.5px;
  color: var(--paper);
  display: flex;
  align-items: center;
  gap: 12px;
  white-space: nowrap;
  text-decoration: none;
}
.logo-sub {
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  color: rgba(245,242,235,0.5);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-left: 2px;
}
.header-stats {
  display: flex;
  gap: 24px;
  margin-left: auto;
  align-items: center;
  flex-wrap: wrap;
}
.hstat {
  font-family: 'DM Mono', monospace;
  font-size: 0.76rem;
  color: rgba(245,242,235,0.6);
  display: flex;
  align-items: center;
  gap: 6px;
}
.hstat strong { color: var(--moss-light); font-size: 1.05rem; font-weight: 600; }

.header-actions {
  display: flex;
  align-items: center;
  gap: 12px;
}

/* ─── HERO ─── */
.hero {
  background: radial-gradient(circle at 80% 20%, #1e3d25 0%, #0e1a0f 100%);
  color: var(--paper);
  padding: 80px 32px 64px;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute; inset: 0;
  background: url("data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%234a9e63' fill-opacity='0.04'%3E%3Cpath d='M40 0l40 40-40 40L0 40z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  opacity: 1;
}

/* Floating leaves animations */
.floating-leaves {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
  z-index: 1;
}
.leaf-svg {
  position: absolute;
  fill: var(--moss-light);
  opacity: 0.12;
  animation: float 20s infinite linear;
}
@keyframes float {
  0% { transform: translateY(110vh) rotate(0deg) translateX(0); }
  50% { transform: translateY(50vh) rotate(180deg) translateX(50px); }
  100% { transform: translateY(-10vh) rotate(360deg) translateX(-50px); }
}

.hero-inner {
  max-width: 1600px;
  margin: 0 auto;
  position: relative;
  z-index: 2;
}
.hero h1 {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(2.2rem, 5vw, 3.8rem);
  line-height: 1.12;
  margin-bottom: 20px;
  letter-spacing: -0.8px;
}
.hero h1 em { color: var(--moss-light); font-style: italic; }
.hero p {
  font-size: 1.1rem;
  color: rgba(245,242,235,0.78);
  max-width: 760px;
  margin-bottom: 36px;
  line-height: 1.7;
}
.framework-badges {
  display: flex; gap: 12px; flex-wrap: wrap;
}
.fbadge {
  font-family: 'DM Mono', monospace;
  font-size: 0.75rem;
  letter-spacing: 0.08em;
  padding: 6px 14px;
  border: 1.5px solid;
  border-radius: 20px;
  text-transform: uppercase;
  font-weight: 550;
  cursor: pointer;
  transition: var(--transition);
  background: transparent;
}
.fbadge.tnfd { color: #6fcf97; border-color: rgba(111,207,151,0.4); }
.fbadge.sbtn { color: #56cfe1; border-color: rgba(86,207,225,0.4); }
.fbadge.csrd { color: #ffd166; border-color: rgba(255,209,102,0.4); }
.fbadge.brsr { color: #ff9f1c; border-color: rgba(255,159,28,0.4); }

.fbadge:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(255,255,255,0.1);
}
.fbadge.active {
  background: currentColor;
  color: #0e1a0f !important;
  font-weight: 600;
  box-shadow: 0 0 20px currentColor;
  border-color: transparent;
}

/* ─── CONTROLS ─── */
.controls-bar {
  background: rgba(235, 230, 218, 0.85);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-bottom: 1px solid rgba(14,26,15,0.06);
  position: sticky;
  top: 61px;
  z-index: 90;
  padding: 14px 32px;
  transition: var(--transition);
}
.controls-inner {
  max-width: 1600px;
  margin: 0 auto;
  display: flex;
  gap: 12px;
  align-items: center;
  flex-wrap: wrap;
}
.search-wrap {
  position: relative;
  flex: 1.5;
  min-width: 240px;
  max-width: 380px;
}
.search-wrap input {
  width: 100%;
  padding: 10px 14px 10px 42px;
  border: 1.5px solid rgba(14,26,15,0.12);
  border-radius: 10px;
  background: var(--paper);
  font-family: 'DM Sans', sans-serif;
  font-size: 0.92rem;
  outline: none;
  transition: var(--transition);
}
.search-wrap input:focus {
  border-color: var(--moss);
  background: white;
  box-shadow: 0 0 0 3px rgba(45, 106, 63, 0.15);
}
.search-icon {
  position: absolute;
  left: 14px; top: 50%;
  transform: translateY(-50%);
  color: rgba(14,26,15,0.35);
  display: flex;
  align-items: center;
  pointer-events: none;
}
select.filter-select {
  padding: 10px 36px 10px 14px;
  border: 1.5px solid rgba(14,26,15,0.12);
  border-radius: 10px;
  background: var(--paper);
  font-family: 'DM Sans', sans-serif;
  font-size: 0.88rem;
  outline: none;
  cursor: pointer;
  appearance: none;
  background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L6 6L11 1' stroke='%230e1a0f' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  background-repeat: no-repeat;
  background-position: right 14px center;
  min-width: 160px;
  transition: var(--transition);
}
select.filter-select:focus {
  border-color: var(--moss);
  background-color: white;
  box-shadow: 0 0 0 3px rgba(45, 106, 63, 0.15);
}
.results-count {
  font-family: 'DM Mono', monospace;
  font-size: 0.82rem;
  color: rgba(14,26,15,0.5);
  margin-left: auto;
  white-space: nowrap;
}
.view-toggle { display: flex; gap: 6px; }
.vbtn {
  padding: 8px 14px;
  border: 1.5px solid rgba(14,26,15,0.12);
  border-radius: 8px;
  background: var(--paper);
  cursor: pointer;
  font-size: 0.88rem;
  font-family: 'DM Sans', sans-serif;
  transition: var(--transition);
  display: flex;
  align-items: center;
  gap: 6px;
}
.vbtn.active { background: var(--moss); color: white; border-color: var(--moss); }
.vbtn:hover:not(.active) { border-color: var(--moss); background: white; }

/* ─── MAIN LAYOUT ─── */
.main {
  max-width: 1600px;
  margin: 0 auto;
  padding: 32px;
  display: grid;
  grid-template-columns: 260px 1fr;
  gap: 32px;
  align-items: start;
}
@media (max-width: 1024px) {
  .main { grid-template-columns: 1fr; }
  .sidebar { display: none; }
}

/* ─── SIDEBAR ─── */
.sidebar {
  position: sticky;
  top: 130px;
}
.sidebar-section { margin-bottom: 28px; }
.sidebar-title {
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(14,26,15,0.45);
  margin-bottom: 12px;
  padding-left: 4px;
  font-weight: 600;
}
.cat-chip {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 12px;
  border-radius: 10px;
  cursor: pointer;
  transition: var(--transition);
  font-size: 0.86rem;
  margin-bottom: 4px;
  border: 1px solid transparent;
  background: transparent;
  width: 100%;
  text-align: left;
  color: var(--ink);
}
.cat-chip:hover {
  background: var(--paper2);
}
.cat-chip.active {
  background: var(--ink);
  color: var(--paper);
  box-shadow: var(--shadow-sm);
}
.cat-chip .cat-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}
.cat-chip .cat-icon-emoji {
  font-size: 1.1rem;
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 18px;
}
.cat-chip .cat-count {
  margin-left: auto;
  font-family: 'DM Mono', monospace;
  font-size: 0.75rem;
  opacity: 0.6;
  background: rgba(14,26,15,0.06);
  padding: 1px 6px;
  border-radius: 4px;
}
.cat-chip.active .cat-count {
  background: rgba(255,255,255,0.15);
  opacity: 0.9;
}

/* ─── CARDS GRID ─── */
.cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 20px;
}
.cards-grid.list-view {
  grid-template-columns: 1fr;
}

/* ─── INDICATOR CARD ─── */
.card {
  background: white;
  border-radius: var(--radius);
  border: 1px solid rgba(14,26,15,0.06);
  overflow: hidden;
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease, border-color 0.3s ease;
  cursor: pointer;
  display: flex;
  flex-direction: column;
  position: relative;
  box-shadow: var(--shadow-sm);
}
.card:hover {
  transform: translateY(-4px) scale(1.005);
  box-shadow: var(--shadow-lg);
  border-color: rgba(45, 106, 63, 0.25);
}
.card-accent {
  height: 4px;
}
.card-body {
  padding: 22px 24px 20px;
  flex: 1;
  display: flex;
  flex-direction: column;
}
.card-top {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 12px;
  padding-right: 24px; /* Space for star button */
}
.card-icon {
  font-size: 1.45rem;
  flex-shrink: 0;
  margin-top: 1px;
}
.card-name {
  font-family: 'DM Serif Display', serif;
  font-size: 1.12rem;
  line-height: 1.25;
  color: var(--ink);
  font-weight: normal;
}
.card-sub {
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  color: rgba(14,26,15,0.45);
  margin-bottom: 10px;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}
.card-desc {
  font-size: 0.88rem;
  color: rgba(14,26,15,0.68);
  margin-bottom: 18px;
  line-height: 1.6;
  flex: 1;
}
.card-footer {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
  margin-top: auto;
}
.pill {
  font-size: 0.72rem;
  font-family: 'DM Mono', monospace;
  padding: 3px 10px;
  border-radius: 20px;
  font-weight: 500;
  letter-spacing: 0.02em;
}
.pill.status-available { background: var(--moss-pale); color: var(--moss); }
.pill.status-prototype { background: var(--gold-pale); color: #9c6615; }
.pill.status-planned { background: var(--water-pale); color: var(--water); }
.pill.status-not_core { background: #f0f0f0; color: #666; }
.pill.rel-high { background: var(--moss-pale); color: var(--moss); }
.pill.rel-medium { background: var(--gold-pale); color: #9c6615; }
.pill.rel-low { background: var(--fire-pale); color: var(--fire); }
.pill.cx-low { background: #f0f0f0; color: #555; }
.pill.cx-medium { background: var(--gold-pale); color: #9c6615; }
.pill.cx-high { background: var(--fire-pale); color: var(--fire); }
.pill.access-open { background: var(--moss-pale); color: var(--moss); }
.pill.access-mixed { background: var(--composite-pale); color: var(--composite); }
.pill.access-proprietary_client { background: var(--fire-pale); color: var(--fire); }

/* list view card */
.cards-grid.list-view .card {
  flex-direction: row;
}
.cards-grid.list-view .card-accent {
  width: 4px;
  height: auto;
}
.cards-grid.list-view .card-body {
  flex-direction: row;
  align-items: center;
  gap: 20px;
  flex-wrap: wrap;
  padding: 16px 24px;
}
.cards-grid.list-view .card-top { margin-bottom: 0; flex: 1.5; min-width: 240px; }
.cards-grid.list-view .card-desc { display: none; }
.cards-grid.list-view .card-sub { margin-bottom: 0; flex: 0.8; min-width: 140px; }
.cards-grid.list-view .card-footer { margin-top: 0; flex: 1.2; justify-content: flex-end; }

/* ─── Star Bookmark Button on Cards ─── */
.card-star {
  position: absolute;
  top: 14px; right: 14px;
  background: rgba(255, 255, 255, 0.9);
  border: 1px solid rgba(14,26,15,0.08);
  border-radius: 50%;
  width: 32px; height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  z-index: 5;
  color: rgba(14,26,15,0.3);
  transition: var(--transition);
  box-shadow: var(--shadow-sm);
}
.card-star:hover {
  transform: scale(1.1) rotate(15deg);
  color: #d4a373;
  border-color: #d4a373;
  background: white;
}
.card-star.active {
  color: #d4a373;
  background: #fefae0;
  border-color: #d4a373;
  animation: popStar 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
@keyframes popStar {
  0% { transform: scale(0.6); }
  70% { transform: scale(1.2); }
  100% { transform: scale(1); }
}

/* ─── MODAL ─── */
.modal-overlay {
  position: fixed; inset: 0;
  background: rgba(14,26,15,0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
  backdrop-filter: blur(8px);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}
.modal-overlay.open {
  opacity: 1;
  pointer-events: all;
}
.modal {
  background: var(--paper);
  border-radius: 18px;
  max-width: 860px;
  width: 100%;
  max-height: 90vh;
  overflow-y: auto;
  box-shadow: var(--shadow-lg);
  transform: scale(0.95) translateY(15px);
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  border: 1px solid rgba(14,26,15,0.06);
}
.modal-overlay.open .modal {
  transform: scale(1) translateY(0);
}
.modal-header {
  padding: 32px 40px 24px;
  border-bottom: 1px solid rgba(14,26,15,0.08);
  position: sticky;
  top: 0;
  background: var(--paper);
  z-index: 2;
  display: flex;
  align-items: flex-start;
  gap: 20px;
}
.modal-title-block { flex: 1; }
.modal-cat-badge {
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  padding: 4px 12px;
  border-radius: 20px;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 10px;
  font-weight: 600;
}
.modal-title {
  font-family: 'DM Serif Display', serif;
  font-size: 1.8rem;
  line-height: 1.2;
  margin-bottom: 8px;
  color: var(--ink);
  font-weight: normal;
}
.modal-sub {
  font-family: 'DM Mono', monospace;
  font-size: 0.8rem;
  color: rgba(14,26,15,0.45);
  letter-spacing: 0.05em;
  text-transform: uppercase;
}
.modal-close {
  background: white;
  border: 1.5px solid rgba(14,26,15,0.12);
  border-radius: 50%;
  width: 40px; height: 40px;
  cursor: pointer;
  font-size: 1.2rem;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: var(--transition);
  box-shadow: var(--shadow-sm);
}
.modal-close:hover {
  background: var(--paper2);
  transform: rotate(90deg);
}
.modal-body {
  padding: 32px 40px 40px;
}
.modal-desc {
  font-size: 0.98rem;
  color: rgba(14,26,15,0.72);
  margin-bottom: 28px;
  line-height: 1.7;
  padding: 20px 24px;
  background: white;
  border-radius: 10px;
  border-left: 4px solid var(--moss);
  box-shadow: var(--shadow-sm);
}

/* framework tabs */
.fw-tabs {
  display: flex;
  gap: 8px;
  margin-bottom: 24px;
  border-bottom: 1.5px solid rgba(14,26,15,0.06);
  padding-bottom: 0;
  overflow-x: auto;
}
.fw-tab {
  padding: 10px 18px;
  border: none;
  background: none;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.92rem;
  font-weight: 550;
  cursor: pointer;
  color: rgba(14,26,15,0.45);
  border-bottom: 3px solid transparent;
  margin-bottom: -1.5px;
  transition: var(--transition);
  white-space: nowrap;
}
.fw-tab:hover { color: var(--ink); }
.fw-tab.active { color: var(--moss); border-bottom-color: var(--moss); }

.tab-panel { display: none; }
.tab-panel.active { display: block; animation: tabFade 0.25s ease both; }
@keyframes tabFade {
  from { opacity: 0; transform: translateY(6px); }
  to { opacity: 1; transform: translateY(0); }
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-bottom: 16px;
}
@media (max-width: 600px) { .info-grid { grid-template-columns: 1fr; } }

.info-block {
  background: white;
  border-radius: 12px;
  padding: 18px 20px;
  border: 1px solid rgba(14,26,15,0.05);
  box-shadow: var(--shadow-sm);
}
.info-block.full { grid-column: 1 / -1; }
.info-label {
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: rgba(14,26,15,0.42);
  margin-bottom: 6px;
  font-weight: 600;
}
.info-value {
  font-size: 0.9rem;
  color: var(--ink);
  line-height: 1.6;
}
.info-value code {
  font-family: 'DM Mono', monospace;
  font-size: 0.84rem;
  background: var(--paper2);
  padding: 2px 6px;
  border-radius: 4px;
}
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 6px;
}
.tag {
  font-family: 'DM Mono', monospace;
  font-size: 0.75rem;
  padding: 4px 10px;
  border-radius: 6px;
  background: var(--paper2);
  color: rgba(14,26,15,0.72);
}

.india-banner {
  background: linear-gradient(135deg, #fff3e6 0%, #ffffff 50%, #effaee 100%);
  border-radius: 12px;
  padding: 18px 20px;
  margin-bottom: 16px;
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(14,26,15,0.06);
  box-shadow: var(--shadow-sm);
}
.india-banner::before {
  content: '🇮🇳';
  position: absolute;
  right: 20px; top: 14px;
  font-size: 1.8rem;
  opacity: 0.25;
}
.india-banner .info-label { color: rgba(14,26,15,0.5); }
.india-banner .info-value {
  color: var(--ink);
  font-size: 0.92rem;
  line-height: 1.65;
}
.use-case-block {
  background: linear-gradient(135deg, var(--moss-pale), #f2faf5);
  border-radius: 12px;
  padding: 18px 20px;
  border-left: 4px solid var(--moss);
  margin-bottom: 16px;
  box-shadow: var(--shadow-sm);
}
.use-case-block .info-value { font-style: italic; }

.reference-block {
  background: var(--paper2);
  border-radius: 12px;
  padding: 18px 20px;
  border-left: 4px solid var(--earth);
  margin-bottom: 16px;
  box-shadow: var(--shadow-sm);
}
.reference-block .info-value { font-size: 0.88rem; color: rgba(14,26,15,0.8); }

.badge-row { display: flex; gap: 8px; flex-wrap: wrap; }

/* ─── CATEGORY OVERVIEW / SVG MAP ─── */
.cat-summary-section {
  margin-bottom: 36px;
  padding-bottom: 32px;
  border-bottom: 1px solid rgba(14,26,15,0.06);
}
.cat-summary-title {
  font-family: 'DM Serif Display', serif;
  font-size: 1.25rem;
  margin-bottom: 18px;
  display: flex;
  align-items: center;
  gap: 10px;
  font-weight: normal;
}
.cat-cards-row {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 14px;
}
.cat-stat-card {
  padding: 16px 18px;
  border-radius: var(--radius);
  border: 1px solid rgba(14,26,15,0.06);
  cursor: pointer;
  transition: var(--transition);
  background: white;
  display: flex;
  flex-direction: column;
  gap: 4px;
  box-shadow: var(--shadow-sm);
}
.cat-stat-card:hover {
  transform: translateY(-3px);
  box-shadow: var(--shadow);
  border-color: rgba(45, 106, 63, 0.15);
}
.cat-stat-icon { font-size: 1.5rem; }
.cat-stat-name { font-size: 0.84rem; font-weight: 555; line-height: 1.35; color: var(--ink); }
.cat-stat-count {
  font-family: 'DM Mono', monospace;
  font-size: 1.35rem;
  font-weight: 600;
  margin-top: 4px;
}
.cat-stat-bar { height: 4px; border-radius: 2px; margin-top: 6px; opacity: 0.7; }

/* ─── INTERACTIVE SVG REALM MAP ─── */
.realm-map-wrapper {
  background: white;
  border-radius: var(--radius);
  border: 1px solid rgba(14,26,15,0.06);
  padding: 24px;
  margin-bottom: 28px;
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}
#realmMap {
  display: block;
  max-width: 100%;
  height: auto;
  margin: 0 auto;
}
.map-hub {
  fill: var(--ink);
  cursor: pointer;
  transition: var(--transition);
}
.map-hub-ring {
  fill: none;
  stroke: var(--moss-light);
  stroke-width: 1.5;
  stroke-dasharray: 6,4;
  animation: spin 60s linear infinite;
  transform-origin: 400px 160px;
}
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
.map-node {
  cursor: pointer;
}
.map-node-circle {
  transition: r 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), fill-opacity 0.3s, stroke-width 0.3s;
}
.map-node:hover .map-node-circle {
  stroke-width: 2.5;
}
.map-edge {
  stroke: rgba(14,26,15,0.07);
  stroke-width: 1.5;
  transition: stroke 0.3s, stroke-width 0.3s;
}
.map-node:hover + .map-edge,
.map-edge.highlighted {
  stroke: var(--moss-light);
  stroke-width: 2.5;
}
.map-label {
  font-size: 10px;
  font-family: 'DM Mono', monospace;
  fill: var(--ink);
  pointer-events: none;
  font-weight: 500;
  text-transform: uppercase;
}
.map-node:hover .map-label {
  font-weight: 600;
}
.map-tooltip {
  position: absolute;
  background: var(--ink);
  color: var(--paper);
  padding: 8px 12px;
  border-radius: 6px;
  font-size: 0.78rem;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.2s;
  z-index: 10;
  font-family: 'DM Mono', monospace;
  box-shadow: var(--shadow-lg);
}

/* ─── DASHBOARD / SVG CHARTS ─── */
.dashboard-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 20px;
  margin-bottom: 28px;
}
.dashboard-card {
  background: white;
  border-radius: var(--radius);
  border: 1px solid rgba(14,26,15,0.06);
  padding: 20px 24px;
  display: flex;
  flex-direction: column;
  box-shadow: var(--shadow-sm);
}
.dashboard-card-title {
  font-family: 'DM Serif Display', serif;
  font-size: 1.15rem;
  margin-bottom: 16px;
  color: var(--ink);
  display: flex;
  align-items: center;
  gap: 8px;
  font-weight: normal;
}
.chart-container {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 180px;
  flex: 1;
}
/* Donut Chart */
.donut-svg {
  transform: rotate(-90deg);
}
.donut-hole {
  fill: white;
}
.donut-ring {
  fill: none;
  stroke: var(--paper);
  stroke-width: 14;
}
.donut-segment {
  fill: none;
  stroke-width: 14;
  transition: stroke-dashoffset 0.6s cubic-bezier(0.16, 1, 0.3, 1), stroke 0.3s;
  stroke-linecap: round;
}
.donut-center-text {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}
.donut-text-count {
  font-family: 'DM Serif Display', serif;
  font-size: 1.8rem;
  color: var(--ink);
  line-height: 1;
}
.donut-text-label {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.72rem;
  color: rgba(14,26,15,0.45);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-top: 2px;
}
.donut-legend {
  display: flex;
  flex-direction: column;
  gap: 8px;
  justify-content: center;
  margin-left: 12px;
}
.legend-item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.8rem;
  font-family: 'DM Mono', monospace;
  cursor: pointer;
  padding: 4px 8px;
  border-radius: 6px;
  transition: var(--transition);
}
.legend-item:hover {
  background: var(--paper2);
}
.legend-color {
  width: 10px;
  height: 10px;
  border-radius: 50%;
}
/* Bar Chart */
.bar-chart-container {
  display: flex;
  flex-direction: column;
  gap: 12px;
  width: 100%;
}
.bar-row {
  display: flex;
  align-items: center;
  gap: 12px;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.84rem;
  cursor: pointer;
  padding: 4px;
  border-radius: 6px;
  transition: var(--transition);
}
.bar-row:hover {
  background: var(--paper);
}
.bar-label {
  width: 90px;
  text-align: right;
  font-weight: 550;
  white-space: nowrap;
}
.bar-track {
  flex: 1;
  background: var(--paper2);
  height: 18px;
  border-radius: 6px;
  overflow: hidden;
  position: relative;
}
.bar-fill {
  height: 100%;
  transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1), background 0.3s;
  border-radius: 6px;
}
.bar-value {
  width: 32px;
  font-family: 'DM Mono', monospace;
  font-size: 0.8rem;
  color: rgba(14,26,15,0.5);
  text-align: left;
}

/* ─── REPORT BUILDER DRAWER ─── */
.drawer-backdrop {
  position: fixed; inset: 0;
  background: rgba(14,26,15,0.4);
  backdrop-filter: blur(2px);
  -webkit-backdrop-filter: blur(2px);
  z-index: 998;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}
.drawer-backdrop.open {
  opacity: 1;
  pointer-events: all;
}
.drawer {
  position: fixed;
  top: 0; right: 0; bottom: 0;
  width: 440px;
  max-width: 100%;
  background: var(--paper);
  z-index: 999;
  box-shadow: -4px 0 32px rgba(14,26,15,0.12);
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform 0.32s cubic-bezier(0.16, 1, 0.3, 1);
  border-left: 1px solid rgba(14,26,15,0.06);
}
.drawer.open {
  transform: translateX(0);
}
.drawer-header {
  padding: 20px 24px;
  border-bottom: 1px solid rgba(14,26,15,0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--ink);
  color: var(--paper);
}
.drawer-title {
  font-family: 'DM Serif Display', serif;
  font-size: 1.25rem;
  display: flex;
  align-items: center;
  gap: 10px;
  font-weight: normal;
}
.drawer-close {
  background: none;
  border: 1px solid rgba(245,242,235,0.2);
  color: var(--paper);
  border-radius: 50%;
  width: 32px; height: 32px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: var(--transition);
}
.drawer-close:hover {
  background: rgba(245,242,235,0.15);
  transform: rotate(90deg);
}
.drawer-body {
  flex: 1;
  overflow-y: auto;
  padding: 24px;
}
.drawer-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60%;
  text-align: center;
  color: rgba(14,26,15,0.35);
}
.drawer-empty-icon {
  font-size: 2.5rem;
  margin-bottom: 12px;
  opacity: 0.7;
}
.drawer-item {
  background: white;
  border-radius: 10px;
  border: 1px solid rgba(14,26,15,0.05);
  padding: 14px;
  margin-bottom: 10px;
  position: relative;
  display: flex;
  align-items: center;
  gap: 12px;
  box-shadow: var(--shadow-sm);
  transition: var(--transition);
}
.drawer-item:hover {
  box-shadow: var(--shadow);
  border-color: rgba(45, 106, 63, 0.12);
}
.drawer-item-cat-icon {
  font-size: 1.3rem;
  flex-shrink: 0;
}
.drawer-item-content {
  flex: 1;
  min-width: 0;
}
.drawer-item-name {
  font-family: 'DM Serif Display', serif;
  font-size: 0.94rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: var(--ink);
  font-weight: normal;
}
.drawer-item-sub {
  font-family: 'DM Mono', monospace;
  font-size: 0.7rem;
  color: rgba(14,26,15,0.42);
  text-transform: uppercase;
}
.drawer-item-remove {
  background: none;
  border: none;
  color: rgba(14,26,15,0.35);
  cursor: pointer;
  padding: 6px;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: var(--transition);
}
.drawer-item-remove:hover {
  color: var(--fire);
  background: var(--fire-pale);
}
.drawer-footer {
  padding: 24px;
  border-top: 1px solid rgba(14,26,15,0.08);
  background: rgba(235, 230, 218, 0.6);
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.drawer-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
  margin-bottom: 10px;
}
.drawer-stat-box {
  background: white;
  padding: 8px;
  border-radius: 8px;
  text-align: center;
  border: 1px solid rgba(14,26,15,0.05);
  box-shadow: var(--shadow-sm);
}
.drawer-stat-num {
  font-family: 'DM Mono', monospace;
  font-weight: 600;
  font-size: 1.15rem;
  color: var(--moss);
}
.drawer-stat-lbl {
  font-size: 0.62rem;
  color: rgba(14,26,15,0.45);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-top: 2px;
}
.btn-primary {
  background: var(--moss);
  color: white;
  border: none;
  border-radius: 10px;
  padding: 12px 18px;
  font-family: 'DM Sans', sans-serif;
  font-weight: 550;
  font-size: 0.92rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  transition: var(--transition);
  box-shadow: 0 4px 12px rgba(45, 106, 63, 0.2);
}
.btn-primary:hover {
  background: #235331;
  box-shadow: 0 6px 16px rgba(45, 106, 63, 0.3);
  transform: translateY(-1px);
}
.btn-primary:active {
  transform: translateY(0) scale(0.98);
}
.btn-secondary {
  background: white;
  color: var(--ink);
  border: 1.5px solid rgba(14,26,15,0.15);
  border-radius: 10px;
  padding: 11px 18px;
  font-family: 'DM Sans', sans-serif;
  font-weight: 550;
  font-size: 0.92rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  transition: var(--transition);
  box-shadow: var(--shadow-sm);
}
.btn-secondary:hover {
  border-color: var(--ink);
  background: var(--paper);
}
.btn-secondary:active {
  transform: scale(0.98);
}

/* Starred indicator count badge in header */
.star-counter-badge {
  background: #d4a373;
  color: #0e1a0f;
  font-family: 'DM Mono', monospace;
  font-size: 0.7rem;
  font-weight: 600;
  border-radius: 10px;
  padding: 1px 6px;
  margin-left: 2px;
}

/* ─── COMPARE MODAL TABLE ─── */
.compare-modal-inner {
  padding: 8px 0;
}
.compare-table-wrapper {
  overflow-x: auto;
  border: 1px solid rgba(14,26,15,0.08);
  border-radius: 10px;
  background: white;
  box-shadow: var(--shadow-sm);
}
.compare-table {
  width: 100%;
  border-collapse: collapse;
  text-align: left;
  font-size: 0.86rem;
}
.compare-table th, .compare-table td {
  padding: 14px 18px;
  border-bottom: 1px solid rgba(14,26,15,0.06);
  vertical-align: top;
}
.compare-table th {
  background: var(--paper2);
  font-family: 'DM Serif Display', serif;
  font-size: 1.05rem;
  color: var(--ink);
  font-weight: normal;
}
.compare-table td:first-child, .compare-table th:first-child {
  font-family: 'DM Mono', monospace;
  font-size: 0.74rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: rgba(14,26,15,0.48);
  width: 180px;
  background: var(--paper);
  border-right: 1px solid rgba(14,26,15,0.06);
  font-weight: 600;
}
.compare-col-header {
  font-family: 'DM Serif Display', serif;
  font-size: 1.15rem !important;
  color: var(--moss) !important;
}
.compare-remove-col {
  font-size: 0.74rem;
  color: var(--fire);
  cursor: pointer;
  margin-top: 6px;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-family: 'DM Sans', sans-serif;
  transition: var(--transition);
}
.compare-remove-col:hover {
  text-decoration: underline;
}

/* ─── NO RESULTS ─── */
.no-results {
  grid-column: 1 / -1;
  text-align: center;
  padding: 80px 32px;
  color: rgba(14,26,15,0.35);
  font-size: 1.05rem;
}
.no-results .emoji { font-size: 3.5rem; display: block; margin-bottom: 16px; opacity: 0.6; }

/* ─── FOOTER ─── */
footer {
  background: var(--ink);
  color: rgba(245,242,235,0.45);
  padding: 32px;
  text-align: center;
  font-family: 'DM Mono', monospace;
  font-size: 0.78rem;
  margin-top: 64px;
  border-top: 1px solid rgba(255,255,255,0.05);
}
footer strong { color: var(--moss-light); }

/* scrollbar */
::-webkit-scrollbar { width: 8px; height: 8px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(14,26,15,0.18); border-radius: 4px; }
::-webkit-scrollbar-thumb:hover { background: rgba(14,26,15,0.3); }

/* animations */
.card { animation: fadeUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) both; }
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Floating Home Button */
.floating-home-btn {
  position: fixed;
  bottom: 24px;
  right: 24px;
  width: 48px;
  height: 48px;
  background: var(--moss);
  color: white;
  border: none;
  border-radius: 50%;
  box-shadow: 0 4px 16px rgba(45, 106, 63, 0.3);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s, transform 0.3s, background-color 0.3s;
  transform: translateY(10px);
}
.floating-home-btn.visible {
  opacity: 1;
  pointer-events: all;
  transform: translateY(0);
}
.floating-home-btn:hover {
  background: #235331;
  transform: scale(1.05);
}
.floating-home-btn:active {
  transform: scale(0.95);
}
</style>
</head>
<body>

<header class="site-header">
  <div class="header-inner">
    <a href="javascript:void(0)" onclick="goHome()" class="logo" title="Go to Home Screen">
      <img src="darukaa_logo.png" alt="Darukaa.Earth" style="height: 32px; width: auto;">
      <span class="logo-sub">Nature Indicator Atlas</span>
    </a>
    <div class="header-stats">
      <div class="hstat"><strong id="total-count">200+</strong> indicators</div>
      <div class="hstat"><strong>10</strong> categories</div>
      <div class="hstat"><strong>60</strong> sub-categories</div>
      <div class="hstat"><strong>TNFD · SBTN · CSRD · BRSR</strong></div>
    </div>
    <div class="header-actions">
      <button class="btn-primary" onclick="toggleDrawer()" style="padding: 7px 14px; font-size: 0.82rem; background: var(--gold); color: var(--ink); border-radius: 8px; box-shadow: none; display: flex; align-items: center; gap: 6px;">
        <i data-lucide="star" style="width: 14px; height: 14px; fill: var(--ink); color: var(--ink);"></i> Custom Report
        <span class="star-counter-badge" id="headerStarCount">0</span>
      </button>
    </div>
  </div>
</header>

<button class="floating-home-btn" id="floatingHomeBtn" onclick="goHome()" title="Go to Home Screen">
  <i data-lucide="home" style="width: 20px; height: 20px;"></i>
</button>

<section class="hero">
  <div class="floating-leaves" id="floatingLeaves"></div>
  <div class="hero-inner">
    <h1>India's <em>Nature Intelligence</em><br>Indicator Library</h1>
    <p>A comprehensive, framework-aligned atlas of 200+ environmental indicators—mapped to TNFD LEAP, SBTN targets, CSRD/ESRS datapoints, and India-specific data sources—to power nature disclosure for Indian corporates, financial institutions, and project developers.</p>
    <div class="framework-badges" id="frameworkBadges">
      <span class="fbadge tnfd" onclick="toggleFrameworkFilter('TNFD', this)">TNFD LEAP</span>
      <span class="fbadge sbtn" onclick="toggleFrameworkFilter('SBTN', this)">SBTN Targets</span>
      <span class="fbadge csrd" onclick="toggleFrameworkFilter('CSRD', this)">CSRD / ESRS</span>
      <span class="fbadge brsr" onclick="toggleFrameworkFilter('BRSR', this)">BRSR Core</span>
    </div>
  </div>
</section>

<div class="controls-bar">
  <div class="controls-inner">
    <div class="search-wrap">
      <span class="search-icon"><i data-lucide="search" style="width: 16px; height: 16px;"></i></span>
      <input type="text" id="searchInput" placeholder="Search indicators…" oninput="filterCards()">
    </div>
    <select class="filter-select" id="catFilter" onchange="filterCards()">
      <option value="">All Categories</option>
    </select>
    <select class="filter-select" id="statusFilter" onchange="filterCards()">
      <option value="">All Statuses</option>
      <option value="available">Available</option>
      <option value="prototype">Prototype</option>
      <option value="planned">Planned</option>
      <option value="not_core">Not Core</option>
    </select>
    <select class="filter-select" id="relFilter" onchange="filterCards()">
      <option value="">All India Relevance</option>
      <option value="high">High relevance</option>
      <option value="medium">Medium relevance</option>
      <option value="low">Low relevance</option>
    </select>
    <select class="filter-select" id="cxFilter" onchange="filterCards()">
      <option value="">All Complexity</option>
      <option value="low">Low complexity</option>
      <option value="medium">Medium complexity</option>
      <option value="high">High complexity</option>
    </select>
    <div class="results-count" id="resultsCount">200+ indicators</div>
    <div class="view-toggle">
      <button class="vbtn active" id="gridBtn" onclick="setView('grid')"><i data-lucide="layout-grid" style="width: 14px; height: 14px;"></i> Grid</button>
      <button class="vbtn" id="listBtn" onclick="setView('list')"><i data-lucide="list" style="width: 14px; height: 14px;"></i> List</button>
    </div>
  </div>
</div>

<div class="main">
  <aside class="sidebar">
    <div class="sidebar-section">
      <div class="sidebar-title">Categories</div>
      <div id="catSidebar"></div>
    </div>
    <div class="sidebar-section">
      <div class="sidebar-title">Framework Legend</div>
      <div style="font-size:0.78rem; color:rgba(14,26,15,0.55); line-height:1.9;">
        <div style="display:flex; align-items:center; gap:6px; margin-bottom:4px;"><i data-lucide="leaf" style="width: 12px; height: 12px; color: var(--moss);"></i> <strong>TNFD</strong> — LEAP stages</div>
        <div style="display:flex; align-items:center; gap:6px; margin-bottom:4px;"><i data-lucide="target" style="width: 12px; height: 12px; color: var(--water);"></i> <strong>SBTN</strong> — Realm + Steps</div>
        <div style="display:flex; align-items:center; gap:6px; margin-bottom:4px;"><i data-lucide="file-text" style="width: 12px; height: 12px; color: var(--gold);"></i> <strong>ESRS</strong> — E1/E3/E4</div>
        <div style="display:flex; align-items:center; gap:6px; margin-bottom:4px;"><i data-lucide="flag" style="width: 12px; height: 12px; color: var(--fire);"></i> <strong>BRSR</strong> — India ESG</div>
      </div>
    </div>
  </aside>

  <div id="mainContent">
    <!-- Interactive SVG Realm Map -->
    <div class="realm-map-wrapper" id="realmMapWrapper">
      <div class="realm-map-title">
        <i data-lucide="compass" style="width: 18px; height: 18px; color: var(--moss);"></i> Nature Wheel Realm Selector
      </div>
      <div class="map-tooltip" id="mapTooltip"></div>
      <svg id="realmMap" viewBox="0 0 800 320" width="800" height="320"></svg>
    </div>

    <!-- Category Dashboard Panel (SVG charts) -->
    <div class="dashboard-grid" id="dashboardSection">
      <div class="dashboard-card">
        <div class="dashboard-card-title">
          <i data-lucide="pie-chart" style="width: 16px; height: 16px; color: var(--moss);"></i> Indicator Status Distribution
        </div>
        <div class="chart-container">
          <div id="statusDonutContainer" style="display:flex; align-items:center; justify-content:center; width:100%;"></div>
        </div>
      </div>
      <div class="dashboard-card">
        <div class="dashboard-card-title">
          <i data-lucide="bar-chart-3" style="width: 16px; height: 16px; color: var(--moss);"></i> Computational Complexity
        </div>
        <div class="chart-container">
          <div id="complexityBarContainer" style="width: 100%;"></div>
        </div>
      </div>
    </div>

    <div class="cat-summary-section" id="overviewSection">
      <div class="cat-summary-title"><i data-lucide="layout-dashboard" style="width: 18px; height: 18px; color: var(--moss);"></i> Overview by Category</div>
      <div class="cat-cards-row" id="catOverview"></div>
    </div>
    <div class="cards-grid" id="cardsGrid"></div>
  </div>
</div>

<div class="modal-overlay" id="modalOverlay" onclick="closeModal(event)">
  <div class="modal" id="modal">
    <div class="modal-header">
      <div class="modal-title-block">
        <span class="modal-cat-badge" id="mCatBadge"></span>
        <div class="modal-title" id="mTitle"></div>
        <div class="modal-sub" id="mSub"></div>
      </div>
      <button class="modal-close" onclick="closeModalDirect()">✕</button>
    </div>
    <div class="modal-body">
      <div class="modal-desc" id="mDesc"></div>
      <div class="fw-tabs">
        <button class="fw-tab active" onclick="switchTab('tnfd',this)">🌿 TNFD</button>
        <button class="fw-tab" onclick="switchTab('sbtn',this)">🎯 SBTN</button>
        <button class="fw-tab" onclick="switchTab('csrd',this)">📋 CSRD/ESRS</button>
        <button class="fw-tab" onclick="switchTab('india',this)">🇮🇳 India</button>
        <button class="fw-tab" onclick="switchTab('data',this)">🗄️ Data</button>
        <button class="fw-tab" onclick="switchTab('usecase',this)">💼 Use Case</button>
        <button class="fw-tab" onclick="switchTab('references',this)">📚 References</button>
        <button class="fw-tab" id="tabBtnOtherMetrics" onclick="switchTab('othermetrics',this)" style="display:none;">🌡️ Other Metrics</button>
      </div>
      <div class="tab-panel active" id="tab-tnfd">
        <div class="info-grid">
          <div class="info-block">
            <div class="info-label">TNFD Link</div>
            <div class="info-value" id="m-tnfd-link"></div>
          </div>
          <div class="info-block">
            <div class="info-label">TNFD Metric Type</div>
            <div class="info-value" id="m-tnfd-type"></div>
          </div>
          <div class="info-block">
            <div class="info-label">TNFD Code</div>
            <div class="info-value" id="m-tnfd-code"></div>
          </div>
          <div class="info-block">
            <div class="info-label">Data Type</div>
            <div class="info-value" id="m-data-type"></div>
          </div>
        </div>
      </div>
      <div class="tab-panel" id="tab-sbtn">
        <div class="info-grid">
          <div class="info-block full">
            <div class="info-label">SBTN Link</div>
            <div class="info-value" id="m-sbtn"></div>
          </div>
        </div>
      </div>
      <div class="tab-panel" id="tab-csrd">
        <div class="info-grid">
          <div class="info-block full">
            <div class="info-label">CSRD / ESRS Datapoints</div>
            <div class="info-value" id="m-csrd"></div>
          </div>
        </div>
      </div>
      <div class="tab-panel" id="tab-india">
        <div class="india-banner">
          <div class="info-label">India Relevance & Operationalisation</div>
          <div class="info-value" id="m-india-notes"></div>
        </div>
        <div class="info-grid">
          <div class="info-block">
            <div class="info-label">India Relevance</div>
            <div class="info-value" id="m-india-rel"></div>
          </div>
          <div class="info-block">
            <div class="info-label">Darukaa Status</div>
            <div class="info-value" id="m-darukaa"></div>
          </div>
        </div>
      </div>
      <div class="tab-panel" id="tab-data">
        <div class="info-grid">
          <div class="info-block full">
            <div class="info-label">Input Data Required</div>
            <div class="info-value" id="m-input-data"></div>
          </div>
          <div class="info-block full">
            <div class="info-label">Open Data Sources</div>
            <div class="tag-list" id="m-open-src"></div>
          </div>
          <div class="info-block">
            <div class="info-label">Access Type</div>
            <div class="info-value" id="m-access"></div>
          </div>
          <div class="info-block">
            <div class="info-label">Computation Complexity</div>
            <div class="info-value" id="m-cx"></div>
          </div>
        </div>
      </div>
      <div class="tab-panel" id="tab-usecase">
        <div class="use-case-block">
          <div class="info-label">Example Use Case (India)</div>
          <div class="info-value" id="m-use-case"></div>
        </div>
        <div class="info-block" id="m-comments-block" style="display:none">
          <div class="info-label">Additional Notes</div>
          <div class="info-value" id="m-comments"></div>
        </div>
      </div>
      <div class="tab-panel" id="tab-references">
        <div class="reference-block" id="m-ref-block">
          <div class="info-label">Scientific Reference</div>
          <div class="info-value" id="m-reference"></div>
        </div>
      </div>
      <div class="tab-panel" id="tab-othermetrics">
        <div class="other-metrics-container" id="m-other-metrics-list" style="max-height: 450px; overflow-y: auto; padding-right: 5px;"></div>
      </div>
    </div>
  </div>
</div>

<!-- Bookmark Drawer (Custom Report Builder) -->
<div class="drawer-backdrop" id="drawerBackdrop" onclick="toggleDrawer()"></div>
<div class="drawer" id="bookmarkDrawer">
  <div class="drawer-header">
    <div class="drawer-title" style="display:flex; align-items:center; gap:8px;">
      <i data-lucide="star" style="width: 20px; height: 20px; fill: var(--gold); color: var(--gold);"></i> <span>Custom Report Builder</span>
    </div>
    <button class="drawer-close" onclick="toggleDrawer()">✕</button>
  </div>
  <div class="drawer-body" id="drawerBody">
    <!-- Starred indicators will render here -->
  </div>
  <div class="drawer-footer">
    <div class="drawer-stats">
      <div class="drawer-stat-box">
        <div class="drawer-stat-num" id="statTnfd">0</div>
        <div class="drawer-stat-lbl">TNFD</div>
      </div>
      <div class="drawer-stat-box">
        <div class="drawer-stat-num" id="statSbtn">0</div>
        <div class="drawer-stat-lbl">SBTN</div>
      </div>
      <div class="drawer-stat-box">
        <div class="drawer-stat-num" id="statCsrd">0</div>
        <div class="drawer-stat-lbl">CSRD</div>
      </div>
      <div class="drawer-stat-box">
        <div class="drawer-stat-num" id="statBrsr">0</div>
        <div class="drawer-stat-lbl">BRSR</div>
      </div>
    </div>
    <button class="btn-primary" onclick="exportReportTemplate()" style="width:100%; margin-top:8px; display:flex; align-items:center; justify-content:center; gap:6px;">
      <i data-lucide="download" style="width:16px; height:16px;"></i> Export Custom Report (.doc)
    </button>
    <button class="btn-secondary" onclick="openCompareMode()" style="width:100%; margin-top:8px; display:flex; align-items:center; justify-content:center; gap:6px;">
      <i data-lucide="sliders" style="width:16px; height:16px;"></i> Compare Selected
    </button>
  </div>
</div>

<!-- Compare Mode Modal Overlay -->
<div class="modal-overlay" id="compareOverlay" onclick="closeCompareModal(event)">
  <div class="modal compare-modal" id="compareModal" onclick="event.stopPropagation()">
    <div class="modal-header">
      <div class="modal-title-block">
        <span class="modal-cat-badge" style="background: var(--gold-pale); color: var(--gold);"><i data-lucide="sliders" style="width:12px; height:12px; display:inline-block; vertical-align:middle; margin-right:4px;"></i>Compare</span>
        <div class="modal-title">Side-by-Side Indicator Comparison</div>
        <div class="modal-sub">Compare core framework mapping, India-relevance and parameters</div>
      </div>
      <button class="modal-close" onclick="closeCompareModalDirect()">✕</button>
    </div>
    <div class="modal-body" style="padding:0;">
      <div class="compare-modal-inner" id="compareModalBody">
        <!-- Comparison Table will render here -->
      </div>
    </div>
  </div>
</div>

