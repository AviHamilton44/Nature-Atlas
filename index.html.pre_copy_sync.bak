    "Zhao, Y. et al. (2022). Analyzing the Spatial Distribution of LST and Its Relationship With Land Use in Different Months. Frontiers in Environmental Science, 10:872282. | NASA LP DAAC MODIS MOD11/MYD11 User Guide.",
  "Ground Surface Temperature (LST Day)":
    "Zhao, Y. et al. (2022). Analyzing the Spatial Distribution of LST and Its Relationship With Land Use in Different Months. Frontiers in Environmental Science, 10:872282. | NASA LP DAAC MODIS MOD11 User Guide.",
  "Nighttime Surface Temperature (LST Night)":
    "Zhao, Y. et al. (2022). Analyzing the Spatial Distribution of LST and Its Relationship With Land Use in Different Months. Frontiers in Environmental Science, 10:872282. | NASA LP DAAC MODIS MYD11 User Guide.",
  "Urban Heat Island Index":
    "Zhao, Y. et al. (2022). Analyzing the Spatial Distribution of LST and Its Relationship With Land Use in Different Months. Frontiers in Environmental Science, 10:872282. | NASA LP DAAC MODIS MOD11/MYD11 User Guide.",
  "Functional Guild Diversity":
    "Petchey, O. L., & Gaston, K. J. (2002). Functional diversity (FD), species richness and community composition. Ecology Letters, 5(3), 402\u2013411. DOI: 10.1046/j.1461-0248.2002.00339.x"
};

INDICATORS.forEach(ind => {
  for (let key in referenceMapping) {
    if (ind.original_name && ind.original_name.includes(key)) {
      ind.reference = referenceMapping[key];
    }
  }
});

const CAT_META = {
  "Biodiversity & ecosystems": { color: "#2d6a3f", bg: "#d4edda", icon: "🌿" },
  "Land use, land cover & fragmentation": { color: "#7a5c2d", bg: "#f0e6da", icon: "🗺️" },
  "Climate & physical risk": { color: "#b94a2c", bg: "#fbe8e3", icon: "🌡️" },
  "Carbon & GHG": { color: "#1a6b5a", bg: "#d0ede8", icon: "💨" },
  "Water quantity & quality": { color: "#1a4f7a", bg: "#d1e8f5", icon: "💧" },
  "Air quality & pollution": { color: "#6c3483", bg: "#ead6f5", icon: "🌫️" },
  "Nature-based solutions & green infrastructure": { color: "#27ae60", bg: "#c8f0d8", icon: "🌳" },
  "Socio-environmental & exposure": { color: "#d68910", bg: "#fdf3d0", icon: "👥" },
  "Compliance & proximity to protected/sensitive areas": { color: "#2e4057", bg: "#d5dce6", icon: "🛡️" },
  "Composite / platform scores": { color: "#6b2d82", bg: "#ead6f5", icon: "📊" }
};

let currentView = 'grid';
let activeCategory = '';
let currentIndicator = null;

let starredNames = JSON.parse(localStorage.getItem('starredIndicators') || '[]');
let activeRealm = '';
let activeFramework = '';

// Realms definition mapping to categories
const REALMS = {
  "Biodiversity": {
    categories: ["Biodiversity & ecosystems"],
    color: "#2d6a3f",
    bg: "#eaf5ec",
    label: "Biodiversity"
  },
  "Land": {
    categories: [
      "Land use, land cover & fragmentation",
      "Carbon & GHG",
      "Nature-based solutions & green infrastructure"
    ],
    color: "#7a5c2d",
    bg: "#f6efe6",
    label: "Land & Soil"
  },
  "Water": {
    categories: ["Water quantity & quality"],
    color: "#1a4f7a",
    bg: "#e6f2fa",
    label: "Freshwater"
  },
  "Atmosphere": {
    categories: ["Climate & physical risk", "Air quality & pollution"],
    color: "#b94a2c",
    bg: "#fdf0ec",
    label: "Atmosphere"
  },
  "Compliance": {
    categories: [
      "Compliance & proximity to protected/sensitive areas",
      "Composite / platform scores",
      "Socio-environmental & exposure"
    ],
    color: "#2e4057",
    bg: "#d5dce6",
    label: "Compliance & Social"
  }
};

document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('total-count').textContent = INDICATORS.length;
  populateCatFilter();
  buildCatSidebar();
  buildCatOverview();
  
  // Upgraded dynamic initializers
  initFloatingLeaves();
  drawRealmMap();
  updateDrawer();
  filterCards();
});

function populateCatFilter() {
  const sel = document.getElementById('catFilter');
  Object.keys(CAT_META).forEach(cat => {
    const opt = document.createElement('option');
    opt.value = cat; opt.textContent = cat;
    sel.appendChild(opt);
  });
}

function buildCatSidebar() {
  const counts = {};
  INDICATORS.forEach(d => { counts[d.category] = (counts[d.category]||0)+1; });
  const el = document.getElementById('catSidebar');
  const all = document.createElement('button');
  all.className = 'cat-chip active';
  all.innerHTML = `<span class="cat-icon-emoji">🌍</span><span>All</span><span class="cat-count">${INDICATORS.length}</span>`;
  all.onclick = () => { activeCategory=''; document.querySelectorAll('.cat-chip').forEach(c=>c.classList.remove('active')); all.classList.add('active'); document.getElementById('catFilter').value=''; filterCards(); };
  el.appendChild(all);
  Object.keys(CAT_META).forEach(cat => {
    const m = CAT_META[cat];
    const btn = document.createElement('button');
    btn.className = 'cat-chip';
    btn.innerHTML = `<span class="cat-icon-emoji">${m.icon}</span><span style="flex:1">${cat.length>28?cat.substr(0,28)+'…':cat}</span><span class="cat-count">${counts[cat]||0}</span>`;
    btn.title = cat;
    btn.onclick = () => {
      document.querySelectorAll('.cat-chip').forEach(c=>c.classList.remove('active')); btn.classList.add('active');
      document.getElementById('catFilter').value = cat;
      filterCards();
    };
    el.appendChild(btn);
  });
}

function buildCatOverview() {
  const counts = {};
  INDICATORS.forEach(d => { counts[d.category] = (counts[d.category]||0)+1; });
  const el = document.getElementById('catOverview');
  Object.entries(CAT_META).forEach(([cat, m]) => {
    const card = document.createElement('div');
    card.className = 'cat-stat-card';
    const pct = ((counts[cat]||0)/INDICATORS.length*100).toFixed(0);
    card.innerHTML = `<span class="cat-stat-icon">${m.icon}</span><span class="cat-stat-name">${cat}</span><span class="cat-stat-count" style="color:${m.color}">${counts[cat]||0}</span><div class="cat-stat-bar" style="background:${m.color};width:${pct}%"></div>`;
    card.onclick = () => { document.getElementById('catFilter').value=cat; filterCards(); card.closest('.cat-summary-section').style.display='none'; };
    el.appendChild(card);
  });
}

function filterCards() {
  const q = document.getElementById('searchInput').value.toLowerCase();
  const cat = document.getElementById('catFilter').value;
  const stat = document.getElementById('statusFilter').value;
  const rel = document.getElementById('relFilter').value;
  const cx = document.getElementById('cxFilter').value;
  
  const filtered = INDICATORS.filter(d => {
    if (activeRealm && !REALMS[activeRealm].categories.includes(d.category)) return false;
    if (cat && d.category !== cat) return false;
    if (stat && d.Darukaa_status !== stat) return false;
    if (rel && d.India_relevance !== rel) return false;
    if (cx && d.computation_complexity !== cx) return false;
    
    // Framework alignment filters
    if (activeFramework === 'TNFD' && (!d.TNFD_code && !d.TNFD_link)) return false;
    if (activeFramework === 'SBTN' && !d.SBTN_link) return false;
    if (activeFramework === 'CSRD' && !d.CSRD_ESRS_link) return false;
    if (activeFramework === 'BRSR' && !(d.India_notes && d.India_notes.toLowerCase().includes('brsr'))) return false;

    if (q) {
      const hay = ((d.original_name||"")+(d.short_description||"")+(d.sub_category||"")+(d.TNFD_metric_type||"")+(d.India_notes||"")).toLowerCase();
      if (!hay.includes(q)) return false;
    }
    return true;
  });
  
  document.getElementById('resultsCount').textContent = `${filtered.length} indicator${filtered.length!==1?'s':''}`;
  
  // Dynamic layout display transitions
  const hasFilter = q || cat || stat || rel || cx || activeRealm || activeFramework;
  document.getElementById('overviewSection').style.display = hasFilter ? 'none' : '';
  document.getElementById('realmMapWrapper').style.display = (q || cat || stat || rel || cx || activeFramework) ? 'none' : '';
  document.getElementById('dashboardSection').style.display = (q || cat || stat || rel || cx || activeFramework) ? 'none' : '';

  renderCards(filtered);
  
  // Re-draw analytical charts
  drawStatusDonut(filtered);
  drawComplexityBars(filtered);
}

const LST_SIMILAR_NAMES = [
  "LST annual range",
  "LST range delta between years",
  "Night Land Surface Temperature",
  "Urban Thermal Field Variance Index",
  "Ground Surface Temperature (LST Day)",
  "Nighttime Surface Temperature (LST Night)"
];

function renderCards(list) {
  const grid = document.getElementById('cardsGrid');
  grid.innerHTML = '';
  
  // Filter out similar LST metrics from the main grid view
  let cardsList = list.filter(d => !LST_SIMILAR_NAMES.includes(d.original_name));
  
  // Force include the main Land Surface Temperature card if any sub-metric matched the active search/filters
  const hasMatchedSimilarLST = list.some(d => LST_SIMILAR_NAMES.includes(d.original_name));
  const hasMainLST = cardsList.some(d => d.original_name === "Land Surface Temperature");
  if (hasMatchedSimilarLST && !hasMainLST) {
    const mainLST = INDICATORS.find(d => d.original_name === "Land Surface Temperature");
    if (mainLST) {
      cardsList.push(mainLST);
    }
  }
  
  if (!cardsList.length) {
    grid.innerHTML = '<div class="no-results"><span class="emoji">🔍</span>No indicators match your filters.</div>';
    return;
  }
  
  cardsList.forEach((d, i) => {
    const m = CAT_META[d.category] || { color:'#555', bg:'#eee', icon:'📊' };
    const card = document.createElement('div');
    card.className = 'card';
    card.style.animationDelay = `${Math.min(i,20)*0.03}s`;
    
    const isStarred = starredNames.includes(d.original_name);
    
    card.innerHTML = `
      <div class="card-accent" style="background:${m.color}"></div>
      <button class="card-star ${isStarred ? 'active' : ''}" onclick="toggleStar('${esc(d.original_name)}', event)" title="Star Indicator">
        <i data-lucide="star" style="width:14px; height:14px; ${isStarred ? 'fill:currentColor;' : ''}"></i>
      </button>
      <div class="card-body">
        <div class="card-top"><span class="card-icon">${m.icon}</span><div><div class="card-name">${esc(d.original_name)}</div></div></div>
        <div class="card-sub">${esc(d.sub_category)}</div>
        <div class="card-desc">${esc(d.short_description)}</div>
        <div class="card-footer">
          <span class="pill status-${d.Darukaa_status}">${statusLabel(d.Darukaa_status)}</span>
          <span class="pill rel-${d.India_relevance}">India: ${d.India_relevance}</span>
          <span class="pill cx-${d.computation_complexity}">${d.computation_complexity} cx</span>
          <span class="pill access-${d.access_type}">${accessLabel(d.access_type)}</span>
        </div>
      </div>`;
    card.onclick = () => openModal(d);
    grid.appendChild(card);
  });
  
  lucide.createIcons();
}

function openModal(d) {
  currentIndicator = d;
  const m = CAT_META[d.category] || { color:'#555', bg:'#eee', icon:'📊' };
  document.getElementById('mCatBadge').textContent = m.icon+' '+d.category;
  document.getElementById('mCatBadge').style.background = m.bg;
  document.getElementById('mCatBadge').style.color = m.color;
  document.getElementById('mTitle').textContent = d.original_name;
  document.getElementById('mSub').textContent = d.sub_category;
  document.getElementById('mDesc').textContent = d.short_description;
  
  document.getElementById('m-tnfd-link').textContent = d.TNFD_link||'—';
  document.getElementById('m-tnfd-type').textContent = d.TNFD_metric_type||'—';
  document.getElementById('m-tnfd-code').innerHTML = d.TNFD_code ? `<code>${d.TNFD_code}</code>` : '<em style="opacity:0.5">No specific code</em>';
  document.getElementById('m-data-type').textContent = d.data_type||d.TNFD_metric_type||'—';
  document.getElementById('m-sbtn').textContent = d.SBTN_link||'—';
  document.getElementById('m-csrd').textContent = d.CSRD_ESRS_link||'—';
  document.getElementById('m-india-notes').textContent = d.India_notes||'—';
  document.getElementById('m-india-rel').innerHTML = `<span class="pill rel-${d.India_relevance}">${d.India_relevance}</span>`;
  document.getElementById('m-darukaa').innerHTML = `<span class="pill status-${d.Darukaa_status}">${statusLabel(d.Darukaa_status)}</span>`;
  
  document.getElementById('m-input-data').textContent = d.input_data_required||'—';
  const srcEl = document.getElementById('m-open-src');
  srcEl.innerHTML = '';
  (d.open_data_sources||[]).forEach(s => {
    const t = document.createElement('span'); t.className='tag'; t.textContent=s; srcEl.appendChild(t);
  });
  document.getElementById('m-access').innerHTML = `<span class="pill access-${d.access_type}">${accessLabel(d.access_type)}</span>`;
  document.getElementById('m-cx').innerHTML = `<span class="pill cx-${d.computation_complexity}">${d.computation_complexity} complexity</span>`;
  
  document.getElementById('m-use-case').textContent = d.example_use_case||'—';
  
  if (d.additional_comments) {
    document.getElementById('m-comments-block').style.display='';
    document.getElementById('m-comments').textContent = d.additional_comments;
  } else {
    document.getElementById('m-comments-block').style.display='none';
  }

  if (d.reference) {
    document.getElementById('m-ref-block').style.display='';
    document.getElementById('m-reference').textContent = d.reference;
  } else {
    document.getElementById('m-ref-block').style.display='none';
  }
  
  if (d.original_name === "Land Surface Temperature") {
    document.getElementById('tabBtnOtherMetrics').style.display = 'block';
    renderOtherMetricsTab();
  } else {
    document.getElementById('tabBtnOtherMetrics').style.display = 'none';
  }
  
  switchTab('tnfd', document.querySelector('.fw-tab'));
  document.getElementById('modalOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal(e) { if (e.target === document.getElementById('modalOverlay')) closeModalDirect(); }
function closeModalDirect() { document.getElementById('modalOverlay').classList.remove('open'); document.body.style.overflow = ''; }
document.addEventListener('keydown', e => { if(e.key==='Escape') closeModalDirect(); });

function switchTab(tabId, btn) {
  document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.fw-tab').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+tabId).classList.add('active');
  btn.classList.add('active');
}

function renderOtherMetricsTab() {
  const container = document.getElementById('m-other-metrics-list');
  container.innerHTML = '';
  
  const similar = INDICATORS.filter(ind => LST_SIMILAR_NAMES.includes(ind.original_name));
  
  similar.forEach((ind, index) => {
    const isStarred = starredNames.includes(ind.original_name);
    const item = document.createElement('div');
    item.className = 'other-metric-item';
    item.style.marginBottom = '16px';
    item.style.border = '1px solid rgba(14,26,15,0.08)';
    item.style.borderRadius = '10px';
    item.style.overflow = 'hidden';
    item.style.background = '#fcfbfa';
    item.style.transition = 'box-shadow 0.2s';
    
    item.innerHTML = `
      <div class="other-metric-header" style="padding:12px 16px; display:flex; align-items:center; justify-content:space-between; background:#f4f1eb; border-bottom:1px solid rgba(14,26,15,0.05); cursor:pointer;" onclick="toggleOtherMetricContent(${index})">
        <div style="display:flex; align-items:center; gap:8px;">
          <span style="font-size:1.1rem; color:var(--fire);">🌡️</span>
          <span style="font-family:'DM Sans', sans-serif; font-size:0.95rem; font-weight:600; color:var(--ink);">${esc(ind.original_name)}</span>
        </div>
        <div style="display:flex; align-items:center; gap:10px;" onclick="event.stopPropagation();">
          <button class="card-star ${isStarred ? 'active' : ''}" style="position:static; width:26px; height:26px; background:white; border:1px solid rgba(14,26,15,0.1); border-radius:50%; display:flex; align-items:center; justify-content:center; cursor:pointer;" onclick="toggleStar('${esc(ind.original_name)}', event)" title="Star Indicator">
            <i data-lucide="star" style="width:12px; height:12px; ${isStarred ? 'fill:var(--gold); color:var(--gold);' : 'color:rgba(14,26,15,0.4);'}"></i>
          </button>
          <span class="pill status-${ind.Darukaa_status}" style="font-size:0.68rem; padding:2px 8px; font-weight:500;">${statusLabel(ind.Darukaa_status)}</span>
          <div style="cursor:pointer; display:flex; align-items:center;" onclick="toggleOtherMetricContent(${index})">
            <i data-lucide="chevron-down" class="other-metric-chevron-${index}" style="width:16px; height:16px; transition: transform 0.25s; color:rgba(14,26,15,0.4);"></i>
          </div>
        </div>
      </div>
      <div class="other-metric-content other-metric-content-${index}" style="display:none; padding:16px; background: white;">
        <div style="margin-bottom:14px; font-size:0.88rem; color:rgba(14,26,15,0.7); line-height:1.5;">${esc(ind.short_description)}</div>
        
        <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap:12px;">
          <div style="background:#faf9f6; padding:10px 12px; border-radius:8px; border:1px solid rgba(14,26,15,0.04);">
            <div style="font-size:0.7rem; font-family:'DM Sans', sans-serif; font-weight:700; color:rgba(14,26,15,0.45); text-transform:uppercase; margin-bottom:4px; letter-spacing:0.03em;">🌿 TNFD LEAP</div>
            <div style="font-size:0.82rem; line-height:1.4; color:var(--ink);">${esc(ind.TNFD_link || '—')}</div>
            <div style="margin-top:6px; font-size:0.78rem; color:rgba(14,26,15,0.6);">
              <strong>Code:</strong> <code>${esc(ind.TNFD_code || 'N/A')}</code> &nbsp;·&nbsp; <strong>Type:</strong> ${esc(ind.TNFD_metric_type || '—')}
            </div>
          </div>
          
          <div style="background:#faf9f6; padding:10px 12px; border-radius:8px; border:1px solid rgba(14,26,15,0.04);">
            <div style="font-size:0.7rem; font-family:'DM Sans', sans-serif; font-weight:700; color:rgba(14,26,15,0.45); text-transform:uppercase; margin-bottom:4px; letter-spacing:0.03em;">🎯 SBTN Targets</div>
            <div style="font-size:0.82rem; line-height:1.4; color:var(--ink);">${esc(ind.SBTN_link || '—')}</div>
          </div>
          
          <div style="background:#faf9f6; padding:10px 12px; border-radius:8px; border:1px solid rgba(14,26,15,0.04);">
            <div style="font-size:0.7rem; font-family:'DM Sans', sans-serif; font-weight:700; color:rgba(14,26,15,0.45); text-transform:uppercase; margin-bottom:4px; letter-spacing:0.03em;">📋 CSRD / ESRS</div>
            <div style="font-size:0.82rem; line-height:1.4; color:var(--ink);">${esc(ind.CSRD_ESRS_link || '—')}</div>
          </div>
          
          <div style="background:#faf9f6; padding:10px 12px; border-radius:8px; border:1px solid rgba(14,26,15,0.04);">
            <div style="font-size:0.7rem; font-family:'DM Sans', sans-serif; font-weight:700; color:rgba(14,26,15,0.45); text-transform:uppercase; margin-bottom:4px; letter-spacing:0.03em;">🇮🇳 India & BRSR Notes</div>
