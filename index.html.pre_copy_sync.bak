, {"original_name": "Fertilizer pollution overview", "category": "Water quantity & quality", "sub_category": "nutrient & agricultural pollution", "short_description": "Overview of fertilizer pollution (N, P, K) from agricultural activity", "TNFD_link": "LEAP-E (Evaluate): nutrient pollution as ecosystem condition stressor; Impact", "TNFD_metric_type": "impacts \u2013 water quality / nutrient pollution", "TNFD_code": "C5.0", "SBTN_link": "Realm: Freshwater; Steps: Assess, Track; Pressure: pollution \u2013 nutrients; metric: N/P load (kg/ha/year)", "CSRD_ESRS_link": "ESRS E2-4 (water quality \u2013 nutrients); ESRS E3-4 (water body ecological status); ESRS E4-5 (freshwater ecosystem condition)", "India_relevance": "high", "India_notes": "India uses >17M tonnes fertiliser/year; excess N/P major driver of river and groundwater pollution. CPCB water quality monitoring network; NRSC agricultural land maps. High relevance for Ganga and Krishna river basins.", "Darukaa_status": "planned", "input_data_required": "fertiliser application data, satellite NDVI, CPCB water quality, LULC", "open_data_sources": ["CPCB water quality data India", "ISRO LULC agri layers", "FAO fertiliser statistics", "Global NEWS nutrient model", "NRSC agricultural mapping"], "access_type": "mixed", "computation_complexity": "medium", "example_use_case": "A food company assesses nitrogen fertiliser pollution risk in its wheat sourcing watershed in Punjab using FAO and CPCB data to disclose water-quality impacts under ESRS E2-4 and TNFD Evaluate.", "additional_comments": null}, {"original_name": "Nitrogen fertilizer pollution", "category": "Water quantity & quality", "sub_category": "nutrient & agricultural pollution", "short_description": "Nitrogen (N) fertilizer application and pollution risk", "TNFD_link": "LEAP-E (Evaluate): nutrient pollution as ecosystem condition stressor; Impact", "TNFD_metric_type": "impacts \u2013 water quality / nutrient pollution", "TNFD_code": "C2.1", "SBTN_link": "Realm: 