            <div style="font-size:0.82rem; line-height:1.4; color:var(--ink); margin-bottom:6px;">
              <strong>Open Sources:</strong> ${(ind.open_data_sources || []).map(s => `<span class="tag" style="display:inline-block; font-size:0.7rem; padding:1px 6px; background:rgba(14,26,15,0.04); margin-right:4px; border-radius:4px;">${s}</span>`).join('')}
            </div>
            <div style="font-size:0.78rem; margin-top:8px;">
              <strong>Access:</strong> <span class="pill access-${ind.access_type}" style="padding:1px 6px; font-size:0.65rem;">${accessLabel(ind.access_type)}</span> &nbsp;·&nbsp; 
              <strong>Complexity:</strong> <span class="pill cx-${ind.computation_complexity}" style="padding:1px 6px; font-size:0.65rem;">${ind.computation_complexity} complexity</span>
            </div>
          </div>
          
          <div style="background:#faf9f6; padding:10px 12px; border-radius:8px; border:1px solid rgba(14,26,15,0.04); grid-column: 1 / -1;">
            <div style="font-size:0.7rem; font-family:'DM Sans', sans-serif; font-weight:700; color:rgba(14,26,15,0.45); text-transform:uppercase; margin-bottom:4px; letter-spacing:0.03em;">💼 Corporate Use Case</div>
            <div style="font-size:0.82rem; line-height:1.4; color:var(--ink); font-style:italic;">"${esc(ind.example_use_case || '—')}"</div>
          </div>
          
          ${ind.reference ? `
          <div style="background:#faf9f6; padding:10px 12px; border-radius:8px; border:1px solid rgba(14,26,15,0.04); grid-column: 1 / -1;">
            <div style="font-size:0.7rem; font-family:'DM Sans', sans-serif; font-weight:700; color:rgba(14,26,15,0.45); text-transform:uppercase; margin-bottom:4px; letter-spacing:0.03em;">📚 Scientific Reference</div>
            <div style="font-size:0.82rem; line-height:1.4; color:rgba(14,26,15,0.6);">${esc(ind.reference)}</div>
          </div>` : ''}
        </div>
      </div>
    `;
    container.appendChild(item);
  });
  
  lucide.createIcons();
}

function toggleOtherMetricContent(idx) {
  const content = document.querySelector(`.other-metric-content-${idx}`);
  const chevron = document.querySelector(`.other-metric-chevron-${idx}`);
  if (content) {
    const isHidden = content.style.display === 'none';
    content.style.display = isHidden ? 'block' : 'none';
    if (chevron) {
      chevron.style.transform = isHidden ? 'rotate(180deg)' : 'rotate(0deg)';
    }
  }
}

function setView(v) {
  currentView = v;
  const grid = document.getElementById('cardsGrid');
  grid.classList.toggle('list-view', v==='list');
  document.getElementById('gridBtn').classList.toggle('active', v==='grid');
  document.getElementById('listBtn').classList.toggle('active', v==='list');
}

function esc(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function statusLabel(s) { return { available:'✓ Available', prototype:'⚗ Prototype', planned:'⏳ Planned', not_core:'— Not Core' }[s]||s; }
function accessLabel(s) { return { open:'Open', mixed:'Mixed', proprietary_client:'Proprietary' }[s]||s; }

// --- Hero Framework Filter Toggles ---
function toggleFrameworkFilter(framework, el) {
  const badges = document.querySelectorAll('#frameworkBadges .fbadge');
  if (activeFramework === framework) {
    activeFramework = '';
    el.classList.remove('active');
  } else {
    activeFramework = framework;
    badges.forEach(b => b.classList.remove('active'));
    el.classList.add('active');
  }
  filterCards();
}

// --- Floating Leaves ---
function initFloatingLeaves() {
  const container = document.getElementById('floatingLeaves');
  if (!container) return;
  container.innerHTML = '';
  const leafCount = 12;
  for (let i = 0; i < leafCount; i++) {
    const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    svg.setAttribute('class', 'leaf-svg');
    svg.setAttribute('viewBox', '0 0 24 24');
    svg.style.left = `${Math.random() * 90 + 5}%`;
    svg.style.width = `${Math.random() * 20 + 16}px`;
    svg.style.height = svg.style.width;
    svg.style.opacity = `${Math.random() * 0.12 + 0.05}`;
    svg.style.animationDuration = `${Math.random() * 15 + 15}s`;
    svg.style.animationDelay = `${Math.random() * -20}s`;
    svg.innerHTML = `<path d="M2,21 C8,21 12,18 17,12 C22,6 22,2 22,2 C22,2 18,2 12,7 C6,12 3,16 3,22 M12,7 L3,22" stroke="currentColor" stroke-width="1" fill="none"/>`;
    container.appendChild(svg);
  }
}

// --- Interactive SVG Realm Map (Nature Wheel) ---
function drawRealmMap() {
  const svg = document.getElementById('realmMap');
  if (!svg) return;
  svg.innerHTML = '';
  
  // Calculate counts for each realm
  Object.keys(REALMS).forEach(realmKey => {
    const r = REALMS[realmKey];
    r.count = INDICATORS.filter(d => r.categories.includes(d.category)).length;
  });
  
  // 1. Draw dashed orbit ring
  const orbit = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
  orbit.setAttribute('class', 'map-hub-ring');
  orbit.setAttribute('cx', '400');
  orbit.setAttribute('cy', '160');
  orbit.setAttribute('r', '110');
  svg.appendChild(orbit);
  
  // 2. Draw central reset hub
  const hubGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');
  hubGroup.setAttribute('class', 'map-hub');
  hubGroup.onclick = () => resetRealmFilter();
  
  const hubCircle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
  hubCircle.setAttribute('cx', '400');
  hubCircle.setAttribute('cy', '160');
  hubCircle.setAttribute('r', '32');
  hubCircle.setAttribute('fill', 'var(--ink)');
  hubGroup.appendChild(hubCircle);
  
  const hubText = document.createElementNS('http://www.w3.org/2000/svg', 'text');
  hubText.setAttribute('x', '400');
  hubText.setAttribute('y', '163');
  hubText.setAttribute('text-anchor', 'middle');
  hubText.setAttribute('fill', 'white');
  hubText.setAttribute('font-family', '\'DM Mono\', monospace');
  hubText.setAttribute('font-size', '9');
  hubText.setAttribute('font-weight', '600');
  hubText.setAttribute('letter-spacing', '0.05em');
  hubText.textContent = 'RESET';
  hubGroup.appendChild(hubText);
  
  // 3. Draw nodes and edges
  const keys = Object.keys(REALMS);
  keys.forEach((key, i) => {
    const r = REALMS[key];
    const angle = i * 2 * Math.PI / 5 - Math.PI / 2;
    const nx = 400 + 110 * Math.cos(angle);
    const ny = 160 + 110 * Math.sin(angle);
    
    // Draw edge line
    const edge = document.createElementNS('http://www.w3.org/2000/svg', 'line');
    edge.setAttribute('class', 'map-edge');
    edge.setAttribute('id', `edge-${key}`);
    edge.setAttribute('x1', '400');
    edge.setAttribute('y1', '160');
    edge.setAttribute('x2', nx.toString());
    edge.setAttribute('y2', ny.toString());
    svg.appendChild(edge);
    
    // Draw node group
    const nodeGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');
    nodeGroup.setAttribute('class', 'map-node');
    nodeGroup.setAttribute('id', `node-${key}`);
    nodeGroup.onclick = () => selectRealm(key);
    nodeGroup.onmouseenter = () => showRealmTooltip(key, nx, ny);
    nodeGroup.onmouseleave = () => hideRealmTooltip();
    
    const nodeCircle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    nodeCircle.setAttribute('class', 'map-node-circle');
    nodeCircle.setAttribute('cx', nx.toString());
    nodeCircle.setAttribute('cy', ny.toString());
    nodeCircle.setAttribute('r', '28');
    nodeCircle.setAttribute('fill', r.bg);
    nodeCircle.setAttribute('stroke', r.color);
    nodeCircle.setAttribute('stroke-width', '1.5');
    nodeGroup.appendChild(nodeCircle);
    
    const nodeLabel = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    nodeLabel.setAttribute('x', nx.toString());
    nodeLabel.setAttribute('y', (ny - 3).toString());
    nodeLabel.setAttribute('text-anchor', 'middle');
    nodeLabel.setAttribute('font-family', '\'DM Sans\', sans-serif');
    nodeLabel.setAttribute('font-size', '9');
    nodeLabel.setAttribute('font-weight', '600');
    nodeLabel.setAttribute('fill', 'var(--ink)');
    
    const shortLabels = { Biodiversity: "Bio", Land: "Land", Water: "Water", Atmosphere: "Climate", Compliance: "Comply" };
    nodeLabel.textContent = shortLabels[key] || key;
    nodeGroup.appendChild(nodeLabel);
    
    const nodeCount = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    nodeCount.setAttribute('x', nx.toString());
    nodeCount.setAttribute('y', (ny + 10).toString());
    nodeCount.setAttribute('text-anchor', 'middle');
    nodeCount.setAttribute('font-family', '\'DM Mono\', monospace');
    nodeCount.setAttribute('font-size', '8');
    nodeCount.setAttribute('font-weight', '500');
    nodeCount.setAttribute('fill', r.color);
    nodeCount.textContent = `${r.count} IND`;
    nodeGroup.appendChild(nodeCount);
    
    svg.appendChild(nodeGroup);
  });
  
  svg.appendChild(hubGroup);
}

function selectRealm(key) {
  if (activeRealm === key) {
    activeRealm = '';
  } else {
    activeRealm = key;
  }
  
  document.querySelectorAll('.map-node-circle').forEach(c => {
    c.setAttribute('stroke-width', '1.5');
  });
  document.querySelectorAll('.map-edge').forEach(e => {
    e.classList.remove('highlighted');
  });
  
  if (activeRealm) {
    const activeCircle = document.querySelector(`#node-${activeRealm} .map-node-circle`);
    if (activeCircle) activeCircle.setAttribute('stroke-width', '3');
    const activeEdge = document.getElementById(`edge-${activeRealm}`);
    if (activeEdge) activeEdge.classList.add('highlighted');
  }
  
  filterCards();
}

function resetRealmFilter() {
  activeRealm = '';
  document.querySelectorAll('.map-node-circle').forEach(c => {
    c.setAttribute('stroke-width', '1.5');
  });
  document.querySelectorAll('.map-edge').forEach(e => {
    e.classList.remove('highlighted');
  });
  filterCards();
}

function showRealmTooltip(key, x, y) {
  const tooltip = document.getElementById('mapTooltip');
  const r = REALMS[key];
  tooltip.innerHTML = `
    <div style="font-weight:600; color:var(--paper); margin-bottom:4px;">${r.label} Realm</div>
    <div style="font-size:0.7rem; color:rgba(245,242,235,0.7); max-width:200px;">
      Categories: ${r.categories.map(c => c.substr(0,18) + '...').join(', ')}<br>
      <strong>${r.count} Indicators</strong>
    </div>
  `;
  tooltip.style.opacity = '1';
  
  const svg = document.getElementById('realmMap');
  const rect = svg.getBoundingClientRect();
  const wrapperRect = document.getElementById('realmMapWrapper').getBoundingClientRect();
  
  const scaleX = rect.width / 800;
  const scaleY = rect.height / 320;
  
  const clientX = rect.left + x * scaleX - wrapperRect.left;
  const clientY = rect.top + y * scaleY - wrapperRect.top;
  
  tooltip.style.left = `${clientX}px`;
  tooltip.style.top = `${clientY - 55}px`;
}

function hideRealmTooltip() {
  document.getElementById('mapTooltip').style.opacity = '0';
}

// --- Analytical Charts Rendering ---
function drawStatusDonut(list) {
  const container = document.getElementById('statusDonutContainer');
  if (!container) return;
  container.innerHTML = '';
  
  const counts = { available: 0, prototype: 0, planned: 0, not_core: 0 };
  list.forEach(d => { counts[d.Darukaa_status] = (counts[d.Darukaa_status]||0) + 1; });
  const total = list.length;
  
  const colors = { available: '#2d6a3f', prototype: '#d4a373', planned: '#1a4f7a', not_core: '#888888' };
  
  const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
  svg.setAttribute('class', 'donut-svg');
  svg.setAttribute('width', '140');
  svg.setAttribute('height', '140');
  svg.setAttribute('viewBox', '0 0 160 160');
  
  const track = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
  track.setAttribute('class', 'donut-ring');
  track.setAttribute('cx', '80');
  track.setAttribute('cy', '80');
  track.setAttribute('r', '60');
  svg.appendChild(track);
  
  let currentOffset = 0;
  const circumference = 2 * Math.PI * 60;
  
  const keys = ['available', 'prototype', 'planned', 'not_core'];
  keys.forEach(key => {
    const val = counts[key];
    if (val === 0) return;
    const pct = val / total;
    const strokeLength = pct * circumference;
    const strokeOffset = circumference - currentOffset;
    currentOffset += strokeLength;
    
    const segment = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    segment.setAttribute('class', 'donut-segment');
    segment.setAttribute('cx', '80');
    segment.setAttribute('cy', '80');
    segment.setAttribute('r', '60');
    segment.setAttribute('stroke', colors[key]);
    segment.setAttribute('stroke-dasharray', `${strokeLength} ${circumference - strokeLength}`);
    segment.setAttribute('stroke-dashoffset', strokeOffset.toString());
    svg.appendChild(segment);
  });
  
  const hole = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
  hole.setAttribute('class', 'donut-hole');
  hole.setAttribute('cx', '80');
  hole.setAttribute('cy', '80');
  hole.setAttribute('r', '50');
  svg.appendChild(hole);
  
  const wrapper = document.createElement('div');
  wrapper.style.position = 'relative';
  wrapper.style.display = 'flex';
  wrapper.style.alignItems = 'center';
  wrapper.style.justifyContent = 'center';
  wrapper.style.width = '140px';
  wrapper.style.height = '140px';
  wrapper.appendChild(svg);
  
  const centerText = document.createElement('div');
  centerText.className = 'donut-center-text';
  centerText.innerHTML = `<div class="donut-text-count">${total}</div><div class="donut-text-label">Active</div>`;
  wrapper.appendChild(centerText);
  
  const legend = document.createElement('div');
  legend.className = 'donut-legend';
  legend.innerHTML = `
    <div class="legend-item" onclick="filterByStatus('available')">
      <span class="legend-color" style="background:#2d6a3f;"></span>
      <span>Available: <strong>${counts.available}</strong></span>
    </div>
    <div class="legend-item" onclick="filterByStatus('prototype')">
      <span class="legend-color" style="background:#d4a373;"></span>
      <span>Prototype: <strong>${counts.prototype}</strong></span>
    </div>
    <div class="legend-item" onclick="filterByStatus('planned')">
      <span class="legend-color" style="background:#1a4f7a;"></span>
      <span>Planned: <strong>${counts.planned}</strong></span>
    </div>
    <div class="legend-item" onclick="filterByStatus('not_core')">
      <span class="legend-color" style="background:#888888;"></span>
      <span>Not Core: <strong>${counts.not_core}</strong></span>
    </div>
  `;
  
  container.appendChild(wrapper);
  container.appendChild(legend);
}

function drawComplexityBars(list) {
  const container = document.getElementById('complexityBarContainer');
  if (!container) return;
  container.innerHTML = '';
  
  const counts = { low: 0, medium: 0, high: 0 };
  list.forEach(d => { counts[d.computation_complexity] = (counts[d.computation_complexity]||0) + 1; });
  const maxVal = Math.max(counts.low, counts.medium, counts.high, 1);
  
  container.innerHTML = `
    <div class="bar-chart-container">
      <div class="bar-row" onclick="filterByComplexity('low')">
        <div class="bar-label">Low</div>
        <div class="bar-track">
          <div class="bar-fill" style="width: ${(counts.low / maxVal * 100).toFixed(0)}%; background: #4a9e63;"></div>
        </div>
        <div class="bar-value">${counts.low}</div>
      </div>
      <div class="bar-row" onclick="filterByComplexity('medium')">
        <div class="bar-label">Medium</div>
        <div class="bar-track">
          <div class="bar-fill" style="width: ${(counts.medium / maxVal * 100).toFixed(0)}%; background: #d4a373;"></div>
        </div>
        <div class="bar-value">${counts.medium}</div>
      </div>
      <div class="bar-row" onclick="filterByComplexity('high')">
        <div class="bar-label">High</div>
        <div class="bar-track">
          <div class="bar-fill" style="width: ${(counts.high / maxVal * 100).toFixed(0)}%; background: #b94a2c;"></div>
        </div>
        <div class="bar-value">${counts.high}</div>
      </div>
    </div>
  `;
}

function filterByStatus(status) {
  document.getElementById('statusFilter').value = status;
  filterCards();
}

function filterByComplexity(cx) {
  document.getElementById('cxFilter').value = cx;
  filterCards();
}

// --- Bookmark Report Builder Drawer Functions ---
function toggleDrawer() {
  const drawer = document.getElementById('bookmarkDrawer');
  const backdrop = document.getElementById('drawerBackdrop');
  drawer.classList.toggle('open');
  backdrop.classList.toggle('open');
}

function toggleStar(name, event) {
  if (event) event.stopPropagation();
  
  const idx = starredNames.indexOf(name);
  if (idx !== -1) {
    starredNames.splice(idx, 1);
  } else {
    starredNames.push(name);
  }
  
  localStorage.setItem('starredIndicators', JSON.stringify(starredNames));
  
  document.querySelectorAll('.card').forEach(card => {
    const cardNameEl = card.querySelector('.card-name');
    if (cardNameEl && cardNameEl.textContent === name) {
      const starBtn = card.querySelector('.card-star');
      if (starBtn) {
        starBtn.classList.toggle('active', starredNames.includes(name));
        const starIcon = starBtn.querySelector('i');
        if (starIcon) {
          if (starredNames.includes(name)) {
            starIcon.style.fill = 'currentColor';
          } else {
            starIcon.style.fill = '';
          }
        }
      }
    }
  });
  
  // Sync other metrics panel stars if currently open
  document.querySelectorAll('.other-metric-header').forEach(hdr => {
    const titleEl = hdr.querySelector('span[style*="font-family"]');
    if (titleEl && titleEl.textContent === name) {
      const starBtn = hdr.querySelector('.card-star');
      if (starBtn) {
        starBtn.classList.toggle('active', starredNames.includes(name));
        const starIcon = starBtn.querySelector('i');
        if (starIcon) {
          if (starredNames.includes(name)) {
            starIcon.style.fill = 'var(--gold)';
            starIcon.style.color = 'var(--gold)';
          } else {
            starIcon.style.fill = 'none';
            starIcon.style.color = 'rgba(14,26,15,0.4)';
          }
        }
      }
    }
  });
  
  updateDrawer();
}

function updateDrawer() {
  const listEl = document.getElementById('drawerBody');
  if (!listEl) return;
  listEl.innerHTML = '';
  
  const starredIndicators = INDICATORS.filter(d => starredNames.includes(d.original_name));
  document.getElementById('headerStarCount').textContent = starredIndicators.length;
  
  if (starredIndicators.length === 0) {
    listEl.innerHTML = `
      <div class="drawer-empty">
        <div class="drawer-empty-icon"><i data-lucide="star" style="width: 48px; height: 48px; opacity: 0.35;"></i></div>
        <div style="font-family:'DM Serif Display', serif; font-size:1.1rem; color:var(--ink);">No items selected</div>
        <div style="font-size:0.75rem; color:rgba(14,26,15,0.45); margin-top:4px;">Star indicators to build your custom report</div>
      </div>
    `;
    document.getElementById('statTnfd').textContent = '0';
    document.getElementById('statSbtn').textContent = '0';
    document.getElementById('statCsrd').textContent = '0';
    document.getElementById('statBrsr').textContent = '0';
    
    lucide.createIcons();
    return;
  }
  
  let tnfd = 0, sbtn = 0, csrd = 0, brsr = 0;
  starredIndicators.forEach(d => {
    const m = CAT_META[d.category] || { color:'#555', bg:'#eee', icon:'📊' };
    
    if (d.TNFD_code || d.TNFD_link) tnfd++;
    if (d.SBTN_link) sbtn++;
    if (d.CSRD_ESRS_link) csrd++;
    if (d.India_notes && d.India_notes.toLowerCase().includes('brsr')) brsr++;
    
    const div = document.createElement('div');
    div.className = 'drawer-item';
    div.innerHTML = `
      <div class="drawer-item-cat-icon">${m.icon}</div>
      <div class="drawer-item-content">
        <div class="drawer-item-name">${esc(d.original_name)}</div>
        <div class="drawer-item-sub">${esc(d.sub_category)}</div>
      </div>
      <button class="drawer-item-remove" onclick="toggleStar('${esc(d.original_name)}', event)" title="Remove">✕</button>
    `;
    listEl.appendChild(div);
  });
  
  document.getElementById('statTnfd').textContent = tnfd;
  document.getElementById('statSbtn').textContent = sbtn;
  document.getElementById('statCsrd').textContent = csrd;
  document.getElementById('statBrsr').textContent = brsr;
  
  lucide.createIcons();
}

function exportReportTemplate() {
  const starredIndicators = INDICATORS.filter(d => starredNames.includes(d.original_name));
  if (starredIndicators.length === 0) {
    alert("Please star some indicators first to generate a custom report.");
    return;
  }
  
  const tnfd = starredIndicators.filter(d => d.TNFD_code || d.TNFD_link).length;
  const sbtn = starredIndicators.filter(d => d.SBTN_link).length;
  const csrd = starredIndicators.filter(d => d.CSRD_ESRS_link).length;
  const brsr = starredIndicators.filter(d => d.India_notes && d.India_notes.toLowerCase().includes('brsr')).length;
  
  let html = `<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:w="urn:schemas-microsoft-com:office:word" xmlns="http://www.w3.org/TR/REC-html40">
<head>
  <meta charset="utf-8">
  <title>Nature Intelligence Custom Disclosure Report</title>
  <!--[if gte mso 9]>
  <xml>
    <w:WordDocument>
      <w:View>Print</w:View>
      <w:Zoom>100</w:Zoom>
      <w:DoNotOptimizeForBrowser/>
    </w:WordDocument>
  </xml>
  <![endif]-->
  <style>
    body { font-family: 'Segoe UI', Arial, sans-serif; line-height: 1.6; color: #1e2820; margin: 1in; }
    h1 { font-family: 'Georgia', serif; color: #123018; font-size: 24pt; margin-bottom: 8pt; border-bottom: 2px solid #2d6a3f; padding-bottom: 6pt; }
    h2 { font-family: 'Segoe UI', Arial, sans-serif; color: #2d6a3f; font-size: 16pt; margin-top: 20pt; margin-bottom: 8pt; border-bottom: 1px solid #e0e6e0; padding-bottom: 4pt; }
    h3 { font-family: 'Segoe UI', Arial, sans-serif; color: #2d6a3f; font-size: 13pt; margin-top: 16pt; margin-bottom: 6pt; }
    p, li { font-size: 10.5pt; color: #2e3b30; }
    ul { margin-top: 4pt; margin-bottom: 8pt; padding-left: 20px; }
    li { margin-bottom: 4pt; }
    table { width: 100%; border-collapse: collapse; margin-top: 10pt; margin-bottom: 15pt; }
    th { background-color: #2d6a3f; color: #ffffff; font-weight: bold; text-align: left; padding: 8px; border: 1px solid #2d6a3f; font-size: 10pt; }
    td { padding: 8px; border: 1px solid #dcdfdc; font-size: 10pt; vertical-align: top; }
    .meta-label { font-weight: bold; color: #2d6a3f; }
    .badge { padding: 2px 6px; border-radius: 4px; font-size: 8.5pt; font-weight: bold; }
    .badge-avail { background-color: #eaf5ec; color: #2d6a3f; }
    .badge-proto { background-color: #fcf6e8; color: #b77f32; }
    .badge-plan { background-color: #e6f0fa; color: #1a4f7a; }
    .badge-not { background-color: #f0f0f0; color: #666666; }
  </style>
</head>
<body>
  <h1>Nature Intelligence Custom Disclosure Report</h1>
  <p style="font-style: italic; color: #666666;">Generated by Darukaa.Earth Nature Indicator Atlas on ${new Date().toLocaleDateString()}</p>
  
  <p>This report outlines a customized selection of nature indicators aligned with global disclosure frameworks (TNFD, SBTN, CSRD) and India-specific datasets, customized for corporate reporting, due diligence, and risk evaluation.</p>
  
  <h2>Selection Summary</h2>
  <ul>
    <li><strong>Total Indicators Selected:</strong> ${starredIndicators.length}</li>
    <li><strong>TNFD LEAP Aligned:</strong> ${tnfd}</li>
    <li><strong>SBTN Targets Aligned:</strong> ${sbtn}</li>
    <li><strong>CSRD / ESRS Aligned:</strong> ${csrd}</li>
    <li><strong>BRSR Core Aligned (India):</strong> ${brsr}</li>
  </ul>
  
  <hr style="border: none; border-top: 1px solid #e0e0e0; margin: 20pt 0;">
`;

  starredIndicators.forEach((d, idx) => {
    let statusClass = 'badge-not';
    if (d.Darukaa_status === 'available') statusClass = 'badge-avail';
    else if (d.Darukaa_status === 'prototype') statusClass = 'badge-proto';
    else if (d.Darukaa_status === 'planned') statusClass = 'badge-plan';

    html += `
  <h3>${idx + 1}. ${esc(d.original_name)}</h3>
  <ul>
    <li><span class="meta-label">Category:</span> ${esc(d.category)}</li>
    <li><span class="meta-label">Sub-Category:</span> ${esc(d.sub_category)}</li>
    <li><span class="meta-label">Short Description:</span> ${esc(d.short_description)}</li>
    <li><span class="meta-label">Implementation Status:</span> <span class="badge ${statusClass}">${esc(statusLabel(d.Darukaa_status))}</span></li>
    <li><span class="meta-label">Computational Complexity:</span> ${esc(d.computation_complexity)} complexity</li>
    <li><span class="meta-label">India Relevance:</span> ${esc(d.India_relevance.toUpperCase())} relevance</li>
  </ul>
  
  <h4 style="margin-top: 8pt; margin-bottom: 4pt; font-size: 11pt; color: #2d6a3f;">📋 Framework Alignment Map</h4>
  <table>
    <thead>
      <tr>
        <th style="width: 25%;">Framework</th>
        <th style="width: 75%;">Alignment & Core Code</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><strong>TNFD LEAP</strong></td>
        <td>${esc(d.TNFD_link || 'Not mapped')}</td>
      </tr>
      <tr>
        <td><strong>TNFD Code</strong></td>
        <td><code>${esc(d.TNFD_code || 'N/A')}</code></td>
      </tr>
      <tr>
        <td><strong>SBTN Targets</strong></td>
        <td>${esc(d.SBTN_link || 'Not mapped')}</td>
      </tr>
      <tr>
        <td><strong>CSRD / ESRS</strong></td>
        <td>${esc(d.CSRD_ESRS_link || 'Not mapped')}</td>
      </tr>
    </tbody>
  </table>
  
  <h4 style="margin-top: 8pt; margin-bottom: 4pt; font-size: 11pt; color: #2d6a3f;">🇮🇳 Indian Data Sources & Implementation Details</h4>
  <ul>
    <li><span class="meta-label">India Specific Notes:</span> ${esc(d.India_notes || 'No specific Indian legal overlay.')}</li>
    <li><span class="meta-label">Required Input Datasets:</span> ${esc(d.input_data_required || '—')}</li>
    <li><span class="meta-label">Access Type:</span> ${esc(accessLabel(d.access_type))}</li>
    <li><span class="meta-label">Open Data Sources:</span> ${esc(d.open_data_sources ? d.open_data_sources.join(', ') : 'None')}</li>
    <li><span class="meta-label">Example Corporate Use Case:</span> <em>${esc(d.example_use_case || '—')}</em></li>
  </ul>
`;
    
    if (d.reference) {
      html += `  <p style="margin-top: 6pt; font-size: 9.5pt; color: #555555;"><span class="meta-label">Scientific Reference:</span> ${esc(d.reference)}</p>\n`;
    }
    
    html += `  <hr style="border: none; border-top: 1px solid #e0e0e0; margin: 15pt 0;">\n`;
  });

  html += `</body>\n</html>`;

  const blob = new Blob([html], { type: 'application/msword;charset=utf-8;' });
  const url = URL.createObjectURL(blob);
  const link = document.createElement('a');
  link.href = url;
  link.download = `Nature_Atlas_Custom_Report_${new Date().toISOString().slice(0,10)}.doc`;
  document.body.appendChild(link);
  link.click();
  document.body.removeChild(link);
}

// --- Compare Mode Side-by-Side functions ---
function openCompareMode() {
  const starredIndicators = INDICATORS.filter(d => starredNames.includes(d.original_name));
  if (starredIndicators.length === 0) {
    alert("Please star at least one indicator to compare.");
    return;
  }
  
  const overlay = document.getElementById('compareOverlay');
  const body = document.getElementById('compareModalBody');
  overlay.classList.add('open');
  document.body.style.overflow = 'hidden';
  
  let html = `<div class="compare-table-wrapper"><table class="compare-table"><thead><tr><th>Parameter</th>`;
  
  starredIndicators.forEach(d => {
    html += `
      <th>
        <div class="compare-col-header">${esc(d.original_name)}</div>
        <div class="compare-remove-col" onclick="toggleStar('${esc(d.original_name)}'); openCompareMode();">
          ✕ Remove
        </div>
      </th>
    `;
  });
  
  html += `</tr></thead><tbody>`;
  
  const rows = [
    { label: "Category", key: "category" },
    { label: "Sub-Category", key: "sub_category" },
    { label: "Description", key: "short_description" },
    { label: "TNFD LEAP Alignment", key: "TNFD_link" },
    { label: "TNFD Code", key: "TNFD_code" },
    { label: "SBTN Targets", key: "SBTN_link" },
    { label: "CSRD / ESRS", key: "CSRD_ESRS_link" },
    { label: "India Relevance", key: "India_relevance" },
    { label: "India Notes", key: "India_notes" },
    { label: "Open Data Sources", key: "open_data_sources" },
    { label: "Use Case", key: "example_use_case" },
    { label: "Complexity", key: "computation_complexity" }
  ];
  
  rows.forEach(row => {
    html += `<tr><td>${row.label}</td>`;
    starredIndicators.forEach(d => {
      let val = d[row.key] || '—';
      if (row.key === 'open_data_sources' && Array.isArray(d.open_data_sources)) {
        val = d.open_data_sources.join(', ');
      }
      if (row.key === 'TNFD_code' && d.TNFD_code) {
        val = `<code>${d.TNFD_code}</code>`;
      }
      if (row.key === 'India_relevance') {
        val = `<span class="pill rel-${d.India_relevance}">${d.India_relevance.toUpperCase()}</span>`;
      }
      if (row.key === 'computation_complexity') {
        val = `<span class="pill cx-${d.computation_complexity}">${d.computation_complexity.toUpperCase()}</span>`;
      }
      html += `<td>${val}</td>`;
    });
    html += `</tr>`;
  });
  
  html += `</tbody></table></div>`;
  body.innerHTML = html;
  
  lucide.createIcons();
}

function closeCompareModal(e) {
  if (e.target === document.getElementById('compareOverlay')) {
    closeCompareModalDirect();
  }
}

function closeCompareModalDirect() {
  document.getElementById('compareOverlay').classList.remove('open');
  document.body.style.overflow = '';
}

function goHome() {
  closeModalDirect();
  closeCompareModalDirect();
  
  const drawer = document.getElementById('bookmarkDrawer');
  const backdrop = document.getElementById('drawerBackdrop');
  if (drawer && drawer.classList.contains('open')) {
    drawer.classList.remove('open');
    backdrop.classList.remove('open');
  }

  const searchInput = document.getElementById('searchInput');
  if (searchInput) searchInput.value = '';

  const catFilter = document.getElementById('catFilter');
  if (catFilter) catFilter.value = '';

  const statusFilter = document.getElementById('statusFilter');
  if (statusFilter) statusFilter.value = '';

  const relFilter = document.getElementById('relFilter');
  if (relFilter) relFilter.value = '';

  const cxFilter = document.getElementById('cxFilter');
  if (cxFilter) cxFilter.value = '';

  document.querySelectorAll('.cat-chip').forEach(c => c.classList.remove('active'));

  const overviewSection = document.getElementById('overviewSection');
  if (overviewSection) overviewSection.style.display = 'block';

  activeRealm = '';
  document.querySelectorAll('.map-node-circle').forEach(c => {
    c.setAttribute('stroke-width', '1.5');
  });
  document.querySelectorAll('.map-edge').forEach(e => {
    e.classList.remove('highlighted');
  });

  activeFramework = '';
  document.querySelectorAll('.fbadge').forEach(b => {
    b.classList.remove('active');
  });

  if (typeof filterCards === 'function') {
    filterCards();
  }

  window.scrollTo({ top: 0, behavior: 'smooth' });
}

window.addEventListener('scroll', () => {
  const btn = document.getElementById('floatingHomeBtn');
  if (btn) {
    if (window.scrollY > 300) {
      btn.classList.add('visible');
    } else {
      btn.classList.remove('visible');
    }
  }
});
</script>
</body>
</html>