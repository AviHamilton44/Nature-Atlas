_required": "sea-level tide gauge records, DEM, storm surge models, coastal habitat maps", "open_data_sources": ["INCOIS India sea-level data", "NCSM coastal maps India", "NASA Coastal DEM (CoastalDEM)", "Global Mangrove Watch", "Copernicus Marine Service"], "access_type": "mixed", "computation_complexity": "medium", "example_use_case": "A port authority in Gujarat uses sea-level rise projections and coastal erosion data to disclose 2030\u20132050 coastal infrastructure risk under ESRS E1-9 scenario analysis.", "additional_comments": null}, {"original_name": "Coastal Erosion", "category": "Climate & physical risk", "sub_category": "ocean & coastal risk", "short_description": "Shoreline retreat impacting foundations, infrastructure, and access routes", "TNFD_link": "LEAP-L (Locate): identify coastal exposure; LEAP-A (Assess): sea-level rise and storm surge risk; Risk disclosure", "TNFD_metric_type": "physical risk \u2013 coastal / ocean", "TNFD_code": "C5.0", "SBTN_link": "Realm: Ocean; Steps: Assess, Prioritise; Pressure: sea-level rise, ocean warming; metric: inundation area, erosion rate", "CSRD_ESRS_link": "ESRS E1-9 (physical risks \u2013 sea-level rise, coastal flooding); ESRS E4-5 (coastal ecosystem condition)", "India_relevance": "medium", "India_notes": "India has 7,500 km coastline. INCOIS Sea Level Rise projections, ICZM (Integrated Coastal Zone Management) maps, NCSM (National Centre for Sustainable Coastal Management) relevant.", "Darukaa_status": "planned", "input_data_required": "sea-level tide gauge records, DEM, storm surge models, coastal habitat maps", "open_data_sources": ["INCOIS India sea-level data", "NCSM coastal maps India", "NASA Coastal DEM (CoastalDEM)", "Global Mangrove Watch", "Copernicus Marine Service"], "access_type": "mixed", "computation_complexity": "medium", "example_use_case": "A port authority in Gujarat uses sea-level rise projections and coastal erosion data to disclose 2030\u20132050 coastal infrastructure risk under ESRS E1-