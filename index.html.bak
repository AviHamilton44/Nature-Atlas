  {"original_name":"Current total carbon stock","category":"Carbon & GHG","sub_category":"carbon stock overview","short_description":"Total carbon stock including biomass and soil organic carbon","TNFD_link":"LEAP-E (Evaluate): carbon stock as ecosystem provisioning service; LEAP-A (Assess): impact of land-use change on carbon; Dependency & Impact","TNFD_metric_type":"dependencies \u2013 carbon sequestration / ecosystem service","TNFD_code":"C5.0","SBTN_link":"Realm: Land; Steps: Assess, Track; Pressure: land-use change, degradation; metric: tCO\u2082e/ha stored","CSRD_ESRS_link":"ESRS E4-5 (carbon stocks in ecosystems \u2013 sequestration service); ESRS E1-3 (GHG removals from LULUCF)","India_relevance":"high","India_notes":"India's FSI estimates national forest carbon stocks; ISRO CARBONS project maps above-ground biomass. Global products: ESA CCI Biomass, Global Carbon Stock (Spawn et al.). NATCOM uses IPCC LULUCF methodology.","Darukaa_status":"available","input_data_required":"SAR/optical biomass model, LULC, allometric equations, soil data","open_data_sources":["ESA CCI Biomass 100m","GFW Carbon stocks (Spawn et al.)","ISRO CARBONS project India","FSI India biomass estimates","IPCC LULUCF Tier 2 data"],"access_type":"mixed","computation_complexity":"high","example_use_case":"A forestry company in Arunachal Pradesh quantifies above-ground biomass carbon stocks across its concession using ESA CCI Biomass data to disclose LULUCF removals under ESRS E1-3 and TNFD carbon dependency."},
  {"original_name":"Unrealized AGB carbon potential","category":"Carbon & GHG","sub_category":"carbon sequestration potential","short_description":"Gap between current and potential above-ground biomass carbon","TNFD_link":"LEAP-E (Evaluate) & LEAP-P (Prepare): identify carbon sequestration opportunities from restoration; Opportunity & Dependency","TNFD_metric_type":"opportunities \u2013 nature-based carbon sequestration","TNFD_code":"C5.0","SBTN_link":"Realm: Land; Steps: Act, Track; Pressure: land-use change mitigation; metric: potential tCO\u2082e/ha sequesterable","CSRD_ESRS_link":"ESRS E4-4 (targets \u2013 nature restoration with carbon co-benefits); ESRS E1-3 (planned GHG removals)","India_relevance":"high","India_notes":"India's NDC includes 2.5\u20133 billion tCO\u2082 additional carbon sink by 2030. ISRO/FSI used for national stock assessment. REDD+ methodology under MoEFCC. High opportunity in degraded forests, mangroves.","Darukaa_status":"prototype","input_data_required":"current biomass/SOC, potential natural vegetation model, LULC change data","open_data_sources":["ESA CCI Biomass","GFW Intact Forest Landscapes","ISRO CARBONS","Global Mangrove Watch carbon","FAO FRA global forest data"],"access_type":"mixed","computation_complexity":"high","example_use_case":"A corporate voluntarily quantifies unrealised carbon sequestration potential on degraded land within its supply chain to identify Nature-based Solutions investment opportunities and report under ESRS E4-4 targets."},
  {"original_name":"Unrealized BGB carbon potential","category":"Carbon & GHG","sub_category":"carbon sequestration potential","short_description":"Gap between current and potential below-ground biomass carbon","TNFD_link":"LEAP-E (Evaluate) & LEAP-P (Prepare): identify carbon sequestration opportunities from restoration; Opportunity & Dependency","TNFD_metric_type":"opportunities \u2013 nature-based carbon sequestration","TNFD_code":"C5.0","SBTN_link":"Realm: Land; Steps: Act, Track; Pressure: land-use change mitigation; metric: potential tCO\u2082e/ha sequesterable","CSRD_ESRS_link":"ESRS E4-4 (targets \u2013 nature restoration with carbon co-benefits); ESRS E1-3 (planned GHG removals)","India_relevance":"high","India_notes":"India's NDC includes 2.5\u20133 billion tCO\u2082 additional carbon sink by 2030. ISRO/FSI used for national stock assessment. REDD+ methodology under MoEFCC. High opportunity in degraded forests, mangroves.","Darukaa_status":"prototype","input_data_required":"current biomass/SOC, potential natural vegetation model, LULC change data","open_data_sources":["ESA CCI Biomass","GFW Intact Forest Landscapes","ISRO CARBONS","Global Mangrove Watch carbon","FAO FRA global forest data"],"access_type":"mixed","computation_complexity":"high","example_use_case":"A corporate voluntarily quantifies unrealised carbon sequestration potential on degraded land within its supply chain to identify Nature-based Solutions investment opportunities and report under ESRS E4-4 targets."},
