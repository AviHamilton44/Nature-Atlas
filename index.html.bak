<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Darukaa.Earth — Nature Indicator Atlas</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --ink: #0e1a0f;
  --paper: #f5f2eb;
  --paper2: #ede9df;
  --moss: #2d6a3f;
  --moss-light: #4a9e63;
  --moss-pale: #d4edda;
  --earth: #8b5e3c;
  --earth-pale: #f0e6da;
  --water: #1a4f7a;
  --water-pale: #d1e8f5;
  --fire: #b94a2c;
  --fire-pale: #fbe8e3;
  --sky: #4a2878;
  --sky-pale: #ead6f5;
  --gold: #c9960a;
  --gold-pale: #fdf3d0;
  --carbon: #1a6b5a;
  --carbon-pale: #d0ede8;
  --shield: #2e4057;
  --shield-pale: #d5dce6;
  --composite: #6b2d82;
  --composite-pale: #ead6f5;
  --nbs: #27ae60;
  --nbs-pale: #c8f0d8;
  --radius: 12px;
  --shadow: 0 2px 20px rgba(14,26,15,0.10);
  --shadow-lg: 0 8px 40px rgba(14,26,15,0.18);
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--paper);
  color: var(--ink);
  min-height: 100vh;
  font-size: 15px;
  line-height: 1.6;
}

/* ─── HEADER ─── */
.site-header {
  background: var(--ink);
  color: var(--paper);
  padding: 0;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 3px solid var(--moss);
}
.header-inner {
  max-width: 1600px;
  margin: 0 auto;
  padding: 16px 32px;
  display: flex;
  align-items: center;
  gap: 24px;
  flex-wrap: wrap;
}
.logo {
  font-family: 'DM Serif Display', serif;
  font-size: 1.5rem;
  letter-spacing: -0.5px;
  color: var(--paper);
  display: flex;
  align-items: center;
  gap: 10px;
  white-space: nowrap;
}
.logo .leaf { color: var(--moss-light); font-size: 1.3rem; }
.logo-sub {
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  color: rgba(245,242,235,0.5);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-left: 2px;
}
.header-stats {
  display: flex;
  gap: 20px;
  margin-left: auto;
  flex-wrap: wrap;
}
.hstat {
  font-family: 'DM Mono', monospace;
  font-size: 0.78rem;
  color: rgba(245,242,235,0.6);
  display: flex;
  align-items: center;
  gap: 6px;
}
.hstat strong { color: var(--moss-light); font-size: 1.1rem; font-weight: 600; }

/* ─── HERO ─── */
.hero {
  background: linear-gradient(135deg, var(--ink) 0%, #1a3322 50%, #0e2a1f 100%);
  color: var(--paper);
  padding: 64px 32px 48px;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute; inset: 0;
  background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%234a9e63' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  opacity: 1;
}
.hero-inner {
  max-width: 1600px;
  margin: 0 auto;
  position: relative;
}
.hero h1 {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(2rem, 4vw, 3.4rem);
  line-height: 1.15;
  margin-bottom: 16px;
  letter-spacing: -0.5px;
}
.hero h1 em { color: var(--moss-light); font-style: italic; }
.hero p {
  font-size: 1.05rem;
  color: rgba(245,242,235,0.75);
  max-width: 700px;
  margin-bottom: 32px;
  line-height: 1.7;
}
.framework-badges {
  display: flex; gap: 10px; flex-wrap: wrap;
}
.fbadge {
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  letter-spacing: 0.08em;
  padding: 5px 12px;
  border: 1.5px solid;
  border-radius: 20px;
  text-transform: uppercase;
  font-weight: 500;
}
.fbadge.tnfd { color: #6fcf97; border-color: #6fcf97; }
.fbadge.sbtn { color: #56cfe1; border-color: #56cfe1; }
.fbadge.csrd { color: #ffd166; border-color: #ffd166; }
.fbadge.brsr { color: #ff9f1c; border-color: #ff9f1c; }

/* ─── CONTROLS ─── */
.controls-bar {
  background: var(--paper2);
  border-bottom: 1px solid rgba(14,26,15,0.1);
  position: sticky;
  top: 64px;
  z-index: 90;
  padding: 14px 32px;
}
.controls-inner {
  max-width: 1600px;
  margin: 0 auto;
  display: flex;
  gap: 12px;
  align-items: center;
  flex-wrap: wrap;
}
.search-wrap {
  position: relative;
  flex: 1;
  min-width: 200px;
  max-width: 340px;
}
.search-wrap input {
  width: 100%;
  padding: 9px 14px 9px 38px;
  border: 1.5px solid rgba(14,26,15,0.15);
  border-radius: 8px;
  background: var(--paper);
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem;
  outline: none;
  transition: border-color 0.2s;
}
.search-wrap input:focus { border-color: var(--moss); }
.search-icon {
  position: absolute;
  left: 12px; top: 50%;
  transform: translateY(-50%);
  color: rgba(14,26,15,0.35);
  font-size: 0.9rem;
  pointer-events: none;
}
select.filter-select {
  padding: 9px 32px 9px 12px;
  border: 1.5px solid rgba(14,26,15,0.15);
  border-radius: 8px;
  background: var(--paper);
  font-family: 'DM Sans', sans-serif;
  font-size: 0.85rem;
  outline: none;
  cursor: pointer;
  appearance: none;
  background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L6 6L11 1' stroke='%230e1a0f' stroke-width='1.5'/%3E%3C/svg%3E");
  background-repeat: no-repeat;
  background-position: right 10px center;
  min-width: 160px;
}
select.filter-select:focus { border-color: var(--moss); }
.results-count {
  font-family: 'DM Mono', monospace;
  font-size: 0.8rem;
  color: rgba(14,26,15,0.45);
  margin-left: auto;
  white-space: nowrap;
}
.view-toggle { display: flex; gap: 6px; }
.vbtn {
  padding: 7px 14px;
  border: 1.5px solid rgba(14,26,15,0.15);
  border-radius: 7px;
  background: var(--paper);
  cursor: pointer;
  font-size: 0.85rem;
  font-family: 'DM Sans', sans-serif;
  transition: all 0.15s;
}
.vbtn.active { background: var(--moss); color: white; border-color: var(--moss); }
.vbtn:hover:not(.active) { border-color: var(--moss); }

/* ─── MAIN LAYOUT ─── */
.main {
  max-width: 1600px;
  margin: 0 auto;
  padding: 28px 32px;
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: 28px;
  align-items: start;
}
@media (max-width: 900px) {
  .main { grid-template-columns: 1fr; }
  .sidebar { display: none; }
}

/* ─── SIDEBAR ─── */
.sidebar {
  position: sticky;
  top: 130px;
}
.sidebar-section { margin-bottom: 24px; }
.sidebar-title {
  font-family: 'DM Mono', monospace;
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(14,26,15,0.4);
  margin-bottom: 10px;
  padding-left: 4px;
}
.cat-chip {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 7px 10px;
  border-radius: 8px;
  cursor: pointer;
  transition: background 0.15s;
  font-size: 0.84rem;
  margin-bottom: 3px;
  border: none;
  background: transparent;
  width: 100%;
  text-align: left;
  color: var(--ink);
}
.cat-chip:hover { background: var(--paper2); }
.cat-chip.active { background: var(--ink); color: var(--paper); }
.cat-chip .cat-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
}
.cat-chip .cat-count {
  margin-left: auto;
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  opacity: 0.55;
}

/* ─── CARDS GRID ─── */
.cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 18px;
}
.cards-grid.list-view {
  grid-template-columns: 1fr;
}

/* ─── INDICATOR CARD ─── */
.card {
  background: white;
  border-radius: var(--radius);
  border: 1.5px solid rgba(14,26,15,0.08);
  overflow: hidden;
  transition: transform 0.18s, box-shadow 0.18s;
  cursor: pointer;
  display: flex;
  flex-direction: column;
}
.card:hover {
  transform: translateY(-3px);
  box-shadow: var(--shadow-lg);
}
.card-accent {
  height: 4px;
}
.card-body {
  padding: 18px 20px 16px;
  flex: 1;
  display: flex;
  flex-direction: column;
}
.card-top {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  margin-bottom: 10px;
}
.card-icon {
  font-size: 1.4rem;
  flex-shrink: 0;
  margin-top: 1px;
}
.card-name {
  font-family: 'DM Serif Display', serif;
  font-size: 1.02rem;
  line-height: 1.3;
  color: var(--ink);
}
.card-sub {
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  color: rgba(14,26,15,0.45);
  margin-bottom: 8px;
  letter-spacing: 0.04em;
}
.card-desc {
  font-size: 0.84rem;
  color: rgba(14,26,15,0.65);
  margin-bottom: 14px;
  line-height: 1.55;
  flex: 1;
}
.card-footer {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
  margin-top: auto;
}
.pill {
  font-size: 0.7rem;
  font-family: 'DM Mono', monospace;
  padding: 3px 8px;
  border-radius: 20px;
  font-weight: 500;
  letter-spacing: 0.03em;
}
.pill.status-available { background: #d4edda; color: #1a6b36; }
.pill.status-prototype { background: #fdf3d0; color: #8a6000; }
.pill.status-planned { background: #d1e8f5; color: #0c3d6e; }
.pill.status-not_core { background: #f0f0f0; color: #555; }
.pill.rel-high { background: #d4edda; color: #1a6b36; }
.pill.rel-medium { background: #fdf3d0; color: #8a6000; }
.pill.rel-low { background: #f5e0e0; color: #8a1a1a; }
.pill.cx-low { background: #f0f0f0; color: #444; }
.pill.cx-medium { background: #fdf3d0; color: #8a6000; }
.pill.cx-high { background: #fbe8e3; color: #8a2a1a; }
.pill.access-open { background: #d4edda; color: #1a5a36; }
.pill.access-mixed { background: #ead6f5; color: #4a1060; }
.pill.access-proprietary_client { background: #f5e0e0; color: #7a1a1a; }

/* list view card */
.cards-grid.list-view .card {
  flex-direction: row;
}
.cards-grid.list-view .card-accent {
  width: 4px;
  height: auto;
}
.cards-grid.list-view .card-body {
  flex-direction: row;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
  padding: 14px 20px;
}
.cards-grid.list-view .card-top { margin-bottom: 0; flex: 1; min-width: 200px; }
.cards-grid.list-view .card-desc { display: none; }
.cards-grid.list-view .card-sub { margin-bottom: 0; }
.cards-grid.list-view .card-footer { margin-top: 0; }

/* ─── MODAL ─── */
.modal-overlay {
  position: fixed; inset: 0;
  background: rgba(14,26,15,0.65);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  backdrop-filter: blur(4px);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s;
}
.modal-overlay.open {
  opacity: 1;
  pointer-events: all;
}
.modal {
  background: var(--paper);
  border-radius: 16px;
  max-width: 860px;
  width: 100%;
  max-height: 90vh;
  overflow-y: auto;
  box-shadow: var(--shadow-lg);
  transform: translateY(20px);
  transition: transform 0.25s;
}
.modal-overlay.open .modal { transform: translateY(0); }
.modal-header {
  padding: 28px 32px 20px;
  border-bottom: 1px solid rgba(14,26,15,0.1);
  position: sticky;
  top: 0;
  background: var(--paper);
  z-index: 2;
  display: flex;
  align-items: flex-start;
  gap: 16px;
}
.modal-title-block { flex: 1; }
.modal-cat-badge {
  font-family: 'DM Mono', monospace;
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  padding: 3px 10px;
  border-radius: 20px;
  display: inline-block;
  margin-bottom: 8px;
  font-weight: 500;
}
.modal-title {
  font-family: 'DM Serif Display', serif;
  font-size: 1.65rem;
  line-height: 1.2;
  margin-bottom: 6px;
}
.modal-sub {
  font-family: 'DM Mono', monospace;
  font-size: 0.78rem;
  color: rgba(14,26,15,0.45);
  letter-spacing: 0.05em;
}
.modal-close {
  background: none;
  border: 1.5px solid rgba(14,26,15,0.15);
  border-radius: 50%;
  width: 36px; height: 36px;
  cursor: pointer;
  font-size: 1.1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background 0.15s;
}
.modal-close:hover { background: var(--paper2); }
.modal-body {
  padding: 24px 32px 32px;
}
.modal-desc {
  font-size: 0.95rem;
  color: rgba(14,26,15,0.7);
  margin-bottom: 24px;
  line-height: 1.7;
  padding: 16px;
  background: var(--paper2);
  border-radius: 8px;
  border-left: 3px solid var(--moss);
}

/* framework tabs */
.fw-tabs {
  display: flex;
  gap: 6px;
  margin-bottom: 20px;
  border-bottom: 1px solid rgba(14,26,15,0.1);
  padding-bottom: 0;
}
.fw-tab {
  padding: 8px 16px;
  border: none;
  background: none;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.88rem;
  font-weight: 500;
  cursor: pointer;
  color: rgba(14,26,15,0.5);
  border-bottom: 2.5px solid transparent;
  margin-bottom: -1px;
  transition: all 0.15s;
}
.fw-tab:hover { color: var(--ink); }
.fw-tab.active { color: var(--moss); border-bottom-color: var(--moss); }

.tab-panel { display: none; }
.tab-panel.active { display: block; }

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
  margin-bottom: 14px;
}
@media (max-width: 600px) { .info-grid { grid-template-columns: 1fr; } }

.info-block {
  background: white;
  border-radius: 10px;
  padding: 14px 16px;
  border: 1px solid rgba(14,26,15,0.08);
}
.info-block.full { grid-column: 1 / -1; }
.info-label {
  font-family: 'DM Mono', monospace;
  font-size: 0.68rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: rgba(14,26,15,0.4);
  margin-bottom: 5px;
}
.info-value {
  font-size: 0.88rem;
  color: var(--ink);
  line-height: 1.55;
}
.info-value code {
  font-family: 'DM Mono', monospace;
  font-size: 0.83rem;
  background: var(--paper2);
  padding: 1px 5px;
  border-radius: 4px;
}
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  margin-top: 4px;
}
.tag {
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  padding: 3px 8px;
  border-radius: 5px;
  background: var(--paper2);
  color: rgba(14,26,15,0.7);
}

.india-banner {
  background: linear-gradient(135deg, #ff9933 0%, #fff 50%, #138808 100%);
  border-radius: 10px;
  padding: 14px 16px;
  margin-bottom: 14px;
  position: relative;
  overflow: hidden;
}
.india-banner::before {
  content: '🇮🇳';
  position: absolute;
  right: 14px; top: 10px;
  font-size: 1.8rem;
  opacity: 0.3;
}
.india-banner .info-label { color: rgba(14,26,15,0.5); }
.india-banner .info-value {
  color: var(--ink);
  font-size: 0.87rem;
}
.use-case-block {
  background: linear-gradient(135deg, var(--moss-pale), #e8f5ee);
  border-radius: 10px;
  padding: 14px 16px;
  border-left: 3px solid var(--moss);
  margin-bottom: 14px;
}
.use-case-block .info-value { font-style: italic; }

/* NEW REFERENCE BLOCK STYLES */
.reference-block {
  background: var(--paper2);
  border-radius: 10px;
  padding: 14px 16px;
  border-left: 3px solid var(--earth);
  margin-bottom: 14px;
}
.reference-block .info-value { font-size: 0.85rem; color: rgba(14,26,15,0.8); }

.badge-row { display: flex; gap: 8px; flex-wrap: wrap; }

/* ─── CATEGORY SUMMARY SECTION ─── */
.cat-summary-section {
  margin-bottom: 32px;
  padding-bottom: 28px;
  border-bottom: 1px solid rgba(14,26,15,0.08);
}
.cat-summary-title {
  font-family: 'DM Serif Display', serif;
  font-size: 1.1rem;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.cat-cards-row {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 12px;
}
.cat-stat-card {
  padding: 14px 16px;
  border-radius: 10px;
  border: 1.5px solid rgba(14,26,15,0.08);
  cursor: pointer;
  transition: all 0.15s;
  background: white;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.cat-stat-card:hover { transform: translateY(-2px); box-shadow: var(--shadow); }
.cat-stat-icon { font-size: 1.4rem; }
.cat-stat-name { font-size: 0.8rem; font-weight: 500; line-height: 1.3; }
.cat-stat-count {
  font-family: 'DM Mono', monospace;
  font-size: 1.3rem;
  font-weight: 600;
  margin-top: 4px;
}
.cat-stat-bar { height: 3px; border-radius: 2px; margin-top: 6px; opacity: 0.6; }

/* ─── NO RESULTS ─── */
.no-results {
  grid-column: 1 / -1;
  text-align: center;
  padding: 64px 32px;
  color: rgba(14,26,15,0.35);
}
.no-results .emoji { font-size: 3rem; display: block; margin-bottom: 12px; }

/* ─── FOOTER ─── */
footer {
  background: var(--ink);
  color: rgba(245,242,235,0.5);
  padding: 24px 32px;
  text-align: center;
  font-family: 'DM Mono', monospace;
  font-size: 0.75rem;
  margin-top: 48px;
}
footer strong { color: var(--moss-light); }

/* scrollbar */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(14,26,15,0.2); border-radius: 3px; }

/* animations */
.card { animation: fadeUp 0.3s ease both; }
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}
</style>
</head>
<body>

<header class="site-header">
  <div class="header-inner">
    <div class="logo">
      <img src="Darukaa.Earth New Logo_White.jpg" alt="Darukaa.Earth" style="height: 32px; width: auto; border-radius: 4px;">
      <span class="logo-sub">Nature Indicator Atlas</span>
    </div>
    <div class="header-stats">
      <div class="hstat"><strong id="total-count">200+</strong> indicators</div>
      <div class="hstat"><strong>10</strong> categories</div>
      <div class="hstat"><strong>60</strong> sub-categories</div>
      <div class="hstat"><strong>TNFD · SBTN · CSRD · BRSR</strong></div>
    </div>
  </div>
</header>

<section class="hero">
  <div class="hero-inner">
    <h1>India's <em>Nature Intelligence</em><br>Indicator Library</h1>
    <p>A comprehensive, framework-aligned atlas of 200+ environmental indicators—mapped to TNFD LEAP, SBTN targets, CSRD/ESRS datapoints, and India-specific data sources—to power nature disclosure for Indian corporates, financial institutions, and project developers.</p>
    <div class="framework-badges">
      <span class="fbadge tnfd">TNFD LEAP</span>
      <span class="fbadge sbtn">SBTN Targets</span>
