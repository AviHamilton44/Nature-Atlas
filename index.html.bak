  {"original_name":"Future unrealized carbon potential","category":"Carbon & GHG","sub_category":"carbon sequestration potential","short_description":"Projected unrealized carbon potential under future climate scenarios","TNFD_link":"LEAP-E (Evaluate) & LEAP-P (Prepare): identify carbon sequestration opportunities from restoration; Opportunity & Dependency","TNFD_metric_type":"opportunities \u2013 nature-based carbon sequestration","TNFD_code":"IFRS S2","SBTN_link":"Realm: Land; Steps: Act, Track; Pressure: land-use change mitigation; metric: potential tCO\u2082e/ha sequesterable","CSRD_ESRS_link":"ESRS E4-4 (targets \u2013 nature restoration with carbon co-benefits); ESRS E1-3 (planned GHG removals)","India_relevance":"high","India_notes":"India's NDC includes 2.5\u20133 billion tCO\u2082 additional carbon sink by 2030. ISRO/FSI used for national stock assessment. REDD+ methodology under MoEFCC. High opportunity in degraded forests, mangroves.","Darukaa_status":"prototype","input_data_required":"current biomass/SOC, potential natural vegetation model, LULC change data","open_data_sources":["ESA CCI Biomass","GFW Intact Forest Landscapes","ISRO CARBONS","Global Mangrove Watch carbon","FAO FRA global forest data"],"access_type":"mixed","computation_complexity":"high","example_use_case":"A corporate voluntarily quantifies unrealised carbon sequestration potential on degraded land within its supply chain to identify Nature-based Solutions investment opportunities and report under ESRS E4-4 targets."},
  {"original_name":"Future carbon potential change","category":"Carbon & GHG","sub_category":"carbon sequestration potential","short_description":"Change in carbon sequestration potential under future climate scenarios","TNFD_link":"LEAP-E (Evaluate) & LEAP-P (Prepare): identify carbon sequestration opportunities from restoration; Opportunity & Dependency","TNFD_metric_type":"opportunities \u2013 nature-based carbon sequestration","TNFD_code":"C5.0 | IFRS S2","SBTN_link":"Realm: Land; Steps: Act, Track; Pressure: land-use change mitigation; metric: potential tCO\u2082e/ha sequesterable","CSRD_ESRS_link":"ESRS E4-4 (targets \u2013 nature restoration with carbon co-benefits); ESRS E1-3 (planned GHG removals)","India_relevance":"high","India_notes":"India's NDC includes 2.5\u20133 billion tCO\u2082 additional carbon sink by 2030. ISRO/FSI used for national stock assessment. REDD+ methodology under MoEFCC. High opportunity in degraded forests, mangroves.","Darukaa_status":"prototype","input_data_required":"current biomass/SOC, potential natural vegetation model, LULC change data","open_data_sources":["ESA CCI Biomass","GFW Intact Forest Landscapes","ISRO CARBONS","Global Mangrove Watch carbon","FAO FRA global forest data"],"access_type":"mixed","computation_complexity":"high","example_use_case":"A corporate voluntarily quantifies unrealised carbon sequestration potential on degraded land within its supply chain to identify Nature-based Solutions investment opportunities and report under ESRS E4-4 targets."},
  {"original_name":"Active fire detection","category":"Climate & physical risk","sub_category":"wildfire & fire risk","short_description":"Near-real-time detection of active fire hotspots from satellite","TNFD_link":"LEAP-A (Assess): acute physical risk from wildfire; LEAP-E (Evaluate): assess fire impact on ecosystem; Risk & Impact","TNFD_metric_type":"physical risk \u2013 wildfire","TNFD_code":"IFRS S2","SBTN_link":"Realm: Land; Steps: Assess, Track; Pressure: fire; metric: burned area, fire frequency","CSRD_ESRS_link":"ESRS E1-9 (physical risk \u2013 wildfire); ESRS E4-5 (ecosystem condition post-fire)","India_relevance":"high","India_notes":"FSI India Annual Forest Survey tracks fire incidence. ISRO NRSC provides near-real-time fire detection. High relevance for forested states: Chhattisgarh, Odisha, Uttarakhand, Manipur.","Darukaa_status":"available","input_data_required":"MODIS/VIIRS active fire, historical fire scars, climate data, LULC","open_data_sources":["NASA FIRMS (VIIRS/MODIS)","FSI Forest Fire data India","ISRO NRSC fire detection","Global Fire Emissions Database (GFED)","Copernicus CEMS fire"],"access_type":"open","computation_complexity":"low","example_use_case":"A forestry company in Odisha discloses wildfire risk and historical fire incidence within its plantation area using FSI/FIRMS data for TNFD physical risk assessment and ESRS E1-9 reporting."},
  {"original_name":"Socioeconomic indicators","category":"Socio-environmental & exposure","sub_category":"socioeconomic vulnerability","short_description":"Composite socioeconomic data layer for the area of interest","TNFD_link":"LEAP-A (Assess): socioeconomic vulnerability as amplifier of nature-related risk; Risk","TNFD_metric_type":"exposure index \u2013 socioeconomic vulnerability","TNFD_code":"No Annex 1/2 code \u2014 relates to TNFD Strategy D (priority locations) and stakeholder engagement guidance","SBTN_link":"Realm: Land; Steps: Assess; Pressure: all; metric: vulnerability index","CSRD_ESRS_link":"ESRS S3-3 (affected communities \u2013 vulnerability); ESRS E1-9 (climate risk \u2013 vulnerable populations)","India_relevance":"high","India_notes":"India's SECC (Socio-Economic and Caste Census) provides district-level vulnerability. UNDP MPI (Multidimensional Poverty Index) India data. Relevant for just transition analysis and community impact disclosures.","Darukaa_status":"not_core","input_data_required":"India SECC, UNDP MPI, District Human Development Index","open_data_sources":["UNDP MPI India data","India SECC 2011 (village level)","India Census socioeconomic indicators","Oxford Poverty & Human Development Initiative","World Bank poverty maps India"],"access_type":"open","computation_complexity":"low","example_use_case":"A development finance institution overlays socioeconomic vulnerability indices with flood risk maps to assess the disproportionate risk to marginalised communities in Bihar for ESRS S3-3 affected community disclosure."},
  {"original_name":"Harmonized World Soil Database","category":"Land use, land cover & fragmentation","sub_category":"soil type & condition","short_description":"Soil type classification from the FAO Harmonized World Soil Database","TNFD_link":"LEAP-E (Evaluate): soil quality as ecosystem condition indicator; Dependency disclosure (soil-based production)","TNFD_metric_type":"ecosystem condition \u2013 soil","TNFD_code":"C5.0","SBTN_link":"Realm: Land; Steps: Assess; Pressure: soil degradation; metric: soil organic carbon, soil type","CSRD_ESRS_link":"ESRS E4-5 (soil ecosystem condition); ESRS E2-5 (soil contamination)","India_relevance":"medium","India_notes":"FAO HWSD v2 and SoilGrids freely available. India has NBSS&LUP (National Bureau of Soil Survey) soil maps at 1:250K. Relevance for agri-food sector and mining.","Darukaa_status":"not_core","input_data_required":"FAO HWSD, SoilGrids, NBSS&LUP soil maps","open_data_sources":["FAO HWSD v2","ISRIC SoilGrids 250m","NBSS&LUP India soil maps","ICAR soil health data","Copernicus Soil Moisture"],"access_type":"open","computation_complexity":"low","example_use_case":"An agri-food company assesses baseline soil type and condition across its sourcing region in Punjab for TNFD Evaluate soil dependency disclosure."},
  {"original_name":"Distance to green areas","category":"Nature-based solutions & green infrastructure","sub_category":"urban green access","short_description":"Distance from each point to the nearest urban green area","TNFD_link":"LEAP-E (Evaluate): urban green area as NbS ecosystem service; Opportunity & Dependency","TNFD_metric_type":"opportunities \u2013 urban NbS / green infrastructure","TNFD_code":"C1.1 | C5.0","SBTN_link":"Realm: Land; Steps: Act, Track; Pressure: urban habitat loss; metric: green area per capita, distance to green","CSRD_ESRS_link":"ESRS E4-3 (action plans \u2013 urban greening); ESRS E4-4 (nature restoration targets in urban areas); ESRS S3-3 (community health)","India_relevance":"high","India_notes":"India's urban green gap is significant (WHO recommends 9 m\u00b2/person, most Indian cities <5 m\u00b2). Census town data + satellite NDVI for urban green mapping. Smart Cities Mission data available.","Darukaa_status":"prototype","input_data_required":"LULC urban layer, NDVI, OpenStreetMap park polygons, population grid","open_data_sources":["ISRO LULC urban Bhuvan","ESA WorldCover urban green","OpenStreetMap (parks/green)","GHSL population grid","Smart Cities Mission India portal"],"access_type":"open","computation_complexity":"medium","example_use_case":"A municipality in Pune uses satellite-derived urban green access mapping to benchmark green space equity across wards and set ESRS E4-4 urban restoration targets under BRSR ESG community reporting."},
  {"original_name":"Distance to small gardens","category":"Nature-based solutions & green infrastructure","sub_category":"urban green access","short_description":"Distance from each point to the nearest small urban garden","TNFD_link":"LEAP-E (Evaluate): urban green area as NbS ecosystem service; Opportunity & Dependency","TNFD_metric_type":"opportunities \u2013 urban NbS / green infrastructure","TNFD_code":"C1.1 | C5.0","SBTN_link":"Realm: Land; Steps: Act, Track; Pressure: urban habitat loss; metric: green area per capita, distance to green","CSRD_ESRS_link":"ESRS E4-3 (action plans \u2013 urban greening); ESRS E4-4 (nature restoration targets in urban areas); ESRS S3-3 (community health)","India_relevance":"high","India_notes":"India's urban green gap is significant (WHO recommends 9 m\u00b2/person, most Indian cities <5 m\u00b2). Census town data + satellite NDVI for urban green mapping. Smart Cities Mission data available.","Darukaa_status":"prototype","input_data_required":"LULC urban layer, NDVI, OpenStreetMap park polygons, population grid","open_data_sources":["ISRO LULC urban Bhuvan","ESA WorldCover urban green","OpenStreetMap (parks/green)","GHSL population grid","Smart Cities Mission India portal"],"access_type":"open","computation_complexity":"medium","example_use_case":"A municipality in Pune uses satellite-derived urban green access mapping to benchmark green space equity across wards and set ESRS E4-4 urban restoration targets under BRSR ESG community reporting."},
  {"original_name":"Distance to parks","category":"Nature-based solutions & green infrastructure","sub_category":"urban green access","short_description":"Distance from each point to the nearest park","TNFD_link":"LEAP-E (Evaluate): urban green area as NbS ecosystem service; Opportunity & Dependency","TNFD_metric_type":"opportunities \u2013 urban NbS / green infrastructure","TNFD_code":"C1.1 | C5.0","SBTN_link":"Realm: Land; Steps: Act, Track; Pressure: urban habitat loss; metric: green area per capita, distance to green","CSRD_ESRS_link":"ESRS E4-3 (action plans \u2013 urban greening); ESRS E4-4 (nature restoration targets in urban areas); ESRS S3-3 (community health)","India_relevance":"high","India_notes":"India's urban green gap is significant (WHO recommends 9 m\u00b2/person, most Indian cities <5 m\u00b2). Census town data + satellite NDVI for urban green mapping. Smart Cities Mission data available.","Darukaa_status":"prototype","input_data_required":"LULC urban layer, NDVI, OpenStreetMap park polygons, population grid","open_data_sources":["ISRO LULC urban Bhuvan","ESA WorldCover urban green","OpenStreetMap (parks/green)","GHSL population grid","Smart Cities Mission India portal"],"access_type":"open","computation_complexity":"medium","example_use_case":"A municipality in Pune uses satellite-derived urban green access mapping to benchmark green space equity across wards and set ESRS E4-4 urban restoration targets under BRSR ESG community reporting."},
  {"original_name":"Carbon Monoxide (map)","category":"Air quality & pollution","sub_category":"trace gas concentration","short_description":"Carbon monoxide (CO) column concentration from satellite","TNFD_link":"LEAP-A (Assess): air quality risk from trace gas pollution; Impact & Risk","TNFD_metric_type":"impacts \u2013 air quality / trace gas pollution","TNFD_code":"C2.4","SBTN_link":"Realm: Atmosphere; Steps: Assess, Track; Pressure: air pollution; metric: NO2/SO2/CO column density","CSRD_ESRS_link":"ESRS E2-4 (air pollutants \u2013 NOx, SOx, CO, VOCs); ESRS E2-3 (material pollution policy)","India_relevance":"high","India_notes":"CPCB monitors NOx, SOx, CO at 800+ stations. Sentinel-5P provides free satellite columns. High relevance for power plants, refineries, chemical industries subject to Environment Protection Act.","Darukaa_status":"prototype","input_data_required":"Sentinel-5P TROPOMI, CPCB CAAQM, EPA emission inventories","open_data_sources":["ESA Sentinel-5P TROPOMI","CPCB CAAQM India","OpenAQ","GEO-CHEM reanalysis","EDGAR emissions inventory India"],"access_type":"mixed","computation_complexity":"low","example_use_case":"A power utility in Chhattisgarh uses Sentinel-5P NO2 and SO2 data to monitor plume dispersion around its thermal plant and discloses under ESRS E2-4 air pollution indicators."},
  {"original_name":"Formaldehyde concentration","category":"Air quality & pollution","sub_category":"trace gas concentration","short_description":"Atmospheric formaldehyde (HCHO) column density","TNFD_link":"LEAP-A (Assess): air quality risk from trace gas pollution; Impact & Risk","TNFD_metric_type":"impacts \u2013 air quality / trace gas pollution","TNFD_code":"C5.0","SBTN_link":"Realm: Atmosphere; Steps: Assess, Track; Pressure: air pollution; metric: NO2/SO2/CO column density","CSRD_ESRS_link":"ESRS E2-4 (air pollutants \u2013 NOx, SOx, CO, VOCs); ESRS E2-3 (material pollution policy)","India_relevance":"high","India_notes":"CPCB monitors NOx, SOx, CO at 800+ stations. Sentinel-5P provides free satellite columns. High relevance for power plants, refineries, chemical industries subject to Environment Protection Act.","Darukaa_status":"prototype","input_data_required":"Sentinel-5P TROPOMI, CPCB CAAQM, EPA emission inventories","open_data_sources":["ESA Sentinel-5P TROPOMI","CPCB CAAQM India","OpenAQ","GEO-CHEM reanalysis","EDGAR emissions inventory India"],"access_type":"mixed","computation_complexity":"low","example_use_case":"A power utility in Chhattisgarh uses Sentinel-5P NO2 and SO2 data to monitor plume dispersion around its thermal plant and discloses under ESRS E2-4 air pollution indicators."},
  {"original_name":"Methane (map)","category":"Carbon & GHG","sub_category":"GHG atmospheric concentration","short_description":"Methane (CH4) column concentration from satellite","TNFD_link":"LEAP-A (Assess): site-level GHG emission monitoring from satellite; Impact disclosure","TNFD_metric_type":"impacts \u2013 GHG emissions (Scope 1 proxy)","TNFD_code":"IFRS S2","SBTN_link":"Realm: Atmosphere; Steps: Track; Pressure: GHG emissions; metric: atmospheric concentration (ppm/ppb)","CSRD_ESRS_link":"ESRS E1-6 (GHG emissions \u2013 Scope 1 gross); ESRS E1-7 (GHG removals); indirect validation layer","India_relevance":"high","India_notes":"Sentinel-5P/TROPOMI provides CH4 and CO2 column data useful for anomaly detection at industrial sites. CPCB Continuous Ambient Air Quality Monitoring (CAAQM) stations provide in-situ GHG proxies.","Darukaa_status":"prototype","input_data_required":"Sentinel-5P TROPOMI, GOSAT-2, in-situ atmospheric sensors","open_data_sources":["ESA Sentinel-5P TROPOMI (Copernicus)","JAXA GOSAT-2","NOAA GML atmospheric data","CPCB CAAQM India","Global Carbon Project"],"access_type":"open","computation_complexity":"medium","example_use_case":"A coal mine operator in Jharkhand uses Sentinel-5P methane column data to cross-validate its Scope 1 fugitive methane emissions estimates reported under ESRS E1-6."},
  {"original_name":"Nitrogen Dioxide (map)","category":"Air quality & pollution","sub_category":"trace gas concentration","short_description":"NO2 column concentration from satellite","TNFD_link":"LEAP-A (Assess): air quality risk from trace gas pollution; Impact & Risk","TNFD_metric_type":"impacts \u2013 air quality / trace gas pollution","TNFD_code":"C2.1 | C2.4","SBTN_link":"Realm: Atmosphere; Steps: Assess, Track; Pressure: air pollution; metric: NO2/SO2/CO column density","CSRD_ESRS_link":"ESRS E2-4 (air pollutants \u2013 NOx, SOx, CO, VOCs); ESRS E2-3 (material pollution policy)","India_relevance":"high","India_notes":"CPCB monitors NOx, SOx, CO at 800+ stations. Sentinel-5P provides free satellite columns. High relevance for power plants, refineries, chemical industries subject to Environment Protection Act.","Darukaa_status":"prototype","input_data_required":"Sentinel-5P TROPOMI, CPCB CAAQM, EPA emission inventories","open_data_sources":["ESA Sentinel-5P TROPOMI","CPCB CAAQM India","OpenAQ","GEO-CHEM reanalysis","EDGAR emissions inventory India"],"access_type":"mixed","computation_complexity":"low","example_use_case":"A power utility in Chhattisgarh uses Sentinel-5P NO2 and SO2 data to monitor plume dispersion around its thermal plant and discloses under ESRS E2-4 air pollution indicators."},
  {"original_name":"Ozone (map)","category":"Air quality & pollution","sub_category":"trace gas concentration","short_description":"Tropospheric ozone (O3) column concentration from satellite","TNFD_link":"LEAP-A (Assess): air quality risk from trace gas pollution; Impact & Risk","TNFD_metric_type":"impacts \u2013 air quality / trace gas pollution","TNFD_code":"C2.4","SBTN_link":"Realm: Atmosphere; Steps: Assess, Track; Pressure: air pollution; metric: NO2/SO2/CO column density","CSRD_ESRS_link":"ESRS E2-4 (air pollutants \u2013 NOx, SOx, CO, VOCs); ESRS E2-3 (material pollution policy)","India_relevance":"high","India_notes":"CPCB monitors NOx, SOx, CO at 800+ stations. Sentinel-5P provides free satellite columns. High relevance for power plants, refineries, chemical industries subject to Environment Protection Act.","Darukaa_status":"prototype","input_data_required":"Sentinel-5P TROPOMI, CPCB CAAQM, EPA emission inventories","open_data_sources":["ESA Sentinel-5P TROPOMI","CPCB CAAQM India","OpenAQ","GEO-CHEM reanalysis","EDGAR emissions inventory India"],"access_type":"mixed","computation_complexity":"low","example_use_case":"A power utility in Chhattisgarh uses Sentinel-5P NO2 and SO2 data to monitor plume dispersion around its thermal plant and discloses under ESRS E2-4 air pollution indicators."},
  {"original_name":"Sulfur dioxide concentration","category":"Air quality & pollution","sub_category":"trace gas concentration","short_description":"Atmospheric SO2 column concentration from satellite","TNFD_link":"LEAP-A (Assess): air quality risk from trace gas pollution; Impact & Risk","TNFD_metric_type":"impacts \u2013 air quality / trace gas pollution","TNFD_code":"C2.4","SBTN_link":"Realm: Atmosphere; Steps: Assess, Track; Pressure: air pollution; metric: NO2/SO2/CO column density","CSRD_ESRS_link":"ESRS E2-4 (air pollutants \u2013 NOx, SOx, CO, VOCs); ESRS E2-3 (material pollution policy)","India_relevance":"high","India_notes":"CPCB monitors NOx, SOx, CO at 800+ stations. Sentinel-5P provides free satellite columns. High relevance for power plants, refineries, chemical industries subject to Environment Protection Act.","Darukaa_status":"prototype","input_data_required":"Sentinel-5P TROPOMI, CPCB CAAQM, EPA emission inventories","open_data_sources":["ESA Sentinel-5P TROPOMI","CPCB CAAQM India","OpenAQ","GEO-CHEM reanalysis","EDGAR emissions inventory India"],"access_type":"mixed","computation_complexity":"low","example_use_case":"A power utility in Chhattisgarh uses Sentinel-5P NO2 and SO2 data to monitor plume dispersion around its thermal plant and discloses under ESRS E2-4 air pollution indicators."},
  {"original_name":"UV aerosol index","category":"Air quality & pollution","sub_category":"aerosol & particulate matter","short_description":"UV-absorbing aerosol index from satellite (dust, smoke, volcanic ash)","TNFD_link":"LEAP-A (Assess): aerosol loading as air quality and ecosystem impact; Risk","TNFD_metric_type":"impacts \u2013 air quality / aerosol loading","TNFD_code":"C2.4","SBTN_link":"Realm: Atmosphere; Steps: Assess; Pressure: air pollution; metric: AOD","CSRD_ESRS_link":"ESRS E2-4 (air pollutants \u2013 particulates, aerosols)","India_relevance":"high","India_notes":"AOD from MODIS and Sentinel-5P widely used for Indian air quality assessment. IMD SAFAR provides MODIS-based AOD. ISRO has long-term aerosol research over Indian subcontinent.","Darukaa_status":"prototype","input_data_required":"MODIS MOD04 AOD, Sentinel-5P UVAI, AERONET station data","open_data_sources":["MODIS MOD04_3K AOD","Sentinel-5P UVAI (Copernicus)","AERONET India stations","IMD SAFAR","NASA MERRA-2 AOD"],"access_type":"open","computation_complexity":"low","example_use_case":"A logistics company monitors aerosol optical depth trends near its transport corridors in Delhi using MODIS AOD data to assess air quality risks for driver health under ESRS S1-9 and E2-4."},
  {"original_name":"Fertilizer pollution overview","category":"Water quantity & quality","sub_category":"nutrient & agricultural pollution","short_description":"Overview of fertilizer pollution (N, P, K) from agricultural activity","TNFD_link":"LEAP-E (Evaluate): nutrient pollution as ecosystem condition stressor; Impact","TNFD_metric_type":"impacts \u2013 water quality / nutrient pollution","TNFD_code":"C5.0","SBTN_link":"Realm: Freshwater; Steps: Assess, Track; Pressure: pollution \u2013 nutrients; metric: N/P load (kg/ha/year)","CSRD_ESRS_link":"ESRS E2-4 (water quality \u2013 nutrients); ESRS E3-4 (water body ecological status); ESRS E4-5 (freshwater ecosystem condition)","India_relevance":"high","India_notes":"India uses >17M tonnes fertiliser/year; excess N/P major driver of river and groundwater pollution. CPCB water quality monitoring network; NRSC agricultural land maps. High relevance for Ganga and Krishna river basins.","Darukaa_status":"planned","input_data_required":"fertiliser application data, satellite NDVI, CPCB water quality, LULC","open_data_sources":["CPCB water quality data India","ISRO LULC agri layers","FAO fertiliser statistics","Global NEWS nutrient model","NRSC agricultural mapping"],"access_type":"mixed","computation_complexity":"medium","example_use_case":"A food company assesses nitrogen fertiliser pollution risk in its wheat sourcing watershed in Punjab using FAO and CPCB data to disclose water-quality impacts under ESRS E2-4 and TNFD Evaluate."},
  {"original_name":"Nitrogen fertilizer pollution","category":"Water quantity & quality","sub_category":"nutrient & agricultural pollution","short_description":"Nitrogen (N) fertilizer application and pollution risk","TNFD_link":"LEAP-E (Evaluate): nutrient pollution as ecosystem condition stressor; Impact","TNFD_metric_type":"impacts \u2013 water quality / nutrient pollution","TNFD_code":"C2.1","SBTN_link":"Realm: Freshwater; Steps: Assess, Track; Pressure: pollution \u2013 nutrients; metric: N/P load (kg/ha/year)","CSRD_ESRS_link":"ESRS E2-4 (water quality \u2013 nutrients); ESRS E3-4 (water body ecological status); ESRS E4-5 (freshwater ecosystem condition)","India_relevance":"high","India_notes":"India uses >17M tonnes fertiliser/year; excess N/P major driver of river and groundwater pollution. CPCB water quality monitoring network; NRSC agricultural land maps. High relevance for Ganga and Krishna river basins.","Darukaa_status":"planned","input_data_required":"fertiliser application data, satellite NDVI, CPCB water quality, LULC","open_data_sources":["CPCB water quality data India","ISRO LULC agri layers","FAO fertiliser statistics","Global NEWS nutrient model","NRSC agricultural mapping"],"access_type":"mixed","computation_complexity":"medium","example_use_case":"A food company assesses nitrogen fertiliser pollution risk in its wheat sourcing watershed in Punjab using FAO and CPCB data to disclose water-quality impacts under ESRS E2-4 and TNFD Evaluate."},
  {"original_name":"Phosphorus fertilizer pollution","category":"Water quantity & quality","sub_category":"nutrient & agricultural pollution","short_description":"Phosphorus (P) fertilizer application and pollution risk","TNFD_link":"LEAP-E (Evaluate): nutrient pollution as ecosystem condition stressor; Impact","TNFD_metric_type":"impacts \u2013 water quality / nutrient pollution","TNFD_code":"C2.1","SBTN_link":"Realm: Freshwater; Steps: Assess, Track; Pressure: pollution \u2013 nutrients; metric: N/P load (kg/ha/year)","CSRD_ESRS_link":"ESRS E2-4 (water quality \u2013 nutrients); ESRS E3-4 (water body ecological status); ESRS E4-5 (freshwater ecosystem condition)","India_relevance":"high","India_notes":"India uses >17M tonnes fertiliser/year; excess N/P major driver of river and groundwater pollution. CPCB water quality monitoring network; NRSC agricultural land maps. High relevance for Ganga and Krishna river basins.","Darukaa_status":"planned","input_data_required":"fertiliser application data, satellite NDVI, CPCB water quality, LULC","open_data_sources":["CPCB water quality data India","ISRO LULC agri layers","FAO fertiliser statistics","Global NEWS nutrient model","NRSC agricultural mapping"],"access_type":"mixed","computation_complexity":"medium","example_use_case":"A food company assesses nitrogen fertiliser pollution risk in its wheat sourcing watershed in Punjab using FAO and CPCB data to disclose water-quality impacts under ESRS E2-4 and TNFD Evaluate."},
  {"original_name":"Potassium fertilizer pollution","category":"Water quantity & quality","sub_category":"nutrient & agricultural pollution","short_description":"Potassium (K) fertilizer application and pollution risk","TNFD_link":"LEAP-E (Evaluate): nutrient pollution as ecosystem condition stressor; Impact","TNFD_metric_type":"impacts \u2013 water quality / nutrient pollution","TNFD_code":"C5.0","SBTN_link":"Realm: Freshwater; Steps: Assess, Track; Pressure: pollution \u2013 nutrients; metric: N/P load (kg/ha/year)","CSRD_ESRS_link":"ESRS E2-4 (water quality \u2013 nutrients); ESRS E3-4 (water body ecological status); ESRS E4-5 (freshwater ecosystem condition)","India_relevance":"high","India_notes":"India uses >17M tonnes fertiliser/year; excess N/P major driver of river and groundwater pollution. CPCB water quality monitoring network; NRSC agricultural land maps. High relevance for Ganga and Krishna river basins.","Darukaa_status":"planned","input_data_required":"fertiliser application data, satellite NDVI, CPCB water quality, LULC","open_data_sources":["CPCB water quality data India","ISRO LULC agri layers","FAO fertiliser statistics","Global NEWS nutrient model","NRSC agricultural mapping"],"access_type":"mixed","computation_complexity":"medium","example_use_case":"A food company assesses nitrogen fertiliser pollution risk in its wheat sourcing watershed in Punjab using FAO and CPCB data to disclose water-quality impacts under ESRS E2-4 and TNFD Evaluate."},
  {"original_name":"Toxic metals soil pollution","category":"Air quality & pollution","sub_category":"soil & land contamination","short_description":"Soil contamination by toxic heavy metals","TNFD_link":"LEAP-E (Evaluate): soil contamination as ecosystem condition stressor; Impact","TNFD_metric_type":"impacts \u2013 soil pollution / toxic contamination","TNFD_code":"C2.1 | C2.0","SBTN_link":"Realm: Land; Steps: Assess; Pressure: pollution \u2013 toxic substances; metric: heavy metal concentration mg/kg","CSRD_ESRS_link":"ESRS E2-5 (soil contamination); ESRS E2-3 (material pollution policy)","India_relevance":"high","India_notes":"Mining legacy pollution (arsenic in WB, lead in UP) and industrial sites are major issues. CPCB/SPCBs maintain contaminated sites register. NGT orders drive remediation disclosures.","Darukaa_status":"not_core","input_data_required":"in-situ soil sampling, CPCB contaminated sites register, geochemical maps","open_data_sources":["CPCB contaminated sites India","GSI geochemical atlas India","FOREGS geochemical baseline","ISRIC SoilGrids toxic metals","JECFA/FAO soil quality guidelines"],"access_type":"mixed","computation_complexity":"medium","example_use_case":"A mining company uses GSI geochemical maps and CPCB contaminated sites data to disclose soil heavy metal contamination around legacy mine sites under ESRS E2-5 soil contamination datapoint."},
  {"original_name":"Land Cover Classification","category":"Land use, land cover & fragmentation","sub_category":"land cover classification","short_description":"CLC-based land cover classification; prerequisite for biodiversity maps","TNFD_link":"LEAP-L (Locate): baseline spatial context; LEAP-E (Evaluate): land-cover change as ecosystem condition proxy; Impact disclosure","TNFD_metric_type":"ecosystem condition \u2013 land cover","TNFD_code":"C1.0 | C1.1 | C5.0","SBTN_link":"Realm: Land; Steps: Assess & Track; Pressure: land-use change; metric: % natural land cover","CSRD_ESRS_link":"ESRS E4-5 (ecosystem extent); ESRS E4-4 (targets on biodiversity); ESRS E2-5 (soil contamination)","India_relevance":"high","India_notes":"India's national LULC maps available at 1:50K from ISRO/NRSC via Bhuvan portal. ESA WorldCover 10m and Dynamic World 10m usable for annual change detection. State Forest Reports (FSI) for forest class.","Darukaa_status":"available","input_data_required":"multispectral satellite imagery, ground reference data","open_data_sources":["ISRO LULC 1:50K (Bhuvan)","ESA WorldCover 10m","Google Dynamic World","FSI India Forest Cover maps","MODIS MCD12Q1"],"access_type":"open","computation_complexity":"medium","example_use_case":"A plantation company tracks annual changes in natural land cover across its concession in Madhya Pradesh using national LULC data to comply with ESRS E4-5 ecosystem extent disclosures."},
  {"original_name":"Soil impermeability","category":"Land use, land cover & fragmentation","sub_category":"land artificialization","short_description":"Degree of soil sealing / impervious surface coverage","TNFD_link":"LEAP-L: locate where land has been sealed/built up; LEAP-E: assess ecosystem loss from impermeability; Impact & Dependency","TNFD_metric_type":"ecosystem condition \u2013 land impermeability / seal","TNFD_code":"C1.0 | C1.1 | C2.0","SBTN_link":"Realm: Land; Steps: Assess, Act; Pressure: land-use change \u2013 urban expansion; metric: sealed surface %","CSRD_ESRS_link":"ESRS E4-5 (ecosystem extent \u2013 artificial surfaces); ESRS E3-3 (water targets, runoff); ESRS E2-5 (soil)","India_relevance":"high","India_notes":"Urban sprawl fastest in Tier-2/3 Indian cities (Pune, Surat, Hyderabad). ISRO LULC and Copernicus GHSL provide built-up fraction. National Urban Digital Mission data complementary.","Darukaa_status":"available","input_data_required":"satellite LULC, built-up surface layer, DEM","open_data_sources":["GHSL Global Human Settlement Layer","ISRO LULC Bhuvan","ESA WorldCover","Copernicus Urban Atlas","Google Open Buildings India"],"access_type":"open","computation_complexity":"low","example_use_case":"A real estate developer in Bangalore quantifies the fraction of new built-up area replacing natural land over 5 years for TNFD Locate disclosures and ESRS E4-5 reporting."},
  {"original_name":"Natural and Agricultural Areas","category":"Land use, land cover & fragmentation","sub_category":"land cover classification","short_description":"Classification of land into natural vs agricultural area types","TNFD_link":"LEAP-L (Locate): baseline spatial context; LEAP-E (Evaluate): land-cover change as ecosystem condition proxy; Impact disclosure","TNFD_metric_type":"ecosystem condition \u2013 land cover","TNFD_code":"C1.0 | C1.1","SBTN_link":"Realm: Land; Steps: Assess & Track; Pressure: land-use change; metric: % natural land cover","CSRD_ESRS_link":"ESRS E4-5 (ecosystem extent); ESRS E4-4 (targets on biodiversity); ESRS E2-5 (soil contamination)","India_relevance":"high","India_notes":"India's national LULC maps available at 1:50K from ISRO/NRSC via Bhuvan portal. ESA WorldCover 10m and Dynamic World 10m usable for annual change detection. State Forest Reports (FSI) for forest class.","Darukaa_status":"available","input_data_required":"multispectral satellite imagery, ground reference data","open_data_sources":["ISRO LULC 1:50K (Bhuvan)","ESA WorldCover 10m","Google Dynamic World","FSI India Forest Cover maps","MODIS MCD12Q1"],"access_type":"open","computation_complexity":"medium","example_use_case":"A plantation company tracks annual changes in natural land cover across its concession in Madhya Pradesh using national LULC data to comply with ESRS E4-5 ecosystem extent disclosures."},
  {"original_name":"Spectrum device heatmap","category":"Biodiversity & ecosystems","sub_category":"in-situ biodiversity monitoring","short_description":"Heatmap from in-field Spectrum IoT device sensor network","TNFD_link":"LEAP-E (Evaluate): ground-truth ecosystem condition with real-time sensor data; Impact & Dependency monitoring","TNFD_metric_type":"ecosystem condition \u2013 in-situ species activity","TNFD_code":"C5.0","SBTN_link":"Realm: Land; Steps: Track; Pressure: monitoring indicator for all pressures; metric: species activity index","CSRD_ESRS_link":"ESRS E4-5 (biodiversity monitoring method); ESRS E4-3 (action plans with KPIs)","India_relevance":"high","India_notes":"Darukaa's bioacoustic and IoT sensor network is core differentiator in India. Deployable in agri-landscapes, forests, and wetlands. Relevant for BRSR Core ESG indicators on biodiversity.","Darukaa_status":"available","input_data_required":"IoT device telemetry, acoustic recordings, GPS coordinates","open_data_sources":["Darukaa Spectrum/proprietary","iNaturalist India","eBird India","GBIF","WII camera trap networks"],"access_type":"proprietary_client","computation_complexity":"medium","example_use_case":"A tea estate in Assam deploys Darukaa sensors to monitor pollinator activity and nocturnal biodiversity, providing ground-truth data for TNFD Evaluate disclosures and BRSR Core ESG reporting."},
  {"original_name":"Extreme weather events","category":"Climate & physical risk","sub_category":"extreme weather events","short_description":"Historical spatial record of extreme weather events","TNFD_link":"LEAP-A (Assess): acute physical climate risks from storms and extreme events; Risk disclosure","TNFD_metric_type":"physical risk \u2013 extreme weather","TNFD_code":"IFRS S2","SBTN_link":"Realm: Atmosphere; Steps: Assess, Prioritise; Pressure: extreme weather; metric: event frequency and intensity trend","CSRD_ESRS_link":"ESRS E1-9 (physical risks \u2013 extreme precipitation, storms); ESRS E1-3 (scenario analysis)","India_relevance":"high","India_notes":"India faces cyclones (Bay of Bengal), deluges, and hailstorms. IMD cyclone atlas, NDMA multi-hazard atlas, ISRO NRSC extreme event monitoring.","Darukaa_status":"available","input_data_required":"historical weather station data, IMD extreme event records, ERA5","open_data_sources":["IMD India extreme weather events","NDMA multi-hazard atlas","EM-DAT disaster database","NOAA Storm Events DB","ERA5 extreme indices"],"access_type":"open","computation_complexity":"low","example_use_case":"An insurer quantifies the frequency trend of extreme rainfall events at client sites in Maharashtra for TNFD physical risk scenario analysis and ESRS E1-9 disclosure."},
  {"original_name":"Cultural and artistic heritage POIs","category":"Socio-environmental & exposure","sub_category":"cultural & heritage assets","short_description":"Points of interest for cultural and artistic heritage sites","TNFD_link":"LEAP-L (Locate): cultural heritage as context for nature-related risk / social licence; Impact","TNFD_metric_type":"exposure index \u2013 cultural heritage","TNFD_code":"No Annex 1/2 code \u2014 relates to TNFD Strategy D (priority locations) and stakeholder engagement guidance","SBTN_link":"Realm: Land; Steps: Assess; Pressure: infrastructure, tourism pressure; metric: proximity/count","CSRD_ESRS_link":"ESRS S3-3 (affected communities \u2013 indigenous/cultural sites); ESRS E4-2 (policy on sacred/cultural areas)","India_relevance":"medium","India_notes":"ASI (Archaeological Survey of India) maintains 3,691 centrally protected monuments. Forest Rights Act implications for indigenous communities near forested cultural sites.","Darukaa_status":"not_core","input_data_required":"ASI monument database, state heritage lists, NLCPR data","open_data_sources":["ASI India protected monuments list","UNESCO World Heritage India","OpenStreetMap heritage POIs","Wikidata cultural heritage India","State tourism department portals"],"access_type":"open","computation_complexity":"low","example_use_case":"An infrastructure developer screens its project corridor for proximity to ASI-protected monuments and forest communities under ESRS S3-3 affected community identification and India's LARR Act compliance."},
  {"original_name":"Oasi Ecological Features Score","category":"Nature-based solutions & green infrastructure","sub_category":"managed nature restoration sites","short_description":"Ecological features of our managed oasis sites","TNFD_link":"LEAP-P (Prepare): track progress of NbS investments; Opportunity disclosure","TNFD_metric_type":"opportunities \u2013 NbS / ecological restoration","TNFD_code":"C1.1 | C5.0","SBTN_link":"Realm: Land; Steps: Act, Track; Pressure: all; metric: restored area (ha), ecosystem health KPIs","CSRD_ESRS_link":"ESRS E4-3 (action plans \u2013 restoration); ESRS E4-4 (restoration targets and progress KPIs)","India_relevance":"high","India_notes":"India's LCRMP and MoEFCC restoration targets under Bonn Challenge/UNCCD. Darukaa's oasis network is proprietary differentiator for real-time restoration monitoring.","Darukaa_status":"available","input_data_required":"Darukaa sensor network, satellite NDVI/habitat, bioacoustic data","open_data_sources":["Darukaa platform (proprietary)","ISRO LULC restoration layers","FSI India restoration data","IUFRO restoration data","GFW tree cover gain"],"access_type":"proprietary_client","computation_complexity":"medium","example_use_case":"A corporate's biodiversity offset project uses Darukaa's oasis data to track restoration progress with NDVI, bioacoustics, and pollinator KPIs for ESRS E4-4 restoration target reporting."},
  {"original_name":"Aqueduct Water Risk","category":"Water quantity & quality","sub_category":"water stress & aridity","short_description":"Water risk assessment using WRI Aqueduct data (baseline water stress, variability, etc.)","TNFD_link":"LEAP-L (Locate): identify water-stressed locations; LEAP-E (Evaluate): assess water dependency risk; Dependency & Risk","TNFD_metric_type":"dependencies \u2013 water stress / freshwater availability","TNFD_code":"C3.0","SBTN_link":"Realm: Freshwater; Steps: Assess, Interpret; Pressure: water withdrawal vs availability; metric: BWS (Baseline Water Stress)","CSRD_ESRS_link":"ESRS E3-1 (water stress areas policy); ESRS E3-4 (water targets in stressed areas); ESRS E3-3 (water withdrawal)","India_relevance":"high","India_notes":"India has 18% of world population but 4% freshwater. WRI Aqueduct India data freely available. CWC water availability data at sub-basin level. High relevance for manufacturing, agri, textile sectors.","Darukaa_status":"available","input_data_required":"WRI Aqueduct data, CWC streamflow data, GRACE groundwater, LULC","open_data_sources":["WRI Aqueduct 4.0","CWC India water data","NASA GRACE groundwater anomaly","IMD precipitation data","FAO AQUASTAT India"],"access_type":"open","computation_complexity":"low","example_use_case":"A textile company in Tirupur uses WRI Aqueduct data to identify high water-stress sourcing locations and discloses under ESRS E3-1 water stress policy and TNFD Locate disclosures."},
  {"original_name":"IUCN Red List","category":"Biodiversity & ecosystems","sub_category":"threatened species","short_description":"Evaluation of threatened species presence in the area against IUCN Red List categories","TNFD_link":"LEAP-L (Locate): flag sites near threatened-species ranges; LEAP-E (Evaluate): quantify species at risk; Impact & Risk disclosure","TNFD_metric_type":"ecosystem condition \u2013 threatened species","TNFD_code":"C5.0","SBTN_link":"Realm: Land/Freshwater/Ocean; Steps: Assess, Interpret; Pressure: all pressures; metric: number of IUCN threatened species present","CSRD_ESRS_link":"ESRS E4-5 (biodiversity state \u2013 IUCN Red List species); ESRS E4-1 (transition plan); IRO identification","India_relevance":"high","India_notes":"IUCN Red List freely accessible; overlay with WII Protected Area Network, Wildlife Crime Control Bureau data. India hosts 172 IUCN CR/EN species. Schedule I of Wildlife Protection Act 1972 as Indian legal layer.","Darukaa_status":"available","input_data_required":"IUCN Red List species range maps, protected area boundaries, LULC","open_data_sources":["IUCN Red List API","GBIF species occurrence","WII Protected Area Network India","Map of Life","MoEFCC Species lists"],"access_type":"open","computation_complexity":"low","example_use_case":"A mining company in Odisha uses IUCN Red List layer to flag threatened species within 10 km of a proposed mine, fulfilling TNFD Locate step and ESRS E4 IRO identification requirements."},
  {"original_name":"Biodiversity Report","category":"Composite / platform scores","sub_category":"integrated biodiversity report","short_description":"Full biodiversity report with data aggregation, charts, and AI analysis","TNFD_link":"LEAP-P (Prepare): supports integrated reporting and board-level disclosure; aggregates multiple LEAP outputs; Impact, Dependency, Risk & Opportunity","TNFD_metric_type":"composite platform score / integrated report","TNFD_code":"C5.0","SBTN_link":"Realm: cross-realm; Steps: all; metric: composite index or AI narrative","CSRD_ESRS_link":"ESRS E4 (all datapoints via aggregation); ESRS 2-SBM-3 (sustainability due diligence); supports BRSR Core ESG disclosure","India_relevance":"high","India_notes":"Composite outputs are high-value for Indian corporates navigating BRSR Core (SEBI 2023), TNFD early adopter programmes, and voluntary CSRD equivalence. AI narratives can populate ESRS qualitative datapoints.","Darukaa_status":"available","input_data_required":"all indicator layers, AI model (Gemini/Others), Google Docs integration","open_data_sources":["Darukaa platform (proprietary)","TNFD disclosure portal","BRSR MCA21 portal India","GRI Standards","CDP Nature"],"access_type":"proprietary_client","computation_complexity":"high","example_use_case":"A listed Indian company uses Darukaa's Biodiversity Report to auto-generate TNFD-aligned and BRSR Core-compliant nature disclosures, reducing manual effort in annual sustainability reporting.","additional_comments":"This is a platform output product rather than a standalone environmental metric. Quality depends on the underlying indicators feeding the composite."},
  {"original_name":"AI Comment Generation","category":"Composite / platform scores","sub_category":"AI-generated insights","short_description":"AI-powered analysis and commentary on monitoring data using Gemini","TNFD_link":"LEAP-P (Prepare): supports integrated reporting and board-level disclosure; aggregates multiple LEAP outputs; Impact, Dependency, Risk & Opportunity","TNFD_metric_type":"composite platform score / integrated report","TNFD_code":"C5.0","SBTN_link":"Realm: cross-realm; Steps: all; metric: composite index or AI narrative","CSRD_ESRS_link":"ESRS E4 (all datapoints via aggregation); ESRS 2-SBM-3 (sustainability due diligence); supports BRSR Core ESG disclosure","India_relevance":"high","India_notes":"Composite outputs are high-value for Indian corporates navigating BRSR Core (SEBI 2023), TNFD early adopter programmes, and voluntary CSRD equivalence. AI narratives can populate ESRS qualitative datapoints.","Darukaa_status":"available","input_data_required":"all indicator layers, AI model (Gemini/Others), Google Docs integration","open_data_sources":["Darukaa platform (proprietary)","TNFD disclosure portal","BRSR MCA21 portal India","GRI Standards","CDP Nature"],"access_type":"proprietary_client","computation_complexity":"high","example_use_case":"A listed Indian company uses Darukaa's Biodiversity Report to auto-generate TNFD-aligned and BRSR Core-compliant nature disclosures, reducing manual effort in annual sustainability reporting.","additional_comments":"This is a platform output product rather than a standalone environmental metric. Quality depends on the underlying indicators feeding the composite."},
  {"original_name":"Mean Species Abundance","category":"Biodiversity & ecosystems","sub_category":"mean species abundance","short_description":"MSA index measuring average abundance of species relative to undisturbed reference","TNFD_link":"LEAP-E (Evaluate): core metric for biodiversity intactness; LEAP-A (Assess): quantify nature-related impacts from land use; Impacts & Dependencies","TNFD_metric_type":"ecosystem condition \u2013 biodiversity intactness","TNFD_code":"C5.0","SBTN_link":"Realm: Land; Steps: Assess, Interpret, Track; Pressure: land-use change, fragmentation, climate change; metric: MSA loss (PDF.m\u00b2.yr)","CSRD_ESRS_link":"ESRS E4-5 (biodiversity state \u2013 species abundance); ESRS E4-DR (due diligence policies); IRO assessment","India_relevance":"high","India_notes":"GLOBIO/PBL MSA model applicable globally including India. Local calibration needed; use NBSAP species-richness data or WII survey data for ground-truthing. High relevance for mining, infrastructure, and plantation sectors.","Darukaa_status":"available","input_data_required":"LULC map, road network, climate data, species-habitat models","open_data_sources":["PBL GLOBIO4 model","ESA WorldCover 10m","ISRO LULC 1:50K (Bhuvan)","OpenStreetMap road network","GBIF species occurrence"],"access_type":"mixed","computation_complexity":"high","example_use_case":"An infrastructure developer submits MSA scores to TNFD disclosures to show projected biodiversity impact of a highway corridor through a biodiversity hotspot in the Western Ghats."},
  {"original_name":"MSA Climate Change component","category":"Biodiversity & ecosystems","sub_category":"mean species abundance","short_description":"MSA component attributable to climate change pressure","TNFD_link":"LEAP-E (Evaluate): core metric for biodiversity intactness; LEAP-A (Assess): quantify nature-related impacts from land use; Impacts & Dependencies","TNFD_metric_type":"ecosystem condition \u2013 biodiversity intactness","TNFD_code":"C5.0","SBTN_link":"Realm: Land; Steps: Assess, Interpret, Track; Pressure: land-use change, fragmentation, climate change; metric: MSA loss (PDF.m\u00b2.yr)","CSRD_ESRS_link":"ESRS E4-5 (biodiversity state \u2013 species abundance); ESRS E4-DR (due diligence policies); IRO assessment","India_relevance":"high","India_notes":"GLOBIO/PBL MSA model applicable globally including India. Local calibration needed; use NBSAP species-richness data or WII survey data for ground-truthing. High relevance for mining, infrastructure, and plantation sectors.","Darukaa_status":"available","input_data_required":"LULC map, road network, climate data, species-habitat models","open_data_sources":["PBL GLOBIO4 model","ESA WorldCover 10m","ISRO LULC 1:50K (Bhuvan)","OpenStreetMap road network","GBIF species occurrence"],"access_type":"mixed","computation_complexity":"high","example_use_case":"An infrastructure developer submits MSA scores to TNFD disclosures to show projected biodiversity impact of a highway corridor through a biodiversity hotspot in the Western Ghats."},
