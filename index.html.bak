INDICATORS.forEach(ind => {
  for (let key in referenceMapping) {
    if (ind.original_name && ind.original_name.includes(key)) {
      ind.reference = referenceMapping[key];
    }
  }
});

const CAT_META = {
  "Biodiversity & ecosystems": { color: "#2d6a3f", bg: "#d4edda", icon: "🌿" },
  "Land use, land cover & fragmentation": { color: "#7a5c2d", bg: "#f0e6da", icon: "🗺️" },
  "Climate & physical risk": { color: "#b94a2c", bg: "#fbe8e3", icon: "🌡️" },
  "Carbon & GHG": { color: "#1a6b5a", bg: "#d0ede8", icon: "💨" },
  "Water quantity & quality": { color: "#1a4f7a", bg: "#d1e8f5", icon: "💧" },
  "Air quality & pollution": { color: "#6c3483", bg: "#ead6f5", icon: "🌫️" },
  "Nature-based solutions & green infrastructure": { color: "#27ae60", bg: "#c8f0d8", icon: "🌳" },
  "Socio-environmental & exposure": { color: "#d68910", bg: "#fdf3d0", icon: "👥" },
  "Compliance & proximity to protected/sensitive areas": { color: "#2e4057", bg: "#d5dce6", icon: "🛡️" },
  "Composite / platform scores": { color: "#6b2d82", bg: "#ead6f5", icon: "📊" }
};

let currentView = 'grid';
let activeCategory = '';
let currentIndicator = null;

document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('total-count').textContent = INDICATORS.length;
  populateCatFilter();
  buildCatSidebar();
  buildCatOverview();
  renderCards(INDICATORS);
});

function populateCatFilter() {
  const sel = document.getElementById('catFilter');
  Object.keys(CAT_META).forEach(cat => {
    const opt = document.createElement('option');
    opt.value = cat; opt.textContent = cat;
    sel.appendChild(opt);
  });
}

function buildCatSidebar() {
  const counts = {};
  INDICATORS.forEach(d => { counts[d.category] = (counts[d.category]||0)+1; });
  const el = document.getElementById('catSidebar');
  const all = document.createElement('button');
  all.className = 'cat-chip active';
  all.innerHTML = `<span class="cat-dot" style="background:#0e1a0f"></span><span>All</span><span class="cat-count">${INDICATORS.length}</span>`;
  all.onclick = () => { activeCategory=''; document.querySelectorAll('.cat-chip').forEach(c=>c.classList.remove('active')); all.classList.add('active'); document.getElementById('catFilter').value=''; filterCards(); };
  el.appendChild(all);
  Object.keys(CAT_META).forEach(cat => {
    const m = CAT_META[cat];
    const btn = document.createElement('button');
    btn.className = 'cat-chip';
    btn.innerHTML = `<span class="cat-dot" style="background:${m.color}"></span><span style="flex:1">${cat.length>28?cat.substr(0,28)+'…':cat}</span><span class="cat-count">${counts[cat]||0}</span>`;
    btn.title = cat;
    btn.onclick = () => {
      document.querySelectorAll('.cat-chip').forEach(c=>c.classList.remove('active')); btn.classList.add('active');
      document.getElementById('catFilter').value = cat;
      filterCards();
    };
    el.appendChild(btn);
  });
}

function buildCatOverview() {
  const counts = {};
  INDICATORS.forEach(d => { counts[d.category] = (counts[d.category]||0)+1; });
  const el = document.getElementById('catOverview');
  Object.entries(CAT_META).forEach(([cat, m]) => {
    const card = document.createElement('div');
    card.className = 'cat-stat-card';
    const pct = ((counts[cat]||0)/INDICATORS.length*100).toFixed(0);
    card.innerHTML = `<span class="cat-stat-icon">${m.icon}</span><span class="cat-stat-name">${cat}</span><span class="cat-stat-count" style="color:${m.color}">${counts[cat]||0}</span><div class="cat-stat-bar" style="background:${m.color};width:${pct}%"></div>`;
    card.onclick = () => { document.getElementById('catFilter').value=cat; filterCards(); card.closest('.cat-summary-section').style.display='none'; };
    el.appendChild(card);
  });
}

function filterCards() {
  const q = document.getElementById('searchInput').value.toLowerCase();
  const cat = document.getElementById('catFilter').value;
  const stat = document.getElementById('statusFilter').value;
  const rel = document.getElementById('relFilter').value;
  const cx = document.getElementById('cxFilter').value;
  const filtered = INDICATORS.filter(d => {
    if (cat && d.category !== cat) return false;
    if (stat && d.Darukaa_status !== stat) return false;
    if (rel && d.India_relevance !== rel) return false;
    if (cx && d.computation_complexity !== cx) return false;
    if (q) {
      const hay = ((d.original_name||"")+(d.short_description||"")+(d.sub_category||"")+(d.TNFD_metric_type||"")+(d.India_notes||"")).toLowerCase();
      if (!hay.includes(q)) return false;
    }
    return true;
  });
  document.getElementById('resultsCount').textContent = `${filtered.length} indicator${filtered.length!==1?'s':''}`;
  const hasFilter = q||cat||stat||rel||cx;
  document.getElementById('overviewSection').style.display = hasFilter ? 'none' : '';
  renderCards(filtered);
}

function renderCards(list) {
  const grid = document.getElementById('cardsGrid');
  grid.innerHTML = '';
  if (!list.length) {
    grid.innerHTML = '<div class="no-results"><span class="emoji">🔍</span>No indicators match your filters.</div>';
    return;
  }
  list.forEach((d, i) => {
    const m = CAT_META[d.category] || { color:'#555', bg:'#eee', icon:'📊' };
    const card = document.createElement('div');
    card.className = 'card';
    card.style.animationDelay = `${Math.min(i,20)*0.03}s`;
    card.innerHTML = `
      <div class="card-accent" style="background:${m.color}"></div>
      <div class="card-body">
        <div class="card-top"><span class="card-icon">${m.icon}</span><div><div class="card-name">${esc(d.original_name)}</div></div></div>
        <div class="card-sub">${esc(d.sub_category)}</div>
        <div class="card-desc">${esc(d.short_description)}</div>
        <div class="card-footer">
          <span class="pill status-${d.Darukaa_status}">${statusLabel(d.Darukaa_status)}</span>
          <span class="pill rel-${d.India_relevance}">India: ${d.India_relevance}</span>
          <span class="pill cx-${d.computation_complexity}">${d.computation_complexity} cx</span>
          <span class="pill access-${d.access_type}">${accessLabel(d.access_type)}</span>
        </div>
      </div>`;
    card.onclick = () => openModal(d);
    grid.appendChild(card);
  });
}

function openModal(d) {
  currentIndicator = d;
  const m = CAT_META[d.category] || { color:'#555', bg:'#eee', icon:'📊' };
  document.getElementById('mCatBadge').textContent = m.icon+' '+d.category;
  document.getElementById('mCatBadge').style.background = m.bg;
  document.getElementById('mCatBadge').style.color = m.color;
  document.getElementById('mTitle').textContent = d.original_name;
  document.getElementById('mSub').textContent = d.sub_category;
  document.getElementById('mDesc').textContent = d.short_description;
  
  document.getElementById('m-tnfd-link').textContent = d.TNFD_link||'—';
  document.getElementById('m-tnfd-type').textContent = d.TNFD_metric_type||'—';
  document.getElementById('m-tnfd-code').innerHTML = d.TNFD_code ? `<code>${d.TNFD_code}</code>` : '<em style="opacity:0.5">No specific code</em>';
  document.getElementById('m-data-type').textContent = d.data_type||d.TNFD_metric_type||'—';
  document.getElementById('m-sbtn').textContent = d.SBTN_link||'—';
  document.getElementById('m-csrd').textContent = d.CSRD_ESRS_link||'—';
  document.getElementById('m-india-notes').textContent = d.India_notes||'—';
  document.getElementById('m-india-rel').innerHTML = `<span class="pill rel-${d.India_relevance}">${d.India_relevance}</span>`;
  document.getElementById('m-darukaa').innerHTML = `<span class="pill status-${d.Darukaa_status}">${statusLabel(d.Darukaa_status)}</span>`;
  
  document.getElementById('m-input-data').textContent = d.input_data_required||'—';
  const srcEl = document.getElementById('m-open-src');
  srcEl.innerHTML = '';
  (d.open_data_sources||[]).forEach(s => {
    const t = document.createElement('span'); t.className='tag'; t.textContent=s; srcEl.appendChild(t);
  });
  document.getElementById('m-access').innerHTML = `<span class="pill access-${d.access_type}">${accessLabel(d.access_type)}</span>`;
  document.getElementById('m-cx').innerHTML = `<span class="pill cx-${d.computation_complexity}">${d.computation_complexity} complexity</span>`;
  
  document.getElementById('m-use-case').textContent = d.example_use_case||'—';
  
  if (d.additional_comments) {
    document.getElementById('m-comments-block').style.display='';
    document.getElementById('m-comments').textContent = d.additional_comments;
  } else {
    document.getElementById('m-comments-block').style.display='none';
  }

  // --- NEW REFERENCE LOGIC HERE ---
  if (d.reference) {
    document.getElementById('m-ref-block').style.display='';
    document.getElementById('m-reference').textContent = d.reference;
  } else {
    document.getElementById('m-ref-block').style.display='none';
  }
  
  switchTab('tnfd', document.querySelector('.fw-tab'));
  document.getElementById('modalOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal(e) { if (e.target === document.getElementById('modalOverlay')) closeModalDirect(); }
function closeModalDirect() { document.getElementById('modalOverlay').classList.remove('open'); document.body.style.overflow = ''; }
document.addEventListener('keydown', e => { if(e.key==='Escape') closeModalDirect(); });

function switchTab(tabId, btn) {
  document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.fw-tab').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+tabId).classList.add('active');
  btn.classList.add('active');
}

function setView(v) {
  currentView = v;
  const grid = document.getElementById('cardsGrid');
  grid.classList.toggle('list-view', v==='list');
  document.getElementById('gridBtn').classList.toggle('active', v==='grid');
  document.getElementById('listBtn').classList.toggle('active', v==='list');
}

function esc(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function statusLabel(s) { return { available:'✓ Available', prototype:'⚗ Prototype', planned:'⏳ Planned', not_core:'— Not Core' }[s]||s; }
function accessLabel(s) { return { open:'Open', mixed:'Mixed', proprietary_client:'Proprietary' }[s]||s; }
</script>
</body>
</html>