  {"original_name":"NDWI range delta between years","category":"Water quantity & quality","sub_category":"surface water extent","short_description":"Difference in annual mean NDWI between two distinct periods","TNFD_link":"LEAP-E (Evaluate): surface water availability as ecosystem condition; LEAP-L (Locate): locate surface water bodies; Dependency","TNFD_metric_type":"ecosystem condition \u2013 freshwater extent","TNFD_code":"C3.0","SBTN_link":"Realm: Freshwater; Steps: Assess, Track; Pressure: water extraction, land change; metric: surface water area trend","CSRD_ESRS_link":"ESRS E3-4 (water body condition targets); ESRS E4-5 (freshwater ecosystem extent)","India_relevance":"high","India_notes":"JRC Global Surface Water product (1984\u2013present) freely available on GEE. ISRO Bhuvan water body atlas maps 5M+ Indian water bodies. Seasonal dynamics critical in monsoon-driven India.","Darukaa_status":"available","input_data_required":"Landsat archive, Sentinel-2, NDWI time series","open_data_sources":["JRC Global Surface Water (Google EE)","ISRO Bhuvan Water Body Atlas","MODIS MOD44W","ESA WorldCover water class","NRSC wetland inventory"],"access_type":"open","computation_complexity":"low","example_use_case":"A hydropower company tracks seasonal surface water extent changes at reservoir sites in Karnataka using JRC data, disclosing freshwater ecosystem condition under ESRS E3-4 and TNFD Evaluate."},
  {"original_name":"Normalized Difference Moisture Index","category":"Water quantity & quality","sub_category":"soil & vegetation moisture","short_description":"NDMI \u2013 satellite index for vegetation water content and soil moisture","TNFD_link":"LEAP-E (Evaluate): soil moisture as ecosystem condition and agriculture dependency metric; Dependency","TNFD_metric_type":"dependencies \u2013 soil moisture / agricultural water","TNFD_code":"C3.0","SBTN_link":"Realm: Freshwater/Land; Steps: Assess, Track; Pressure: drought, land-use change; metric: soil moisture anomaly","CSRD_ESRS_link":"ESRS E3-3 (water consumed in agriculture); ESRS E4-5 (soil ecosystem condition)","India_relevance":"high","India_notes":"ESA CCI Soil Moisture product freely available. ISRO RISAT-based soil moisture research ongoing. IMD soil moisture index. High relevance for agricultural sector and BRSR ESG reporting.","Darukaa_status":"available","input_data_required":"Sentinel-1 SAR, SMAP, ESA CCI SM, ERA5-Land","open_data_sources":["ESA CCI Soil Moisture","NASA SMAP L4","ERA5-Land (Copernicus CDS)","Copernicus Global Land Service SM","IMD soil moisture index"],"access_type":"open","computation_complexity":"medium","example_use_case":"An agri-tech company in Madhya Pradesh uses satellite soil moisture to monitor irrigation dependency and discloses water consumption efficiency under ESRS E3-3 and TNFD freshwater dependency."},
  {"original_name":"NDMI annual range","category":"Water quantity & quality","sub_category":"soil & vegetation moisture","short_description":"Annual mean NDMI per pixel over selected period","TNFD_link":"LEAP-E (Evaluate): soil moisture as ecosystem condition and agriculture dependency metric; Dependency","TNFD_metric_type":"dependencies \u2013 soil moisture / agricultural water","TNFD_code":"C5.0","SBTN_link":"Realm: Freshwater/Land; Steps: Assess, Track; Pressure: drought, land-use change; metric: soil moisture anomaly","CSRD_ESRS_link":"ESRS E3-3 (water consumed in agriculture); ESRS E4-5 (soil ecosystem condition)","India_relevance":"high","India_notes":"ESA CCI Soil Moisture product freely available. ISRO RISAT-based soil moisture research ongoing. IMD soil moisture index. High relevance for agricultural sector and BRSR ESG reporting.","Darukaa_status":"available","input_data_required":"Sentinel-1 SAR, SMAP, ESA CCI SM, ERA5-Land","open_data_sources":["ESA CCI Soil Moisture","NASA SMAP L4","ERA5-Land (Copernicus CDS)","Copernicus Global Land Service SM","IMD soil moisture index"],"access_type":"open","computation_complexity":"medium","example_use_case":"An agri-tech company in Madhya Pradesh uses satellite soil moisture to monitor irrigation dependency and discloses water consumption efficiency under ESRS E3-3 and TNFD freshwater dependency."},
  {"original_name":"NDMI range delta between years","category":"Water quantity & quality","sub_category":"soil & vegetation moisture","short_description":"Difference in annual mean NDMI between two distinct periods","TNFD_link":"LEAP-E (Evaluate): soil moisture as ecosystem condition and agriculture dependency metric; Dependency","TNFD_metric_type":"dependencies \u2013 soil moisture / agricultural water","TNFD_code":"C5.0","SBTN_link":"Realm: Freshwater/Land; Steps: Assess, Track; Pressure: drought, land-use change; metric: soil moisture anomaly","CSRD_ESRS_link":"ESRS E3-3 (water consumed in agriculture); ESRS E4-5 (soil ecosystem condition)","India_relevance":"high","India_notes":"ESA CCI Soil Moisture product freely available. ISRO RISAT-based soil moisture research ongoing. IMD soil moisture index. High relevance for agricultural sector and BRSR ESG reporting.","Darukaa_status":"available","input_data_required":"Sentinel-1 SAR, SMAP, ESA CCI SM, ERA5-Land","open_data_sources":["ESA CCI Soil Moisture","NASA SMAP L4","ERA5-Land (Copernicus CDS)","Copernicus Global Land Service SM","IMD soil moisture index"],"access_type":"open","computation_complexity":"medium","example_use_case":"An agri-tech company in Madhya Pradesh uses satellite soil moisture to monitor irrigation dependency and discloses water consumption efficiency under ESRS E3-3 and TNFD freshwater dependency."},
  {"original_name":"Artificial light intensity","category":"Air quality & pollution","sub_category":"light pollution","short_description":"Nighttime artificial light intensity (light pollution) from satellite","TNFD_link":"LEAP-E (Evaluate): artificial light as pressure on biodiversity (nocturnal species); Impact","TNFD_metric_type":"impacts \u2013 light pollution / nocturnal biodiversity","TNFD_code":"C1.0 | C1.1","SBTN_link":"Realm: Land; Steps: Assess; Pressure: light pollution; metric: nighttime radiance","CSRD_ESRS_link":"ESRS E4-5 (ecosystem condition \u2013 light pollution pressure on species)","India_relevance":"medium","India_notes":"VIIRS DNB (Day/Night Band) provides annual nighttime light data globally. Relevant for coastal development near sea turtle nesting beaches (Odisha, Tamil Nadu) and forest-fringe urban sprawl.","Darukaa_status":"planned","input_data_required":"VIIRS DNB, Landsat-8/9 OLI nighttime, ground light monitoring","open_data_sources":["NOAA/NASA VIIRS DNB Annual","Earth at Night (NASA)","ISRO NRSC nighttime data","Light Pollution Map (lightpollutionmap.info)","DSMP-OLS archive"],"access_type":"open","computation_complexity":"low","example_use_case":"A coastal infrastructure developer near Odisha's Olive Ridley nesting beaches uses VIIRS light data to assess light pollution impact on sea turtles for TNFD Evaluate biodiversity disclosure."},
  {"original_name":"Light pollution annual range","category":"Air quality & pollution","sub_category":"light pollution","short_description":"Annual mean artificial light intensity per pixel over selected period","TNFD_link":"LEAP-E (Evaluate): artificial light as pressure on biodiversity (nocturnal species); Impact","TNFD_metric_type":"impacts \u2013 light pollution / nocturnal biodiversity","TNFD_code":"C1.0 | C1.1","SBTN_link":"Realm: Land; Steps: Assess; Pressure: light pollution; metric: nighttime radiance","CSRD_ESRS_link":"ESRS E4-5 (ecosystem condition \u2013 light pollution pressure on species)","India_relevance":"medium","India_notes":"VIIRS DNB (Day/Night Band) provides annual nighttime light data globally. Relevant for coastal development near sea turtle nesting beaches (Odisha, Tamil Nadu) and forest-fringe urban sprawl.","Darukaa_status":"planned","input_data_required":"VIIRS DNB, Landsat-8/9 OLI nighttime, ground light monitoring","open_data_sources":["NOAA/NASA VIIRS DNB Annual","Earth at Night (NASA)","ISRO NRSC nighttime data","Light Pollution Map (lightpollutionmap.info)","DSMP-OLS archive"],"access_type":"open","computation_complexity":"low","example_use_case":"A coastal infrastructure developer near Odisha's Olive Ridley nesting beaches uses VIIRS light data to assess light pollution impact on sea turtles for TNFD Evaluate biodiversity disclosure."},
  {"original_name":"Light pollution range delta","category":"Air quality & pollution","sub_category":"light pollution","short_description":"Difference in annual mean light pollution between two distinct periods","TNFD_link":"LEAP-E (Evaluate): artificial light as pressure on biodiversity (nocturnal species); Impact","TNFD_metric_type":"impacts \u2013 light pollution / nocturnal biodiversity","TNFD_code":"C5.0","SBTN_link":"Realm: Land; Steps: Assess; Pressure: light pollution; metric: nighttime radiance","CSRD_ESRS_link":"ESRS E4-5 (ecosystem condition \u2013 light pollution pressure on species)","India_relevance":"medium","India_notes":"VIIRS DNB (Day/Night Band) provides annual nighttime light data globally. Relevant for coastal development near sea turtle nesting beaches (Odisha, Tamil Nadu) and forest-fringe urban sprawl.","Darukaa_status":"planned","input_data_required":"VIIRS DNB, Landsat-8/9 OLI nighttime, ground light monitoring","open_data_sources":["NOAA/NASA VIIRS DNB Annual","Earth at Night (NASA)","ISRO NRSC nighttime data","Light Pollution Map (lightpollutionmap.info)","DSMP-OLS archive"],"access_type":"open","computation_complexity":"low","example_use_case":"A coastal infrastructure developer near Odisha's Olive Ridley nesting beaches uses VIIRS light data to assess light pollution impact on sea turtles for TNFD Evaluate biodiversity disclosure."},
  {"original_name":"Built-up Surface Fraction","category":"Land use, land cover & fragmentation","sub_category":"land artificialization","short_description":"Fraction of land covered by built-up/artificial surfaces","TNFD_link":"LEAP-L: locate where land has been sealed/built up; LEAP-E: assess ecosystem loss from impermeability; Impact & Dependency","TNFD_metric_type":"ecosystem condition \u2013 land impermeability / seal","TNFD_code":"C1.0 | C1.1","SBTN_link":"Realm: Land; Steps: Assess, Act; Pressure: land-use change \u2013 urban expansion; metric: sealed surface %","CSRD_ESRS_link":"ESRS E4-5 (ecosystem extent \u2013 artificial surfaces); ESRS E3-3 (water targets, runoff); ESRS E2-5 (soil)","India_relevance":"high","India_notes":"Urban sprawl fastest in Tier-2/3 Indian cities (Pune, Surat, Hyderabad). ISRO LULC and Copernicus GHSL provide built-up fraction. National Urban Digital Mission data complementary.","Darukaa_status":"available","input_data_required":"satellite LULC, built-up surface layer, DEM","open_data_sources":["GHSL Global Human Settlement Layer","ISRO LULC Bhuvan","ESA WorldCover","Copernicus Urban Atlas","Google Open Buildings India"],"access_type":"open","computation_complexity":"low","example_use_case":"A real estate developer in Bangalore quantifies the fraction of new built-up area replacing natural land over 5 years for TNFD Locate disclosures and ESRS E4-5 reporting."},
  {"original_name":"Population Density","category":"Socio-environmental & exposure","sub_category":"demographic exposure","short_description":"Number of inhabitants per unit area","TNFD_link":"LEAP-L (Locate): population exposure as context for nature-related risks; Risk & Impact","TNFD_metric_type":"exposure index \u2013 population density","TNFD_code":"No Annex 1/2 code \u2014 relates to TNFD Strategy D (priority locations) and stakeholder engagement guidance","SBTN_link":"Realm: Land; Steps: Assess; Pressure: urbanisation; metric: persons/km\u00b2 in risk zones","CSRD_ESRS_link":"ESRS S3-3 (affected communities \u2013 identification); ESRS E1-9 (exposed population to physical risk)","India_relevance":"high","India_notes":"India's 2011 Census gridded data and WorldPop 100m available. GHSL provides built-up and population at 100m. High relevance for climate risk + community exposure assessment.","Darukaa_status":"not_core","input_data_required":"WorldPop, GHSL, India Census 2011 data","open_data_sources":["WorldPop India 100m","GHSL Global Human Settlement","India Census 2011 (villages)","Meta High Resolution Population Density","GPWv4 (CIESIN)"],"access_type":"open","computation_complexity":"low","example_use_case":"A bank screens its project finance exposure in flood-prone areas by overlaying population density with flood hazard maps for ESRS S3-3 community identification and TNFD Locate disclosures."},
  {"original_name":"Aridity (map)","category":"Water quantity & quality","sub_category":"water stress & aridity","short_description":"Aridity index based on ratio of precipitation to evapotranspiration","TNFD_link":"LEAP-L (Locate): identify water-stressed locations; LEAP-E (Evaluate): assess water dependency risk; Dependency & Risk","TNFD_metric_type":"dependencies \u2013 water stress / freshwater availability","TNFD_code":"C3.0","SBTN_link":"Realm: Freshwater; Steps: Assess, Interpret; Pressure: water withdrawal vs availability; metric: BWS (Baseline Water Stress)","CSRD_ESRS_link":"ESRS E3-1 (water stress areas policy); ESRS E3-4 (water targets in stressed areas); ESRS E3-3 (water withdrawal)","India_relevance":"high","India_notes":"India has 18% of world population but 4% freshwater. WRI Aqueduct India data freely available. CWC water availability data at sub-basin level. High relevance for manufacturing, agri, textile sectors.","Darukaa_status":"available","input_data_required":"WRI Aqueduct data, CWC streamflow data, GRACE groundwater, LULC","open_data_sources":["WRI Aqueduct 4.0","CWC India water data","NASA GRACE groundwater anomaly","IMD precipitation data","FAO AQUASTAT India"],"access_type":"open","computation_complexity":"low","example_use_case":"A textile company in Tirupur uses WRI Aqueduct data to identify high water-stress sourcing locations and discloses under ESRS E3-1 water stress policy and TNFD Locate disclosures."},
  {"original_name":"Hydrogeological flood risk","category":"Climate & physical risk","sub_category":"flood & hydrogeological risk","short_description":"Spatial map of hydrogeological flood risk","TNFD_link":"LEAP-A (Assess): acute physical flood risk at site; LEAP-P (Prepare): risk management; Risk disclosure","TNFD_metric_type":"physical risk \u2013 flood","TNFD_code":"IFRS S2","SBTN_link":"Realm: Freshwater/Land; Steps: Assess, Prioritise; Pressure: flood, precipitation change; metric: flood return period, assets at risk","CSRD_ESRS_link":"ESRS E1-9 (flood physical risk); ESRS E3-4 (water-related disaster risk)","India_relevance":"high","India_notes":"India's CWC (Central Water Commission) maintains flood hazard maps for 150+ river basins. NDMA flood risk atlas, ISRO NRSC flood mapping products. High relevance for Bihar, Assam, Maharashtra coasts.","Darukaa_status":"available","input_data_required":"DEM, river network, rainfall data, flood hazard maps, land use","open_data_sources":["CWC India flood hazard maps","NDMA flood risk atlas","JRC Global Flood Database","Copernicus EMS","ISRO NRSC flood monitoring"],"access_type":"mixed","computation_complexity":"medium","example_use_case":"A logistics company assesses flood risk to its warehouses across the Brahmaputra floodplain using CWC flood maps and discloses exposure under ESRS E1-9 acute physical risk metrics."},
  {"original_name":"Evapotranspiration (map)","category":"Water quantity & quality","sub_category":"water balance","short_description":"Actual evapotranspiration derived from satellite data","TNFD_link":"LEAP-E (Evaluate): evapotranspiration as water balance component and ecosystem service; Dependency","TNFD_metric_type":"dependencies \u2013 water balance / evapotranspiration","TNFD_code":"C3.0","SBTN_link":"Realm: Freshwater; Steps: Assess; Pressure: drought, climate change; metric: ET ratio to PET","CSRD_ESRS_link":"ESRS E3-3 (water consumption); ESRS E3-4 (water balance targets)","India_relevance":"high","India_notes":"MODIS MOD16 ET product widely used in India. IMD provides PET at district level. High relevance for irrigation planning, water utilities, and ecosystem restoration monitoring.","Darukaa_status":"available","input_data_required":"MODIS MOD16, ERA5-Land ET, meteorological forcing data","open_data_sources":["MODIS MOD16 ET (NASA)","ERA5-Land ET (Copernicus)","FAO WaPOR water productivity","GLEAM evapotranspiration","IMD PET data"],"access_type":"open","computation_complexity":"medium","example_use_case":"A sugarcane grower in Maharashtra tracks actual evapotranspiration vs potential ET to quantify crop water stress and disclose water consumption under ESRS E3-3."},
  {"original_name":"Degree of Urbanization","category":"Land use, land cover & fragmentation","sub_category":"land artificialization","short_description":"Classification of land by degree of urban development","TNFD_link":"LEAP-L: locate where land has been sealed/built up; LEAP-E: assess ecosystem loss from impermeability; Impact & Dependency","TNFD_metric_type":"ecosystem condition \u2013 land impermeability / seal","TNFD_code":"C1.0 | C1.1","SBTN_link":"Realm: Land; Steps: Assess, Act; Pressure: land-use change \u2013 urban expansion; metric: sealed surface %","CSRD_ESRS_link":"ESRS E4-5 (ecosystem extent \u2013 artificial surfaces); ESRS E3-3 (water targets, runoff); ESRS E2-5 (soil)","India_relevance":"high","India_notes":"Urban sprawl fastest in Tier-2/3 Indian cities (Pune, Surat, Hyderabad). ISRO LULC and Copernicus GHSL provide built-up fraction. National Urban Digital Mission data complementary.","Darukaa_status":"available","input_data_required":"satellite LULC, built-up surface layer, DEM","open_data_sources":["GHSL Global Human Settlement Layer","ISRO LULC Bhuvan","ESA WorldCover","Copernicus Urban Atlas","Google Open Buildings India"],"access_type":"open","computation_complexity":"low","example_use_case":"A real estate developer in Bangalore quantifies the fraction of new built-up area replacing natural land over 5 years for TNFD Locate disclosures and ESRS E4-5 reporting."},
  {"original_name":"Protected natural areas","category":"Compliance & proximity to protected/sensitive areas","sub_category":"protected area coverage","short_description":"Spatial layer of legally protected natural areas","TNFD_link":"LEAP-L (Locate): mandatory step to identify operations in/near protected areas; Compliance & Risk","TNFD_metric_type":"compliance \u2013 protected area proximity","TNFD_code":"C5.0 | IFRS S2 | C1.1","SBTN_link":"Realm: Land/Freshwater/Ocean; Steps: Assess, Interpret; Pressure: all; metric: % operations in/near protected areas","CSRD_ESRS_link":"ESRS E4-1 (biodiversity-sensitive areas \u2013 protected area proximity); ESRS E4-2 (policy for sensitive areas)","India_relevance":"high","India_notes":"India has 900+ Protected Areas (National Parks, Sanctuaries, Conservation Reserves) under WPA 1972, plus Eco-Sensitive Zones (ESZ) under EPA. MoEFCC and ENVIS PA data. SEAC/SEIAA require PA proximity in EIA.","Darukaa_status":"available","input_data_required":"WDPA protected areas, MoEFCC PA boundaries, ESZ notifications, IBA polygons","open_data_sources":["WCMC WDPA (Protected Planet)","MoEFCC India PA database","BirdLife IBA India","IUCN WDPA API","WII PA network India"],"access_type":"open","computation_complexity":"low","example_use_case":"An infrastructure company screens all proposed project sites against WDPA and ESZ boundaries as part of TNFD Locate step and ESRS E4-1 biodiversity-sensitive area identification for EIA compliance."},
  {"original_name":"European ecosystems classification","category":"Land use, land cover & fragmentation","sub_category":"land cover classification","short_description":"Land cover / ecosystem type classification based on European CLC standard","TNFD_link":"LEAP-L (Locate): baseline spatial context; LEAP-E (Evaluate): land-cover change as ecosystem condition proxy; Impact disclosure","TNFD_metric_type":"ecosystem condition \u2013 land cover","TNFD_code":"C1.0 | C1.1","SBTN_link":"Realm: Land; Steps: Assess & Track; Pressure: land-use change; metric: % natural land cover","CSRD_ESRS_link":"ESRS E4-5 (ecosystem extent); ESRS E4-4 (targets on biodiversity); ESRS E2-5 (soil contamination)","India_relevance":"high","India_notes":"India's national LULC maps available at 1:50K from ISRO/NRSC via Bhuvan portal. ESA WorldCover 10m and Dynamic World 10m usable for annual change detection. State Forest Reports (FSI) for forest class.","Darukaa_status":"available","input_data_required":"multispectral satellite imagery, ground reference data","open_data_sources":["ISRO LULC 1:50K (Bhuvan)","ESA WorldCover 10m","Google Dynamic World","FSI India Forest Cover maps","MODIS MCD12Q1"],"access_type":"open","computation_complexity":"medium","example_use_case":"A plantation company tracks annual changes in natural land cover across its concession in Madhya Pradesh using national LULC data to comply with ESRS E4-5 ecosystem extent disclosures."},
  {"original_name":"Wildlife corridors","category":"Biodiversity & ecosystems","sub_category":"habitat connectivity & fragmentation","short_description":"Spatial mapping of ecological connectivity corridors for wildlife movement","TNFD_link":"LEAP-E (Evaluate): assess fragmentation as pressure on ecosystems; LEAP-A: quantify connectivity loss; Impact disclosure","TNFD_metric_type":"ecosystem condition \u2013 habitat connectivity","TNFD_code":"C1.1 | IFRS S2","SBTN_link":"Realm: Land; Steps: Assess, Act; Pressure: fragmentation, infrastructure; metric: effective mesh size, wildlife corridor integrity","CSRD_ESRS_link":"ESRS E4-5 (ecosystem extent and condition, connectivity); ESRS E4-2 (restoration targets incl. corridor restoration)","India_relevance":"high","India_notes":"India's wildlife corridors (e.g., Terai Arc, Elephant corridors) catalogued by WII. Fragmentation assessment critical for linear infra (roads, railways, power lines). Use NCBS/WII corridor maps + OSM road network.","Darukaa_status":"available","input_data_required":"LULC, road network, DEM, protected area polygons, species movement data","open_data_sources":["WII Wildlife Corridors India","OSM road network","ESA WorldCover","ISRO LULC Bhuvan","WCMC WDPA"],"access_type":"mixed","computation_complexity":"high","example_use_case":"A highway project developer uses wildlife corridor mapping to route a new road around critical elephant movement paths, documenting the avoidance measure in TNFD Assess disclosures."},
  {"original_name":"Stepping stone habitats","category":"Biodiversity & ecosystems","sub_category":"habitat connectivity & fragmentation","short_description":"Isolated habitat patches that support species movement between larger areas","TNFD_link":"LEAP-E (Evaluate): assess fragmentation as pressure on ecosystems; LEAP-A: quantify connectivity loss; Impact disclosure","TNFD_metric_type":"ecosystem condition \u2013 habitat connectivity","TNFD_code":"C1.1 | C5.0","SBTN_link":"Realm: Land; Steps: Assess, Act; Pressure: fragmentation, infrastructure; metric: effective mesh size, wildlife corridor integrity","CSRD_ESRS_link":"ESRS E4-5 (ecosystem extent and condition, connectivity); ESRS E4-2 (restoration targets incl. corridor restoration)","India_relevance":"high","India_notes":"India's wildlife corridors (e.g., Terai Arc, Elephant corridors) catalogued by WII. Fragmentation assessment critical for linear infra (roads, railways, power lines). Use NCBS/WII corridor maps + OSM road network.","Darukaa_status":"available","input_data_required":"LULC, road network, DEM, protected area polygons, species movement data","open_data_sources":["WII Wildlife Corridors India","OSM road network","ESA WorldCover","ISRO LULC Bhuvan","WCMC WDPA"],"access_type":"mixed","computation_complexity":"high","example_use_case":"A highway project developer uses wildlife corridor mapping to route a new road around critical elephant movement paths, documenting the avoidance measure in TNFD Assess disclosures."},
  {"original_name":"Ecological transition areas","category":"Biodiversity & ecosystems","sub_category":"habitat connectivity & fragmentation","short_description":"Ecotone areas at the boundary between distinct habitat types","TNFD_link":"LEAP-E (Evaluate): assess fragmentation as pressure on ecosystems; LEAP-A: quantify connectivity loss; Impact disclosure","TNFD_metric_type":"ecosystem condition \u2013 habitat connectivity","TNFD_code":"C1.1","SBTN_link":"Realm: Land; Steps: Assess, Act; Pressure: fragmentation, infrastructure; metric: effective mesh size, wildlife corridor integrity","CSRD_ESRS_link":"ESRS E4-5 (ecosystem extent and condition, connectivity); ESRS E4-2 (restoration targets incl. corridor restoration)","India_relevance":"high","India_notes":"India's wildlife corridors (e.g., Terai Arc, Elephant corridors) catalogued by WII. Fragmentation assessment critical for linear infra (roads, railways, power lines). Use NCBS/WII corridor maps + OSM road network.","Darukaa_status":"available","input_data_required":"LULC, road network, DEM, protected area polygons, species movement data","open_data_sources":["WII Wildlife Corridors India","OSM road network","ESA WorldCover","ISRO LULC Bhuvan","WCMC WDPA"],"access_type":"mixed","computation_complexity":"high","example_use_case":"A highway project developer uses wildlife corridor mapping to route a new road around critical elephant movement paths, documenting the avoidance measure in TNFD Assess disclosures."},
  {"original_name":"Carbon stock overview","category":"Carbon & GHG","sub_category":"carbon stock overview","short_description":"Overview map combining above-ground, below-ground, and soil organic carbon stocks","TNFD_link":"LEAP-E (Evaluate): carbon stock as ecosystem provisioning service; LEAP-A (Assess): impact of land-use change on carbon; Dependency & Impact","TNFD_metric_type":"dependencies \u2013 carbon sequestration / ecosystem service","TNFD_code":"C5.0","SBTN_link":"Realm: Land; Steps: Assess, Track; Pressure: land-use change, degradation; metric: tCO\u2082e/ha stored","CSRD_ESRS_link":"ESRS E4-5 (carbon stocks in ecosystems \u2013 sequestration service); ESRS E1-3 (GHG removals from LULUCF)","India_relevance":"high","India_notes":"India's FSI estimates national forest carbon stocks; ISRO CARBONS project maps above-ground biomass. Global products: ESA CCI Biomass, Global Carbon Stock (Spawn et al.). NATCOM uses IPCC LULUCF methodology.","Darukaa_status":"available","input_data_required":"SAR/optical biomass model, LULC, allometric equations, soil data","open_data_sources":["ESA CCI Biomass 100m","GFW Carbon stocks (Spawn et al.)","ISRO CARBONS project India","FSI India biomass estimates","IPCC LULUCF Tier 2 data"],"access_type":"mixed","computation_complexity":"high","example_use_case":"A forestry company in Arunachal Pradesh quantifies above-ground biomass carbon stocks across its concession using ESA CCI Biomass data to disclose LULUCF removals under ESRS E1-3 and TNFD carbon dependency."},
  {"original_name":"Current above-ground biomass carbon","category":"Carbon & GHG","sub_category":"biomass carbon stock","short_description":"Carbon stored in above-ground living biomass","TNFD_link":"LEAP-E (Evaluate): carbon stock as ecosystem provisioning service; LEAP-A (Assess): impact of land-use change on carbon; Dependency & Impact","TNFD_metric_type":"dependencies \u2013 carbon sequestration / ecosystem service","TNFD_code":"C5.0","SBTN_link":"Realm: Land; Steps: Assess, Track; Pressure: land-use change, degradation; metric: tCO\u2082e/ha stored","CSRD_ESRS_link":"ESRS E4-5 (carbon stocks in ecosystems \u2013 sequestration service); ESRS E1-3 (GHG removals from LULUCF)","India_relevance":"high","India_notes":"India's FSI estimates national forest carbon stocks; ISRO CARBONS project maps above-ground biomass. Global products: ESA CCI Biomass, Global Carbon Stock (Spawn et al.). NATCOM uses IPCC LULUCF methodology.","Darukaa_status":"available","input_data_required":"SAR/optical biomass model, LULC, allometric equations, soil data","open_data_sources":["ESA CCI Biomass 100m","GFW Carbon stocks (Spawn et al.)","ISRO CARBONS project India","FSI India biomass estimates","IPCC LULUCF Tier 2 data"],"access_type":"mixed","computation_complexity":"high","example_use_case":"A forestry company in Arunachal Pradesh quantifies above-ground biomass carbon stocks across its concession using ESA CCI Biomass data to disclose LULUCF removals under ESRS E1-3 and TNFD carbon dependency."},
  {"original_name":"Current below-ground biomass carbon","category":"Carbon & GHG","sub_category":"biomass carbon stock","short_description":"Carbon stored in below-ground living biomass (roots)","TNFD_link":"LEAP-E (Evaluate): carbon stock as ecosystem provisioning service; LEAP-A (Assess): impact of land-use change on carbon; Dependency & Impact","TNFD_metric_type":"dependencies \u2013 carbon sequestration / ecosystem service","TNFD_code":"C5.0","SBTN_link":"Realm: Land; Steps: Assess, Track; Pressure: land-use change, degradation; metric: tCO\u2082e/ha stored","CSRD_ESRS_link":"ESRS E4-5 (carbon stocks in ecosystems \u2013 sequestration service); ESRS E1-3 (GHG removals from LULUCF)","India_relevance":"high","India_notes":"India's FSI estimates national forest carbon stocks; ISRO CARBONS project maps above-ground biomass. Global products: ESA CCI Biomass, Global Carbon Stock (Spawn et al.). NATCOM uses IPCC LULUCF methodology.","Darukaa_status":"available","input_data_required":"SAR/optical biomass model, LULC, allometric equations, soil data","open_data_sources":["ESA CCI Biomass 100m","GFW Carbon stocks (Spawn et al.)","ISRO CARBONS project India","FSI India biomass estimates","IPCC LULUCF Tier 2 data"],"access_type":"mixed","computation_complexity":"high","example_use_case":"A forestry company in Arunachal Pradesh quantifies above-ground biomass carbon stocks across its concession using ESA CCI Biomass data to disclose LULUCF removals under ESRS E1-3 and TNFD carbon dependency."},
