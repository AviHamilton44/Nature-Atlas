  {"original_name":"MSA Land Use - Animals","category":"Biodiversity & ecosystems","sub_category":"mean species abundance","short_description":"Land use MSA component for animal species","TNFD_link":"LEAP-E (Evaluate): core metric for biodiversity intactness; LEAP-A (Assess): quantify nature-related impacts from land use; Impacts & Dependencies","TNFD_metric_type":"ecosystem condition \u2013 biodiversity intactness","TNFD_code":"C1.0 | C1.1 | C5.0","SBTN_link":"Realm: Land; Steps: Assess, Interpret, Track; Pressure: land-use change, fragmentation, climate change; metric: MSA loss (PDF.m\u00b2.yr)","CSRD_ESRS_link":"ESRS E4-5 (biodiversity state \u2013 species abundance); ESRS E4-DR (due diligence policies); IRO assessment","India_relevance":"high","India_notes":"GLOBIO/PBL MSA model applicable globally including India. Local calibration needed; use NBSAP species-richness data or WII survey data for ground-truthing. High relevance for mining, infrastructure, and plantation sectors.","Darukaa_status":"available","input_data_required":"LULC map, road network, climate data, species-habitat models","open_data_sources":["PBL GLOBIO4 model","ESA WorldCover 10m","ISRO LULC 1:50K (Bhuvan)","OpenStreetMap road network","GBIF species occurrence"],"access_type":"mixed","computation_complexity":"high","example_use_case":"An infrastructure developer submits MSA scores to TNFD disclosures to show projected biodiversity impact of a highway corridor through a biodiversity hotspot in the Western Ghats."},
  {"original_name":"Pollination Abundance","category":"Biodiversity & ecosystems","sub_category":"pollination & ecosystem services","short_description":"Total pollination abundance index combining all bee guilds","TNFD_link":"LEAP-E: dependency on ecosystem services (pollination); LEAP-A: assess risk to service continuity; Dependencies & Opportunities","TNFD_metric_type":"dependencies \u2013 pollination ecosystem service","TNFD_code":"C5.0","SBTN_link":"Realm: Land; Steps: Assess & Track; Pressure: habitat loss, pesticide use; metric: pollinator abundance index","CSRD_ESRS_link":"ESRS E4-5 (ecosystem services \u2013 pollination); ESRS E4-2 (policies on biodiversity); IRO dependency disclosure","India_relevance":"high","India_notes":"India supports ~700 wild bee species; pollination dependency critical for >60% of food crops. ICAR data on crop-pollinator relationships available. ISRO landcover + floral phenology models applicable.","Darukaa_status":"available","input_data_required":"LULC map, floral resource layer, nesting substrate map, pesticide application data","open_data_sources":["ESA WorldCover","ISRO Bhuvan LULC","GBIF pollinator occurrences","InVEST Pollination model","ICAR crop-pollination studies"],"access_type":"mixed","computation_complexity":"high","example_use_case":"A food & beverage company maps pollinator abundance across its sourcing landscapes in Karnataka to quantify dependency and disclose under TNFD ecosystem service dependencies."},
